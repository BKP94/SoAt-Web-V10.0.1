@page "/"

<PageTitle>scAtm — ระบบเอทีเอ็ม</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="home">
            <header class="home-hero">
                <div class="home-hero-text">
                    <h1 class="home-title">สวัสดี คุณ@(context.User.Identity?.Name)</h1>
                    <p class="home-sub">
                        ระบบเอทีเอ็ม — เลือกงานจากเมนูด้านซ้ายได้เลย
                    </p>
                </div>
                <span class="home-hero-badge">scAtm</span>
            </header>

            <section class="home-section">
                <h2 class="home-section-title">เริ่มงานด่วน</h2>
                <div class="home-cards">
                    <div class="home-card home-card--soon">
                        <span class="home-card-icon">🛠️</span>
                        <span class="home-card-name">อยู่ระหว่างพัฒนา</span>
                        <span class="home-card-desc">เร็วๆ นี้</span>
                    </div>
                </div>
            </section>
        </div>
    </Authorized>
</AuthorizeView>

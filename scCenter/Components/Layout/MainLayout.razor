@inherits LayoutComponentBase

<div class="app-shell">
    <header class="app-topbar">
        <a class="app-brand" href="/">SoAt</a>

        <div class="app-topbar-spacer"></div>

        <AuthorizeView>
            <Authorized>
                <span class="app-user">@context.User.Identity?.Name</span>
                <form method="post" action="/logout" class="app-logout-form">
                    <AntiforgeryToken />
                    <button type="submit" class="app-logout">ออกจากระบบ</button>
                </form>
            </Authorized>
            <NotAuthorized>
                <a class="app-login-link" href="/login">เข้าสู่ระบบ</a>
            </NotAuthorized>
        </AuthorizeView>
    </header>

    <main class="app-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

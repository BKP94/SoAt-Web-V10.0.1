@page "/"
@layout LauncherLayout
@rendermode InteractiveServer
@implements IDisposable
@using SoAt.Application.Sc
@using Microsoft.AspNetCore.Antiforgery
@inject IScAppService ScApps
@inject IConfiguration Config
@inject IJSRuntime JS
@inject sc.dbFactory DbFactory
@inject IAntiforgery Antiforgery
@inject IHttpContextAccessor HttpAccessor
@inject PersistentComponentState AppState

<PageTitle>ระบบบริหารงานสหกรณ์ออมทรัพย์ — SoAt</PageTitle>

<div class="portal">

    @* ── Header + hero ─────────────────────────────────────── *@
    <header class="pt-header">
        <div class="pt-header-inner">
            <img class="pt-logo" src="ImgMenu/Logo_SoAt.png" alt="SO-AT Solution" />
        </div>

        <div class="pt-hero">
            <div class="pt-hero-art pt-hero-art--left" aria-hidden="true">
                <img src="ImgMenu/Image_1.png" alt="" />
            </div>

            <div class="pt-hero-content">
                <div class="pt-kicker">SO-AT SOLUTION CENTER</div>
                <h1>ศูนย์รวมทุกระบบงาน</h1>
                <p>เข้าถึงทุกระบบงานได้อย่างง่ายดาย ครบจบในที่เดียว</p>

                @* Presentation-only: Claude Code จะผูก state และ filter logic ภายหลัง *@
                <div class="pt-search">
                    <i class="bi bi-search" aria-hidden="true"></i>
                    <DxTextBox NullText="ค้นหาระบบที่คุณต้องการ..." />
                </div>

                <div class="pt-status" aria-label="ข้อมูลการใช้งานระบบ">
                    <div class="pt-status-item">
                        <i class="bi bi-person-circle" aria-hidden="true"></i>
                        <span class="pt-status-label">ผู้ใช้งาน</span>
                        <strong>@UserName</strong>
                        <span class="pt-status-separator" aria-hidden="true">·</span>
                        <span class="pt-status-label">สาขา</span>
                        <strong>@BranchId</strong>
                    </div>
                    <div class="pt-status-item">
                        <i class="bi bi-calendar3" aria-hidden="true"></i>
                        <span class="pt-status-label">วันที่การเงิน</span>
                        <strong>@(_info?.FinanceDate ?? "—")</strong>
                    </div>
                    <div class="pt-status-item">
                        <i class="bi bi-database" aria-hidden="true"></i>
                        <span class="pt-status-label">ฐานข้อมูล</span>
                        <strong>@SysName</strong>
                    </div>
                </div>
            </div>

            <div class="pt-hero-art pt-hero-art--right" aria-hidden="true">
                <img src="ImgMenu/Image_2.png" alt="" />
            </div>
        </div>
    </header>

    @if (_apps is null)
    {
        <div class="pt-loading">กำลังโหลด…</div>
    }
    else
    {
        @* ── Pinned ───────────────────────────────────────── *@
        @if (_favApps.Count > 0)
        {
            <section class="pt-section pt-section--pinned">
                <h2 class="pt-h2"><span class="pt-h2-ic">★</span> ปักหมุด</h2>
                <div class="pt-grid">
                    @foreach (var app in _favApps) { @Card(app) }
                </div>
            </section>
        }

        @* ── Category buttons ──────────────────────────────── *@
        <section class="pt-categories" aria-labelledby="category-title">
            <h2 id="category-title">หมวดหมู่ระบบ</h2>
            <nav class="pt-category-grid" aria-label="หมวดหมู่ระบบ">
                <div class="pt-category-item">
                    <DxButton Text="ทั้งหมด"
                              IconCssClass="bi bi-grid"
                              RenderStyle="@(SelectedCat is null ? ButtonRenderStyle.Primary : ButtonRenderStyle.Light)"
                              RenderStyleMode="ButtonRenderStyleMode.Contained"
                              Click="() => SelectedCat = null" />
                </div>
            @foreach (var c in _categories)
            {
                    <div class="pt-category-item">
                        <DxButton Text="@c"
                                  IconCssClass="@(c switch
                                  {
                                      "ผู้ดูแลระบบ" => "bi bi-shield-check",
                                      "สมาชิก & สวัสดิการ" => "bi bi-people",
                                      "หน้าเคาน์เตอร์" => "bi bi-gear",
                                      "หลังบ้าน & รายงาน" => "bi bi-bar-chart",
                                      _ => "bi bi-grid"
                                  })"
                                  RenderStyle="@(SelectedCat == c ? ButtonRenderStyle.Primary : ButtonRenderStyle.Light)"
                                  RenderStyleMode="ButtonRenderStyleMode.Contained"
                                  Click="() => SelectedCat = c" />
                    </div>
            }
            </nav>
        </section>

        @* ── Main grid ────────────────────────────────────── *@
        <section class="pt-section">
            <div class="pt-grid">
                @foreach (var app in Filtered) { @Card(app) }
            </div>
            @if (!Filtered.Any())
            {
                <div class="pt-empty">ไม่มีระบบงานในหมวดนี้</div>
            }
        </section>
    }
</div>

@* ── Login overlay popup (เด้งทับ landing เมื่อคลิกระบบที่ยังไม่ login) ──────────
   form เป็น native POST ไป /auth/login (full page) — antiforgery token มาจาก
   prerender ผ่าน PersistentComponentState (Home เป็น interactive จึงเรียก
   AntiforgeryToken component ตรงๆ ไม่ได้) *@
<div class="lg-overlay @(_showLogin ? "is-open" : "")"
     role="dialog"
     aria-modal="true"
     aria-labelledby="login-dialog-title">
    <div class="lg-overlay-back" @onclick="CloseLogin"></div>
    <div class="lg-pop">
        <button type="button" class="lg-modal-x" @onclick="CloseLogin" aria-label="ปิด">
            <i class="bi bi-x-lg" aria-hidden="true"></i>
        </button>

        @* ── แผงแบรนด์ (ซ้าย) ─────────────────────────────── *@
        <aside class="lg-brand">
            <div class="lg-brand-head">
                <img class="lg-brand-logo" src="ImgMenu/Logo_SoAt.png" alt="SO-AT Solution" />
                <span>SO-AT SOLUTION CENTER</span>
            </div>

            <div class="lg-brand-copy">
                <div class="lg-brand-chip">
                    <i class="bi bi-shield-check" aria-hidden="true"></i>
                    Secure workspace
                </div>
                <h2>ทุกระบบงาน<br /><span>เริ่มต้นที่นี่</span></h2>
                <p>เชื่อมต่อระบบบริหารงานสหกรณ์ทั้งหมด<br />ด้วยบัญชีเดียวอย่างปลอดภัย</p>
                <div class="lg-brand-benefits" aria-label="จุดเด่นของระบบ">
                    <span><i class="bi bi-check-circle-fill" aria-hidden="true"></i> เข้าใช้งานง่าย</span>
                    <span><i class="bi bi-check-circle-fill" aria-hidden="true"></i> ข้อมูลปลอดภัย</span>
                </div>
            </div>

            <div class="lg-brand-art" aria-hidden="true">
                <img src="ImgMenu/Image_2.png" alt="" />
            </div>

            <div class="lg-brand-foot">
                <span class="lg-brand-status"><i aria-hidden="true"></i> ระบบพร้อมใช้งาน</span>
                <span>© @DateTime.Now.Year SoAt Cooperative</span>
            </div>
        </aside>

        @* ── แผงฟอร์ม (ขวา) ──────────────────────────────── *@
        <section class="lg-form">
            <div class="lg-form-head">
                <span class="lg-form-kicker">เข้าสู่ระบบส่วนกลาง</span>
                <h1 id="login-dialog-title" class="lg-title">ยินดีต้อนรับ</h1>
                <p class="lg-sub">
                    @(string.IsNullOrEmpty(_loginAppText) ? "กรอกข้อมูลของคุณเพื่อเข้าใช้งานระบบ" : $"เข้าสู่ระบบเพื่อใช้งาน{_loginAppText}")
                </p>
            </div>

            <form class="lg-form-fields" method="post" action="/auth/login">
                <input type="hidden" name="__RequestVerificationToken" value="@_afToken" />
                <input type="hidden" name="returnUrl" value="@_loginTarget" />

                @if (_hasError)
                {
                    <div class="lg-error">ชื่อผู้ใช้หรือรหัสผ่านไม่ถูกต้อง</div>
                }

                <div class="lg-fld">
                    <label for="ov-user">ชื่อผู้ใช้</label>
                    <div class="lg-input lg-input--user">
                        <i class="bi bi-person" aria-hidden="true"></i>
                        <input id="ov-user" name="userId" autocomplete="username"
                               placeholder="รหัสผู้ใช้งาน" required />
                    </div>
                </div>

                <div class="lg-fld">
                    <label for="ov-pass">รหัสผ่าน</label>
                    <div class="lg-input lg-input--lock">
                        <i class="bi bi-lock" aria-hidden="true"></i>
                        <input id="ov-pass" name="password" type="password"
                               autocomplete="current-password" placeholder="••••••••" required />
                    </div>
                </div>

                <div class="lg-fld">
                    <label for="ov-branch">สาขา</label>
                    <div class="lg-input lg-input--branch">
                        <i class="bi bi-building" aria-hidden="true"></i>
                        <select id="ov-branch" name="branchId" required>
                            <option value="">— เลือกสาขา —</option>
                            @foreach (var b in _branches)
                            {
                                <option value="@b.Code" selected="@(b.Code == DefaultBranchId)">@b.Code — @b.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="lg-row">
                    <button type="button" class="lg-forgot" @onclick="() => _showForgot = true">
                        <i class="bi bi-question-circle" aria-hidden="true"></i>
                        ลืมรหัสผ่าน?
                    </button>
                </div>

                <button type="submit" class="lg-btn">
                    <span>เข้าสู่ระบบ</span>
                    <i class="bi bi-arrow-right" aria-hidden="true"></i>
                </button>

                <p class="lg-secure-note">
                    <i class="bi bi-shield-lock" aria-hidden="true"></i>
                    ข้อมูลการเข้าสู่ระบบได้รับการปกป้องอย่างปลอดภัย
                </p>
            </form>
        </section>
    </div>
</div>

@* ── Modal "ลืมรหัสผ่าน" (popup ในตัว — เปิดทับ overlay login) ───────────── *@
@if (_showForgot)
{
    <div class="lg-modal is-open">
        <div class="lg-modal-back" @onclick="() => _showForgot = false"></div>
        <div class="lg-modal-card">
            <button type="button" class="lg-modal-x" @onclick="() => _showForgot = false" aria-label="ปิด">
                <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M4.08859 4.21569L4.14645 4.14645C4.32001 3.97288 4.58944 3.9536 4.78431 4.08859L4.85355 4.14645L10 9.293L15.1464 4.14645C15.32 3.97288 15.5894 3.9536 15.7843 4.08859L15.8536 4.14645C16.0271 4.32001 16.0464 4.58944 15.9114 4.78431L15.8536 4.85355L10.707 10L15.8536 15.1464C16.0271 15.32 16.0464 15.5894 15.9114 15.7843L15.8536 15.8536C15.68 16.0271 15.4106 16.0464 15.2157 15.9114L15.1464 15.8536L10 10.707L4.85355 15.8536C4.67999 16.0271 4.41056 16.0464 4.21569 15.9114L4.14645 15.8536C3.97288 15.68 3.9536 15.4106 4.08859 15.2157L4.14645 15.1464L9.293 10L4.14645 4.85355C3.97288 4.67999 3.9536 4.41056 4.08859 4.21569Z"/></svg>
            </button>
            <div class="lg-modal-icon">🔑</div>
            <h3>ลืมรหัสผ่าน?</h3>
            <p>ด้วยเหตุผลด้านความปลอดภัย การรีเซ็ตรหัสผ่านต้องดำเนินการโดยผู้ดูแลระบบ
               กรุณาติดต่อเจ้าหน้าที่ฝ่ายไอทีของสหกรณ์เพื่อขอรหัสผ่านใหม่</p>
            <ul class="lg-modal-contact">
                <li><span>โทรภายใน</span><strong>ต่อ 1234</strong></li>
                <li><span>อีเมล</span><strong>it-support@soat.coop</strong></li>
            </ul>
            <button type="button" class="lg-btn lg-btn--ghost" @onclick="() => _showForgot = false">เข้าใจแล้ว</button>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    // query: module เด้งมา (returnUrl), login fail (error), หรือกด "เข้าสู่ระบบ" (login=1)
    [SupplyParameterFromQuery(Name = "returnUrl")] private string? ReturnUrlQuery { get; set; }
    [SupplyParameterFromQuery(Name = "error")]     private string? ErrorQuery     { get; set; }
    [SupplyParameterFromQuery(Name = "login")]     private string? LoginQuery     { get; set; }

    private IReadOnlyList<ScAppDto>? _apps;
    private ScCenterInfoDto?         _info;
    private string UserName = "ผู้เยี่ยมชม";
    private string BranchId = "—";

    private List<string>  _categories = new();
    private Dictionary<string, string> _catMap = new(StringComparer.OrdinalIgnoreCase);
    private string? SelectedCat;

    private List<string> _favs   = new();
    private List<string> _recent = new();

    // ── login overlay state ──
    private bool   _isAuthed;
    private bool   _showLogin;
    private string? _loginTarget;     // returnUrl ของ module ที่คลิก
    private string? _loginAppText;    // ชื่อระบบ (แสดงใน popup)
    private bool   _hasError;         // login ล้มเหลว (จาก query error=1)
    private bool   _showForgot;       // modal "ลืมรหัสผ่าน"
    private List<sc.ComboItem> _branches = [];
    private const string DefaultBranchId = "01";   // สาขา default ที่เลือกไว้ใน popup login
    private string? _afToken;         // antiforgery token (จาก prerender)
    private PersistingComponentStateSubscription _persistSub;

    private string Version  => Config["App:Version"] ?? "";
    private string SysName  => string.IsNullOrEmpty(_info?.SysName) ? "—" : _info!.SysName;

    private string Greeting
    {
        get
        {
            var h = DateTime.Now.Hour;
            var part = h < 12 ? "สวัสดีตอนเช้า" : h < 17 ? "สวัสดีตอนบ่าย" : "สวัสดีตอนเย็น";
            return UserName == "ผู้เยี่ยมชม" ? $"{part} 👋" : $"{part}, คุณ{UserName} 👋";
        }
    }

    private IEnumerable<ScAppDto> Filtered =>
        SelectedCat is null ? _apps! : _apps!.Where(a => CatOf(a.AppName) == SelectedCat);

    private List<ScAppDto> _favApps =>
        _favs.Select(n => _apps!.FirstOrDefault(a => string.Equals(a.AppName, n, StringComparison.OrdinalIgnoreCase)))
             .Where(a => a is not null).Cast<ScAppDto>().ToList();

    private List<ScAppDto> _recentApps =>
        _recent.Select(n => _apps!.FirstOrDefault(a => string.Equals(a.AppName, n, StringComparison.OrdinalIgnoreCase)))
               .Where(a => a is not null).Cast<ScAppDto>().ToList();

    protected override void OnInitialized()
    {
        // antiforgery token: prerender มี HttpContext → ดึง token แล้วเก็บผ่าน
        //   PersistentComponentState ให้ใช้ต่อใน interactive circuit (ที่ไม่มี HttpContext)
        if (!AppState.TryTakeFromJson("af-token", out _afToken))
        {
            var ctx = HttpAccessor.HttpContext;
            if (ctx is not null) _afToken = Antiforgery.GetAndStoreTokens(ctx).RequestToken;
        }
        _persistSub = AppState.RegisterOnPersisting(() =>
        {
            AppState.PersistAsJson("af-token", _afToken);
            return Task.CompletedTask;
        });
    }

    public void Dispose() => _persistSub.Dispose();

    protected override async Task OnInitializedAsync()
    {
        _apps = (await ScApps.GetAppsAsync(level: 1))
            .Where(a => !string.Equals(a.AppName, "scCenter", StringComparison.OrdinalIgnoreCase))
            .ToList();
        _info = await ScApps.GetCenterInfoAsync();

        // สาขาสำหรับ dropdown ใน login overlay (combo code+name — ตาม Coding Guideline)
        await using (var db = DbFactory.create())
            _branches = await db.getComboAsync(sc.combo.sc_com_m_branch);

        // หมวด ← config Categories (สร้าง lookup AppName→หมวด)
        foreach (var cat in Config.GetSection("Categories").GetChildren())
        {
            _categories.Add(cat.Key);
            foreach (var item in cat.GetChildren())
                if (!string.IsNullOrWhiteSpace(item.Value))
                    _catMap[item.Value!] = cat.Key;
        }

        if (AuthState is not null)
        {
            var user = (await AuthState).User;
            if (user.Identity?.IsAuthenticated == true)
            {
                _isAuthed = true;
                UserName = user.Identity.Name ?? "ผู้ใช้งาน";
                BranchId = user.FindFirst("branch_id")?.Value is { Length: > 0 } b ? b : "—";
            }
        }

        // ยังไม่ login + มี query (module เด้งมา / login fail / กดเข้าสู่ระบบ) → เปิด popup เลย
        if (!_isAuthed && (ReturnUrlQuery is not null || ErrorQuery is not null || LoginQuery is not null))
        {
            _showLogin   = true;
            _hasError    = ErrorQuery is not null;
            _loginTarget = ReturnUrlQuery;
        }
    }

    // คลิกระบบที่ยังไม่ login → เปิด popup (returnUrl = URL ของ module ที่คลิก)
    private async Task OpenLogin(string url, string appName, string appText)
    {
        _loginTarget  = url;
        _loginAppText = appText;
        _showLogin    = true;
        await JS.InvokeVoidAsync("soatPortal.pushRecent", appName);   // จำว่ากำลังจะเข้าระบบไหน
    }

    private void CloseLogin() => _showLogin = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        // โหลด favorites/recent จาก localStorage (ทำได้หลัง interactive เท่านั้น)
        _favs   = (await JS.InvokeAsync<string[]>("soatPortal.getFavorites")).ToList();
        _recent = (await JS.InvokeAsync<string[]>("soatPortal.getRecent")).ToList();
        StateHasChanged();
    }

    private async Task ToggleFav(string appName)
    {
        _favs = (await JS.InvokeAsync<string[]>("soatPortal.toggleFavorite", appName)).ToList();
    }

    private string CatOf(string appName) => _catMap.TryGetValue(appName, out var c) ? c : "อื่นๆ";
    private bool   IsFav(string appName) => _favs.Contains(appName, StringComparer.OrdinalIgnoreCase);

    private string? ModuleUrl(string appName)
        => Config[$"Modules:{appName}"] is { Length: > 0 } u ? u : null;

    private RenderFragment Card(ScAppDto app) => @<text>
        @{
            var url       = ModuleUrl(app.AppName);
            var clickable = app.Active && url is not null;
            var stateCss  = !app.Active ? "pt-card pt-inactive"
                            : url is null ? "pt-card pt-soon"
                            : "pt-card";
        }
        <div class="@stateCss">
            <button class="pt-star @(IsFav(app.AppName) ? "on" : "")"
                    title="@(IsFav(app.AppName) ? "เอาออกจากปักหมุด" : "ปักหมุด")"
                    @onclick="() => ToggleFav(app.AppName)">★</button>

            @if (clickable && _isAuthed)
            {
                @* login แล้ว → เข้า module ตรง (cross-app, cookie ใช้ร่วมกัน) *@
                <a class="pt-card-link" href="@url" onclick="soatPortal.pushRecent('@app.AppName')">
                    @CardInner(app)
                </a>
            }
            else if (clickable)
            {
                @* ยังไม่ login → เด้ง popup login ทับ landing *@
                <button type="button" class="pt-card-link"
                        @onclick="() => OpenLogin(url!, app.AppName, app.AppTextThai)">
                    @CardInner(app)
                </button>
            }
            else
            {
                <div class="pt-card-link">@CardInner(app)</div>
            }

            @if (!app.Active)
            {
                <span class="pt-badge">ปิดใช้งาน</span>
            }
            else if (url is null)
            {
                <span class="pt-badge pt-badge-soon">เร็วๆ นี้</span>
            }
        </div>
    </text>;

    private RenderFragment CardInner(ScAppDto app) => @<text>
        <div class="pt-icon-wrap">
            @if (!string.IsNullOrWhiteSpace(app.IconName))
            {
                <img class="pt-icon" src="ImgMenu/@app.IconName" alt="" />
            }
            else
            {
                <div class="pt-icon pt-icon-empty"></div>
            }
        </div>
        <div class="pt-en">@app.AppTextEnglish</div>
        <div class="pt-th">@app.AppTextThai</div>
    </text>;
}

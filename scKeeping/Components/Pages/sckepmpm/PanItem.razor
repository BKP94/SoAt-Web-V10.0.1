@* ── PanItem — วิธีเรียกเก็บ + รายการประมวลผล (ติ๊กเลือก proc_code) (dumb component) ────
   legacy: panItem.ascx(.cs) — combo keep_method + gvItem (ASPxGridView batch-select over sc_kep_m_ucf_process)
   ข้อมูลถูกโหลดที่ composite (Sckepmpm) แล้วส่งลงมา: Form.Items / Form.SelectedItems / Lookups.KeepMethods
     · keep_method: ถ้ามีวิธีเดียว → ล็อก (Enabled=false) + auto-select (Lookups.KeepMethodLocked)
     · REP (จัดทำงบหน้าเรียกเก็บ) ในหน้า mproc = บังคับติ๊กเสมอตาม default — legacy disable checkbox
       (re-implement: OnSelectionChanged ล็อก REP ให้คงสถานะ default) *@

<div class="ki-item">
    <DxFormLayout>
        <DxFormLayoutItem Caption="วิธีเรียกเก็บ" ColSpanMd="12">
            <DxComboBox Data="Lookups.KeepMethods" @bind-Value="Form.keep_method"
                        TData="sc.ComboItem" TValue="string"
                        ValueFieldName="@nameof(sc.ComboItem.Code)"
                        TextFieldName="@nameof(sc.ComboItem.Name)"
                        Enabled="!Lookups.KeepMethodLocked"
                        NullText="@AllText" />
        </DxFormLayoutItem>
    </DxFormLayout>

    <DxGrid Data="Form.Items"
            KeyFieldName="@nameof(ProcItem.proc_code)"
            SelectionMode="GridSelectionMode.Multiple"
            SelectedDataItems="Form.SelectedItems.Cast<object>().ToList()"
            SelectedDataItemsChanged="OnSelectionChanged"
            ShowAllRows="true"
            ShowGroupPanel="false"
            CssClass="ki-grid">
        <Columns>
            <DxGridSelectionColumn Width="44px" />
            <DxGridDataColumn FieldName="@nameof(ProcItem.proc_detail)" Caption="รายการประมวลผล" />
        </Columns>
    </DxGrid>

    @if (Form.Items.Count == 0)
    {
        <div class="nb-empty">ไม่มีรายการประมวลผล</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public SckepmpmForm     Form    { get; set; } = default!;
    [Parameter, EditorRequired] public SckepmpmLookups  Lookups { get; set; } = default!;
    [Parameter] public bool IsMpost { get; set; }

    private const string AllText = "<ทั้งหมด>";

    private void OnSelectionChanged(IReadOnlyList<object> selected)
    {
        var items = selected.Cast<ProcItem>().ToList();

        // mproc: REP บังคับให้คงสถานะ default (legacy ปิด checkbox ไม่ให้ผู้ใช้แก้)
        if (!IsMpost)
        {
            var rep = Form.Items.FirstOrDefault(i => i.proc_code == "REP");
            if (rep is not null)
            {
                var isSel = items.Contains(rep);
                if (rep.selected && !isSel) items.Add(rep);      // ถูกดึงออก → ใส่กลับ
                else if (!rep.selected && isSel) items.Remove(rep);
            }
        }

        Form.SelectedItems = items;
    }
}

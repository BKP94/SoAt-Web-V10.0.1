<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Design-time only (Visual Studio XtraReports Designer).
    DevExpress designer resolves SqlDataSource.ConnectionName="repConnection" จากที่นี่
    ต้องเป็น DevExpress connection-string format (มี token XpoProvider=Postgres) ไม่งั้น
    designer เดา provider เป็น SQL Server แล้วเด้ง "Keyword not supported: 'host'".

    ⚠ ไฟล์นี้ไม่กระทบ runtime — runtime อ่าน ConnectionStrings:repConnection จาก appsettings.json
       (รูปแบบ Npgsql) แล้ว sc.report.ensureRepConnection() ฉีด ConnectionParameters เองก่อน Fill().
       ห้ามใส่ XpoProvider ใน appsettings.json (Npgsql ไม่รู้จัก keyword นี้ → sc.db พัง).
  -->
  <connectionStrings>
    <add name="repConnection"
         connectionString="XpoProvider=Postgres;Server=localhost;Port=5432;Database=soatdb;User ID=soat;Password=soat1234"
         providerName="DevExpress.Xpo" />
  </connectionStrings>
</configuration>

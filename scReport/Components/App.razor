@inject IConfiguration Config
@inject NavigationManager Nav

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="@(new Uri(Nav.BaseUri).AbsolutePath)" />
    @* DevExpress theme (Bootstrap 5) — เปลี่ยน theme ที่ appsettings "DevExpress:Theme" จุดเดียว *@
    <!-- Prompt font (self-host, intranet-friendly) -->
    <link rel="stylesheet" href="fonts/prompt.css" />
    <!-- Bootstrap Icons (self-host, intranet-friendly) — ใช้ class bi bi-* ได้ทุกที่ (inline / DevExpress IconCssClass) -->
    <link rel="stylesheet" href="icons/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="_content/DevExpress.Blazor.Themes/@(Config["DevExpress:Theme"] ?? "office-white").bs5.min.css" />
    @* DevExpress Reporting native viewer — CSS ที่ให้ icon toolbar (dxd-icon-*); ไม่งั้นปุ่มขนาด 0px มองไม่เห็น *@
    <link rel="stylesheet" href="_content/DevExpress.Blazor.Reporting.Viewer/css/dx-blazor-reporting-components.bs5.css" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["scReport.styles.css"]" />
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@* PanOperate (repCategory) — แถบปุ่ม Operate แนวตั้ง ขวาของหน้า
   เลียน legacy panOperate.ascx: btSave "บันทึก" + btMove "ย้ายกลุ่ม"
   (btExport/btImport = เลื่อนไปเฟส 2)
   ปุ่ม raise EventCallback กลับให้ Page จัดการ *@

<div class="op-orbit-toolbar" role="toolbar" aria-label="เครื่องมือกลุ่มรายงาน">
    <span class="op-orbit-heading">เครื่องมือ</span>

    <div class="op-orbit-item op-orbit-item--primary">
        <DxButton RenderStyle="ButtonRenderStyle.Primary"
                  title="บันทึก" aria-label="บันทึก"
                  @onclick="OnSave" CssClass="op-btn"
                  IconCssClass="bi bi-floppy" />
        <span class="op-orbit-label">บันทึก</span>
    </div>

    <div class="op-orbit-item">
        <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  title="ย้ายข้อรายงานไปกลุ่มอื่น" aria-label="ย้ายข้อรายงานไปกลุ่มอื่น"
                  disabled="@(!CanMove)" @onclick="OnMove" CssClass="op-btn"
                  IconCssClass="bi bi-arrow-left-right" />
        <span class="op-orbit-label">ย้ายกลุ่ม</span>
    </div>
</div>

@code {
    /// ย้ายได้เมื่อเลือกข้อรายงานแล้ว
    [Parameter] public bool CanMove { get; set; }

    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnMove { get; set; }
}

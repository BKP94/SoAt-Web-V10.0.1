@* ── PanHead (repHome) — 3 คอลัมน์ master-detail (เลียน legacy repHome/panHead.ascx) ──
   ระบบงาน (apps) → กลุ่มรายงาน (cats) → ข้อรายงาน (reps)
   dumb component: รับ data + selected ผ่าน [Parameter], ยิง EventCallback กลับให้ Page
   เลือกเดียวต่อคอลัมน์ (DxListBox SelectionMode.Single — DevExpress ไม่มี DxNavBar) *@

<div class="rh-cols">
    <div class="rh-col">
        <div class="rh-col-head">ระบบงาน</div>
        <DxListBox Data="@Apps" TData="AppRow" TValue="string"
                   ValueFieldName="@nameof(AppRow.AppName)" TextFieldName="@nameof(AppRow.Display)"
                   SelectionMode="ListBoxSelectionMode.Single"
                   Values="@Sel(SelectedApp)" ValuesChanged="@OnAppSel" TValueChangedType="IEnumerable<string>"
                   CssClass="rh-listbox" />
    </div>

    <div class="rh-col">
        <div class="rh-col-head">กลุ่มรายงาน</div>
        <DxListBox Data="@Cats" TData="CatRow" TValue="string"
                   ValueFieldName="@nameof(CatRow.CatId)" TextFieldName="@nameof(CatRow.Display)"
                   SelectionMode="ListBoxSelectionMode.Single"
                   Values="@Sel(SelectedCat)" ValuesChanged="@OnCatSel" TValueChangedType="IEnumerable<string>"
                   CssClass="rh-listbox" />
    </div>

    <div class="rh-col">
        <div class="rh-col-head">ข้อรายงาน</div>
        <DxListBox Data="@Reps" TData="RepRow" TValue="string"
                   ValueFieldName="@nameof(RepRow.RepId)" TextFieldName="@nameof(RepRow.Display)"
                   SelectionMode="ListBoxSelectionMode.Single"
                   Values="@Sel(SelectedRep)" ValuesChanged="@OnRepSel" TValueChangedType="IEnumerable<string>"
                   CssClass="rh-listbox">
            <ItemDisplayTemplate Context="ctx">
                @{ var rep = ctx.DataItem; }
                <div class="rh-rep-item @(rep.HasReport ? "rh-rep" : "rh-rep--disabled")"
                     title="@(rep.HasReport ? "ดับเบิลคลิกเพื่อเปิดรายงาน · " + rep.VsPath : "ไม่พบตัวรายงาน [vs_path]")"
                     @onclick="@(() => OnRepItemClick(rep.RepId))">@rep.Display</div>
            </ItemDisplayTemplate>
        </DxListBox>
    </div>
</div>

@code {
    // ── data + selection (Page เป็นเจ้าของ, ส่งลงมา) ──
    [Parameter] public List<AppRow> Apps { get; set; } = [];
    [Parameter] public List<CatRow> Cats { get; set; } = [];
    [Parameter] public List<RepRow> Reps { get; set; } = [];

    [Parameter] public string? SelectedApp { get; set; }
    [Parameter] public string? SelectedCat { get; set; }
    [Parameter] public string? SelectedRep { get; set; }

    [Parameter] public EventCallback<string?> SelectedAppChanged { get; set; }
    [Parameter] public EventCallback<string?> SelectedCatChanged { get; set; }
    [Parameter] public EventCallback<string?> SelectedRepChanged { get; set; }

    // ดับเบิลคลิกข้อรายงาน → เปิด PopArgument/รายงานทันที (Page จัดการ)
    [Parameter] public EventCallback<string> OnRepActivate { get; set; }

    // ── ตรวจจับ double-click เอง (กัน native dblclick พังเพราะ DevExpress re-render <li> กลางสองคลิก) ──
    // คลิกแรกเปลี่ยน selection → ทั้ง item ถูก replace → คลิกสองตกบน node ใหม่ → native dblclick ไม่จับคู่
    // แก้: ใช้ @onclick (ยิงอิสระทุกคลิก) แล้วเทียบ repId+เวลา 2 คลิกติดบนข้อเดียวกัน
    string? _lastClickRep;
    DateTime _lastClickAt;

    Task OnRepItemClick(string repId)
    {
        var now = DateTime.UtcNow;
        if (repId == _lastClickRep && (now - _lastClickAt).TotalMilliseconds <= 500)
        {
            _lastClickRep = null;
            return OnRepActivate.InvokeAsync(repId);
        }
        _lastClickRep = repId;
        _lastClickAt = now;
        return Task.CompletedTask;
    }

    // single-selection → DxListBox.Values รับ IEnumerable; แปลงค่าเดี่ยว ↔ collection
    static IEnumerable<string> Sel(string? v) => string.IsNullOrEmpty(v) ? [] : [v];

    Task OnAppSel(IEnumerable<string> v) => SelectedAppChanged.InvokeAsync(v.FirstOrDefault());
    Task OnCatSel(IEnumerable<string> v) => SelectedCatChanged.InvokeAsync(v.FirstOrDefault());
    Task OnRepSel(IEnumerable<string> v) => SelectedRepChanged.InvokeAsync(v.FirstOrDefault());

    // ── row models (แชร์กับ Page ผ่าน partial class ในไฟล์เดียวกัน namespace) ──
    public class AppRow
    {
        public string AppName { get; set; } = "";
        public string AppText { get; set; } = "";
        public int Seq { get; set; }
        public string Display => $"{Seq}.{(string.IsNullOrWhiteSpace(AppText) ? AppName : AppText)}";
    }

    public class CatRow
    {
        public string CatId { get; set; } = "";
        public string CatText { get; set; } = "";
        public string CatApp { get; set; } = "";
        public string Display => $"{CatId} - {CatText}";
    }

    public class RepRow
    {
        public string CatId { get; set; } = "";
        public string RepId { get; set; } = "";
        public string RepText { get; set; } = "";
        public string VsPath { get; set; } = "";
        public bool HasReport => !string.IsNullOrWhiteSpace(VsPath);
        public string Display => $"{RepId} - {RepText}";
    }
}

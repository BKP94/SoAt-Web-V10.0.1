@* PanOperate (repHome) — แถบปุ่ม Operate แนวตั้ง ขวาของหน้า
   เลียน legacy panOperate.ascx: btNew "เปิดรายงาน" + btFindReport "ค้นหารายงาน"
   (btProgram/btCategory = admin นอกสโคป Step 7)
   ปุ่ม raise EventCallback กลับให้ Page จัดการ (Page ถือ selection) *@

<div class="op-orbit-toolbar" role="toolbar" aria-label="เครื่องมือรายงาน">
    <span class="op-orbit-heading">เครื่องมือ</span>

    <div class="op-orbit-item op-orbit-item--primary">
        <DxButton RenderStyle="ButtonRenderStyle.Primary"
                  title="เปิดรายงาน" aria-label="เปิดรายงาน"
                  disabled="@(!CanOpen)" @onclick="OnOpen" CssClass="op-btn"
                  IconCssClass="bi bi-folder2-open" />
        <span class="op-orbit-label">เปิดรายงาน</span>
    </div>

    <div class="op-orbit-item">
        <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  title="ค้นหารายงาน" aria-label="ค้นหารายงาน"
                  @onclick="OnFind" CssClass="op-btn"
                  IconCssClass="bi bi-search" />
        <span class="op-orbit-label">ค้นหา</span>
    </div>

    <div class="op-orbit-item">
        <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  title="จัดการไฟล์รายงาน (เปิดแท็บใหม่)" aria-label="จัดการไฟล์รายงาน"
                  disabled="@(!CanManage)" @onclick="OnManage" CssClass="op-btn"
                  IconCssClass="bi bi-tools" />
        <span class="op-orbit-label">จัดการรายงาน</span>
    </div>

    <div class="op-orbit-item">
        <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  title="เพิ่ม/แก้ไขกลุ่มรายงาน (เปิดแท็บใหม่)" aria-label="เพิ่มหรือแก้ไขกลุ่มรายงาน"
                  disabled="@(!CanCategory)" @onclick="OnCategory" CssClass="op-btn"
                  IconCssClass="bi bi-folder-plus" />
        <span class="op-orbit-label">จัดการกลุ่ม</span>
    </div>
</div>

@code {
    /// เปิดได้เมื่อเลือกข้อรายงานที่มีตัวรายงาน (vs_path ไม่ว่าง)
    [Parameter] public bool CanOpen { get; set; }

    /// จัดการได้เมื่อเลือกข้อรายงาน (มี cat/rep) — ไม่ต้องมีไฟล์ก็เปิด editor เพื่อสร้างได้
    [Parameter] public bool CanManage { get; set; }

    /// จัดการกลุ่มได้เมื่อเลือกระบบงานแล้ว
    [Parameter] public bool CanCategory { get; set; }

    [Parameter] public EventCallback OnOpen { get; set; }
    [Parameter] public EventCallback OnFind { get; set; }
    [Parameter] public EventCallback OnManage { get; set; }
    [Parameter] public EventCallback OnCategory { get; set; }
}

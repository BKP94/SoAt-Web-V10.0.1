@* PopFindReport (repHome) — ค้นหารายงานข้ามกลุ่ม แล้วเลือกเปิด
   เลียน legacy popFindReport/ofFindReport: ค้นจาก rep_text หรือ vs_path
   DEVIATION (frontend): legacy repopulate 3 คอลัมน์ nav; ใหม่ใช้ result grid แบนแล้วเลือกแถวเปิดตรง
   (scReport = central เห็นทุกระบบงาน — ไม่กรอง cat_app) *@

@inject sc.dbFactory DbFactory

<DxPopup Visible="Visible" VisibleChanged="SetVisible" HeaderText="ค้นหารายงาน"
         Width="720px" CloseOnEscape="true" ShowFooter="true">
    <BodyContentTemplate>
        <div class="rh-find-bar">
            <DxTextBox @bind-Text="_keyword" NullText="พิมพ์ชื่อรายงาน หรือ vs_path…"
                       CssClass="rh-find-input" />
            <DxButton Text="ค้นหา" RenderStyle="ButtonRenderStyle.Primary" Click="Search" />
        </div>

        @if (_error is not null)
        {
            <div class="rh-arg-error">@_error</div>
        }

        <div class="rh-find-grid">
            <div class="rh-find-head">
                <span class="rh-find-c rh-find-c--app">ระบบงาน</span>
                <span class="rh-find-c rh-find-c--cat">กลุ่ม</span>
                <span class="rh-find-c rh-find-c--id">รหัส</span>
                <span class="rh-find-c rh-find-c--name">ชื่อรายงาน</span>
            </div>
            <DxListBox Data="@_rows" TData="FindRow" TValue="string"
                       ValueFieldName="@nameof(FindRow.Key)" TextFieldName="@nameof(FindRow.RepText)"
                       SelectionMode="ListBoxSelectionMode.Single"
                       Values="@Sel(_selected)" ValuesChanged="@OnSel" TValueChangedType="IEnumerable<string>"
                       CssClass="rh-find-listbox">
                <ItemDisplayTemplate Context="ctx">
                    @{ var r = ctx.DataItem; }
                    <div class="rh-find-row @(r.HasReport ? null : "rh-find-row--disabled")"
                         title="@(r.HasReport ? "ดับเบิลคลิกเพื่อเปิด · " + r.VsPath : "ไม่พบตัวรายงาน [vs_path]")"
                         @ondblclick="@(() => OpenRow(r))">
                        <span class="rh-find-c rh-find-c--app">@r.CatApp</span>
                        <span class="rh-find-c rh-find-c--cat">@r.CatText</span>
                        <span class="rh-find-c rh-find-c--id">@r.RepId</span>
                        <span class="rh-find-c rh-find-c--name">@r.RepText</span>
                    </div>
                </ItemDisplayTemplate>
            </DxListBox>
        </div>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton Text="เปิดรายงาน" RenderStyle="ButtonRenderStyle.Primary"
                  Enabled="@(_selected is { } r && r.HasReport)" Click="OpenSelected" />
        <DxButton Text="ปิด" RenderStyle="ButtonRenderStyle.Secondary" Click="() => SetVisible(false)" />
    </FooterContentTemplate>
</DxPopup>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }

    /// ส่ง vs_path ที่เลือกกลับให้ Page เปิด (Page ประกอบ arg+viewer)
    [Parameter] public EventCallback<string> OnPick { get; set; }

    string? _keyword;
    string? _error;
    List<FindRow> _rows = new();
    FindRow? _selected;

    async Task SetVisible(bool v)
    {
        Visible = v;
        await VisibleChanged.InvokeAsync(v);
    }

    async Task Search()
    {
        _error = null;
        _selected = null;
        try
        {
            await using var db = DbFactory.create();
            // scReport เห็นทุกระบบงาน → ไม่เติม and cat_app=... (legacy ofFindReport)
            _rows = await db.getListAsync<FindRow>(@"
                select si_rep_cats.cat_app  as CatApp,
                       si_rep_cats.cat_id   as CatId,
                       si_rep_cats.cat_text as CatText,
                       si_rep_reps.rep_id   as RepId,
                       si_rep_reps.rep_text as RepText,
                       si_rep_reps.vs_path  as VsPath
                from si_rep_reps, si_rep_cats
                where si_rep_reps.cat_id = si_rep_cats.cat_id
                  and (si_rep_reps.rep_text like '%' || {0} || '%'
                       or si_rep_reps.vs_path like '%' || {0} || '%')
                order by si_rep_cats.cat_app, si_rep_cats.cat_id, si_rep_reps.rep_id",
                _keyword ?? string.Empty);
        }
        catch (Exception ex)
        {
            _error = sc.msg.C(ex.Message);
        }
    }

    // single-selection → DxListBox.Values รับ IEnumerable; แปลงค่าเดี่ยว ↔ collection (เหมือน PanHead)
    static IEnumerable<string> Sel(FindRow? r) => r is null ? [] : [r.Key];

    void OnSel(IEnumerable<string> keys)
    {
        var k = keys.FirstOrDefault();
        _selected = k is null ? null : _rows.FirstOrDefault(x => x.Key == k);
    }

    // ดับเบิลคลิกแถว → เลือก + เปิดทันที (เลียน legacy เลือกแถวแล้วเปิด)
    Task OpenRow(FindRow r)
    {
        _selected = r;
        return OpenSelected();
    }

    async Task OpenSelected()
    {
        if (_selected is not { } r || !r.HasReport) return;
        await SetVisible(false);
        await OnPick.InvokeAsync(r.VsPath);
    }

    public class FindRow
    {
        public string CatApp { get; set; } = "";
        public string CatId { get; set; } = "";
        public string CatText { get; set; } = "";
        public string RepId { get; set; } = "";
        public string RepText { get; set; } = "";
        public string VsPath { get; set; } = "";
        public bool HasReport => !string.IsNullOrWhiteSpace(VsPath);
        // คีย์ unique ต่อแถว (cat+rep) สำหรับ DxListBox ValueFieldName
        public string Key => CatId + "|" + RepId;
    }
}

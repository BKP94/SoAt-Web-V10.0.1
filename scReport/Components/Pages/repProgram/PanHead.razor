@using scReport.Services

@* PanHead (repProgram) — Path / Procedure / Focus + ตาราง Arguments
   เลียน legacy panHead.ascx: txtPath(readonly) / procedure / colFocus + gvArguments (id + attr)
   - ปุ่ม "สร้าง" ข้าง Procedure → เปิด PopProcedure builder
   - ปุ่ม "แก้" แต่ละแถว arg → เปิด PopAttribute builder (เขียน attr/id กลับ)
   dumb component: แก้ลง Model (reference ร่วมกับ Page) ตรง *@

<div class="rp-headgrid">
    <div class="nb-field">
        <label class="nb-label">Path</label>
        <DxTextBox Text="@Model.VsPath" ReadOnly="true" CssClass="rp-path" />
    </div>
    <div class="nb-field">
        <label class="nb-label">Procedure</label>
        <div class="rp-field-with-btn">
            <DxTextBox @bind-Text="Model.Procedure" NullText="(ไม่ใช้ procedure)" CssClass="rp-grow" />
            <DxButton Text="สร้าง" RenderStyle="ButtonRenderStyle.Secondary"
                      CssClass="soat-btn soat-btn--ghost soat-btn--compact" Click="() => _procVisible = true" />
        </div>
    </div>
    <div class="nb-field">
        <label class="nb-label">Focus Column</label>
        <DxTextBox @bind-Text="Model.ColFocus" NullText="(คอลัมน์ที่ focus)" />
    </div>
</div>

<div class="nb-grid-head">
    <h3 class="nb-h3">Arguments</h3>
    <DxButton Text="+ เพิ่มแถว" RenderStyle="ButtonRenderStyle.Primary"
              CssClass="soat-btn" Click="AddArg" />
</div>

@if (Model.Args.Count == 0)
{
    <div class="nb-empty">ยังไม่มี argument — กด “เพิ่มแถว” เพื่อเริ่ม</div>
}
else
{
    <DxGrid Data="Model.Args" PageSize="0" ColumnResizeMode="GridColumnResizeMode.NextColumn">
        <Columns>
            <DxGridDataColumn Caption="#" Width="44px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                <CellDisplayTemplate>@(context.VisibleIndex + 1)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ID" Width="180px" AllowSort="false">
                <CellDisplayTemplate>
                    @{ var r = (RepArgRow)context.DataItem; }
                    <DxTextBox @bind-Text="r.Id" NullText="argument id" />
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="Attributes" AllowSort="false">
                <CellDisplayTemplate>
                    @{ var r = (RepArgRow)context.DataItem; }
                    <div class="rp-field-with-btn">
                        <DxTextBox @bind-Text="r.Attr" NullText="name=&quot;value&quot; ..." CssClass="rp-grow" />
                        <DxButton Text="แก้" RenderStyle="ButtonRenderStyle.Secondary"
                                  CssClass="soat-btn soat-btn--compact" Click="() => OpenAttr(r)" />
                    </div>
                </CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="" Width="56px" AllowSort="false">
                <CellDisplayTemplate>
                    @{ var r = (RepArgRow)context.DataItem; }
                    <DxButton Text="ลบ" RenderStyle="ButtonRenderStyle.Danger"
                              CssClass="soat-btn soat-btn--danger soat-btn--compact"
                              Click="() => RemoveArg(r)" />
                </CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
    </DxGrid>
}

<PopProcedure @bind-Visible="_procVisible" Model="Model" OnApply="ApplyProcedure" />
<PopAttribute @bind-Visible="_attrVisible" Arg="_editArg" OnApply="StateHasChanged" />

@code {
    [Parameter, EditorRequired] public RepProgramModel Model { get; set; } = default!;

    bool _procVisible, _attrVisible;
    RepArgRow? _editArg;

    void AddArg() => Model.Args.Add(new RepArgRow());
    void RemoveArg(RepArgRow r) => Model.Args.Remove(r);

    void ApplyProcedure(string proc) => Model.Procedure = proc;

    void OpenAttr(RepArgRow r)
    {
        _editArg = r;
        _attrVisible = true;
    }
}

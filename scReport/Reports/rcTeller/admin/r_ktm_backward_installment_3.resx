  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>select nvl(money_amount,0) - nvl(money_amount_not,0) - ppm_amout as  unkeep_real /*คงค้าง*/ ,tab.*
from (
select sc_kep_t_monthly_receive.membership_no
,pka_com_function.fp_get_member_name( sc_kep_t_monthly_receive.membership_no ) as member_name
,pka_com_function.fp_get_member_group( sc_kep_t_monthly_receive.membership_no ) as member_group_no
,'' as count_month 
,sc_kep_t_monthly_receive.receive_month 
,sc_kep_t_monthly_receive.seq_no 
,sum(sc_kep_t_monthly_receive_det.money_amount) as money_amount /*ยอดเรียกเก็บ*/
,sum(sc_kep_t_monthly_receive_det.money_amount_not) as money_amount_not /*ยอดที่เก็บได้*/
,(  select  max( receipt_date )
    from  sc_com_m_receipt
    where  receipt_mode = 'R'
    and   receipt_status = '0'
    and  month_receipt_no = sc_kep_t_monthly_receive.receipt_no
    ) as ppm_date /*ตามมาชำระ*/
    
,(  select  nvl( sum( recept_amount ) , 0 ) 
    from  sc_com_m_receipt
    where  receipt_mode = 'R'
    and   receipt_status = '0'
    and  month_receipt_no = sc_kep_t_monthly_receive.receipt_no
    ) as ppm_amout /*ตามมาชำระ(บาท)*/
    
from sc_kep_t_monthly_receive_det
    ,sc_kep_t_monthly_receive
where 1 = 2
--( sc_kep_t_monthly_receive_det.membership_no = sc_kep_t_monthly_receive.membership_no )
-- and   ( sc_kep_t_monthly_receive_det.receive_year = sc_kep_t_monthly_receive.receive_year )
--and   ( sc_kep_t_monthly_receive_det.receive_month = sc_kep_t_monthly_receive.receive_month )
--and   ( sc_kep_t_monthly_receive.seq_no = sc_kep_t_monthly_receive_det.seq_no )
--and   ( ( sc_kep_t_monthly_receive_det.money_amount &gt; 0 )
--AND   ( sc_kep_t_monthly_receive.receipt_status = '2' ) )
    --ยอดที่เก็บได้ น้อยกว่ายอดเรียกเก็บ สถานะ 2 ไม่ได้แปลว่าเก็บไม่ได้เสมอไป เคส ดอกเบี้ยสัญญาเก่า น้อยกว่า ดอกเบี้ยสัญญาใหม่
--and sc_kep_t_monthly_receive.kep_method_amount &lt;  PKA_KEP_MAGENT.fp_get_agent_amount_seq(  sc_kep_t_monthly_receive.membership_no ,
--sc_kep_t_monthly_receive.receive_year , sc_kep_t_monthly_receive.receive_month , sc_kep_t_monthly_receive.seq_no )
/*WHERE*/
--    and sc_kep_t_monthly_receive.receipt_effectdate between '01/08/2020' and '31/08/2020'
    --and sc_mem_m_ucf_member_group.member_group_type between '13' and '14'
--             and sc_kep_t_monthly_receive.receive_year = 2020
--             and sc_kep_t_monthly_receive.receive_month = 8
--             and sc_kep_t_monthly_receive.membership_no = '059120'
    group by sc_kep_t_monthly_receive.membership_no
    ,sc_kep_t_monthly_receive.receive_month 
    ,sc_kep_t_monthly_receive.seq_no
    ,sc_kep_t_monthly_receive.receipt_no
--    order by sc_mem_m_ucf_member_group.member_group_no
)tab</value>

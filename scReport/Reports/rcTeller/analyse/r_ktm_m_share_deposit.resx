  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>
    select	sc_mem_m_membership_registered.membership_no
    ,			sc_mem_m_membership_registered.member_group_no
    ,			sc_mem_m_ucf_member_group.member_group_name
    ,			sc_mem_m_ucf_prename.prename
    ,			sc_mem_m_membership_registered.member_name
    ,			sc_mem_m_membership_registered.member_surname
    ,			sc_mem_m_membership_registered.date_of_birth

,PKA_LON_REQSRV.fp_calc_agetext( sc_mem_m_membership_registered.date_of_birth )  as age
    ,		nvl((select	share_amount
    from	sc_mem_m_share_mem
    where	sc_mem_m_share_mem.membership_no  =  sc_mem_m_membership_registered.membership_no
    ) ,0)as share_amount

    ,		nvl((select	share_stock
    from	sc_mem_m_share_mem
    where	sc_mem_m_share_mem.membership_no  =  sc_mem_m_membership_registered.membership_no
    ) ,0)as share_stock


    ,		nvl((select	sc_dep_m_creditor.deposit_balance
    from	sc_dep_m_creditor
    where	sc_dep_m_creditor.membership_no  =  sc_mem_m_membership_registered.membership_no
    and	sc_dep_m_creditor.close_status = '0'
    and  sc_dep_m_creditor.deposit_type_code = '10'
    ) ,0)as deposit_type_10

    ,		nvl((select	sc_dep_m_creditor.deposit_balance
    from	sc_dep_m_creditor
    where	sc_dep_m_creditor.membership_no  =  sc_mem_m_membership_registered.membership_no
    and	sc_dep_m_creditor.close_status = '0'
    and  sc_dep_m_creditor.deposit_type_code = '20'
    ) ,0)as deposit_type_20

    ,		nvl((select	sc_dep_m_creditor.deposit_balance
    from	sc_dep_m_creditor
    where	sc_dep_m_creditor.membership_no  =  sc_mem_m_membership_registered.membership_no
    and	sc_dep_m_creditor.close_status = '0'
    and  sc_dep_m_creditor.deposit_type_code = '30'
    ) ,0)as deposit_type_30

    from		sc_mem_m_membership_registered
    ,			sc_mem_m_ucf_prename
    ,			sc_mem_m_ucf_member_group
    where	sc_mem_m_membership_registered.prename_code	=		sc_mem_m_ucf_prename.prename_code
    and		sc_mem_m_membership_registered.member_group_no	=	sc_mem_m_ucf_member_group.member_group_no
    and		sc_mem_m_membership_registered.member_group_no  between   '011001' and '011010'
    and		sc_mem_m_membership_registered.member_status_code = '0'
    /*WHERE*/</value>

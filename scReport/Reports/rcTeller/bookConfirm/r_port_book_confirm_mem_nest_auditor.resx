  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>select  *
from    (
select  (select manager_name from sc_cnt_m_coop) as manager_name
,       sc_mem_m_ucf_member_group.member_group_no
,       sc_mem_m_ucf_member_group.member_group_name
,       sc_cls_confirm_mem.member_fullname as member_name
,       sc_cls_confirm_mem.membership_no
,       sc_cls_confirm_data.confirm_date
,       pka_com_function.fp_get_thaidate( sc_cls_confirm_data.confirm_date , 'วันที่ sd month yyyy' ) as confirm_date_thai
,       sc_cls_confirm_data.data_balance as share_stock
,       sc_cls_confirm_data.data_group
,       sc_cls_confirm_data.data_type
,       sc_cls_confirm_data.data_refno
,       sc_cls_confirm_data.data_balance

,       (case when sc_cls_confirm_data.data_group = 'SHR' then '1'
        when sc_cls_confirm_data.data_group = 'DEP' then '2'
        when sc_cls_confirm_data.data_group = 'LON' then '3'
        end) as sort_data_group
        
,       (case when sc_cls_confirm_data.data_group = 'SHR' then 'หุ้นปกติ'
        when sc_cls_confirm_data.data_group = 'DEP' then 'เงินฝาก'
        when sc_cls_confirm_data.data_group = 'LON' then 'หนี้เงินกู้'
        end) as name_data_group  
        
,       (case when sc_cls_confirm_data.data_group = 'DEP' then (select deposit_name from sc_dep_m_rule where deposit_type_code = sc_cls_confirm_data.data_type)
        when sc_cls_confirm_data.data_group = 'LON' then (select sc_lon_m_rule.loan_type_description from sc_lon_m_rule where loan_type = sc_cls_confirm_data.data_type)
        end) as data_group_description     
        
from    sc_cls_confirm_mem
,       sc_cls_confirm_data
,       sc_mem_m_ucf_member_group
where   1=2
/*WHERE*/
--and     sc_cls_confirm_data.confirm_date = '01/05/2024'
--and     sc_mem_m_ucf_member_group.member_group_no = '100'
and     sc_cls_confirm_mem.membership_no = '00183'
) tab
order by sort_data_group
,        data_type</value>

  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT  sc_lon_m_contract_coll.loan_contract_no ,
			sc_lon_m_contract_coll.collateral_no ,
			sc_lon_m_contract.begining_of_contract ,
			sc_lon_m_contract.loan_type ,
			sc_lon_m_contract_coll.ref_own_no ,
   
      pka_com_function.fp_get_thaidate(sc_lon_m_contract.begining_of_contract , 'SD MONTH YYYY') as begining_of_contract,
      pka_com_function.fp_get_thaidate(sc_lon_m_contract.begining_of_contract , 'SD') as begining_of_day,
      pka_com_function.fp_get_thaidate(sc_lon_m_contract.begining_of_contract , 'YYYY') as begining_of_year,
      pka_com_function.fp_get_thaidate(sc_lon_m_contract.begining_of_contract , 'MONTH') as begining_of_month,
			sc_lon_m_contract.loan_type ,			
			sc_lon_m_rule.loan_type_description ,
			sc_lon_m_contract.membership_no   ,		
			sc_lon_m_contract.loan_approve_amount,
			sc_mem_m_membership_registered.phone ,
			sc_lon_m_loan_request.max_loan_permit,   
			sc_lon_m_loan_request.total_old_loan,   
			sc_lon_m_loan_request.total_oldint,   
			sc_lon_m_loan_request.buy_share,
      si_security_user.user_name,
      sc_lon_m_req_fee.amount
   
     ,nvl((select sum(principal_of_loan)
      from sc_lon_m_loan_history,
      sc_lon_m_contract
      where sc_lon_m_loan_history.loan_requestment_no = sc_lon_m_loan_request.loan_requestment_no
      and sc_lon_m_loan_history.loan_contract_no = sc_lon_m_contract.loan_contract_no
      and sc_lon_m_contract.loan_type = 'ฉ'
      and sc_lon_m_loan_history.clear_target = '1'),0) as principal_of_loan
      
      ,nvl((select sum(interest_amount)
      from sc_lon_m_loan_history,
      sc_lon_m_contract
      where sc_lon_m_loan_history.loan_requestment_no = sc_lon_m_loan_request.loan_requestment_no
      and sc_lon_m_loan_history.loan_contract_no = sc_lon_m_contract.loan_contract_no
      and sc_lon_m_contract.loan_type = 'ฉ'
      and sc_lon_m_loan_history.clear_target = '1'),0) as interest_amount

FROM 		sc_lon_m_contract_coll ,
			sc_lon_m_contract ,
			sc_mem_m_membership_registered ,
      sc_lon_m_req_fee,
      si_security_user,
			sc_lon_m_rule     ,		
			sc_lon_m_loan_request
WHERE 1 = 2
/*WHERE*/
order by sc_lon_m_contract.begining_of_contract
,sc_lon_m_contract.loan_contract_no </value>
  </data>

  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT  sc_mem_m_membership_registered.membership_no , 
        '!loan_payment_date_2!' as adtm_edate,
        'เลขที่ '||pka_com_function.fp_get_member_address_perm(sc_mem_m_membership_registered.membership_no) as c_address,
        (select coop_name from sc_cnt_m_coop) as coop_name,  
        sc_lon_m_loan_card_detail.loan_payment_date,
        (select prename from sc_mem_m_ucf_prename where prename_code = sc_mem_m_membership_registered.prename_code)||sc_mem_m_membership_registered.member_name||' '||sc_mem_m_membership_registered.member_surname as member_name,
           sc_lon_m_contract.loan_contract_no ,
        pka_lon_intsrv.fp_intrate_table_loantype( sc_lon_m_contract.loan_type , sc_lon_m_contract.begining_of_contract ) * 100 as lon_int_rate,
         (-sign_status *  interest_amout ) as c_int,
           sc_lon_m_contract.begining_of_contract ,
           sc_lon_m_contract.loan_installment_amount ,
           sc_lon_m_contract.loan_type ,
           sc_lon_m_contract.loan_objective_code ,
           sc_lon_m_contract.loan_approve_amount ,
           sc_lon_m_ucf_loan_card_item.sign_status ,
           sc_lon_m_loan_card_detail.interest_amout     
        FROM sc_lon_m_loan_card_detail ,
           sc_lon_m_ucf_loan_card_item ,
           sc_mem_m_membership_registered ,
           sc_lon_m_contract     
        WHERE 1 = 2
        /*WHERE*/
        --and  ( sc_lon_m_loan_card_detail.loan_payment_date between '10/06/2021' and '11/06/2021' ) 
        --and ( sc_mem_m_membership_registered.membership_no = '009011' )  </value>
  </data>

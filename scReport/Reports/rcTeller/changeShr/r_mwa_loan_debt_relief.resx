  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT  sc_mem_m_chg_loan_det.membership_no 
        ,sc_mem_m_chg_loan_det.document_no 
        ,sc_mem_m_chg_loan_det.loan_contract 
        ,sc_mem_m_chg_loan_det.pricipal 
        ,sc_mem_m_chg_loan_det.balance 
        ,nvl(sc_mem_m_chg_loan_det.period_old,0) as period_old
        ,sc_mem_m_chg_loan_det.period_payment_old 
        ,sc_mem_m_chg_loan_det.period_payment_new 
        ,sc_mem_m_chg_loan_det.period_compomise 

        ,pka_com_function.fp_get_thaidate(sc_mem_m_chg_loan_det.effactive_date, 'DD/MM/YYYY') as effactive_tdate
        ,sc_mem_m_chg_loan_det.remark 
        ,sc_mem_m_share_mem.share_stock 
        ,sc_mem_m_membership_registered.salary_amount 
        ,sc_mem_m_ucf_member_group_a.member_group_no 
        ,sc_mem_m_ucf_member_group_a.member_group_control 
        ,sc_mem_m_ucf_member_group_a.member_group_name 
        ,sc_mem_m_ucf_member_group_b.member_group_name 
        ,sc_mem_m_ucf_prename.prename 
        ,sc_mem_m_membership_registered.member_name 
        ,sc_mem_m_membership_registered.member_surname 
        ,sc_mem_m_share_mem.period_recrieve  
        ,pka_com_function.fp_get_thaidate(sc_mem_m_chang_request.operate_date, 'DD/MM/YYYY') as operate_tdate
        ,sc_mem_m_chg_loan_det.installment_old  
        ,sc_mem_m_chang_request.approve_id 
        
        ,sc_mem_m_chg_loan_det.code_put
        ,case 
         when sc_mem_m_chg_loan_det.code_put = '01' then 'คงต้น'
         when sc_mem_m_chg_loan_det.code_put = '02' then 'คงยอด'
         else null
         end as code_put_desc
        
        ,sc_mem_m_chg_loan_det.drop_status_last
        ,case
        when sc_mem_m_chg_loan_det.drop_status_last = '0' then 'ปกติ'
        when sc_mem_m_chg_loan_det.drop_status_last = '1' then 'งดส่งทั้งหมด'
        when sc_mem_m_chg_loan_det.drop_status_last = '2' then 'งดต้น'
        when sc_mem_m_chg_loan_det.drop_status_last = '3' then 'งดดอก'
        when sc_mem_m_chg_loan_det.drop_status_last = '4' then 'ปกติ/เปลี่ยนแปลง'
        else null
        end as drop_status_last_desc
        
        ,sc_mem_m_chg_loan_det.drop_status
        ,case
        when sc_mem_m_chg_loan_det.drop_status = '0' then 'ปกติ'
        when sc_mem_m_chg_loan_det.drop_status = '1' then 'งดส่งทั้งหมด'
        when sc_mem_m_chg_loan_det.drop_status = '2' then 'งดต้น'
        when sc_mem_m_chg_loan_det.drop_status = '3' then 'งดดอก'
        when sc_mem_m_chg_loan_det.drop_status = '4' then 'ปกติ/เปลี่ยนแปลง'
        else null
        end as drop_status_desc
         
         
FROM sc_mem_m_chg_loan_det
    ,sc_mem_m_membership_registered
    ,sc_mem_m_share_mem
    ,sc_mem_m_ucf_member_group sc_mem_m_ucf_member_group_a
    ,sc_mem_m_ucf_member_group sc_mem_m_ucf_member_group_b
    ,sc_mem_m_ucf_prename
    ,sc_mem_m_chang_request 
           
WHERE 1 = 2</value>

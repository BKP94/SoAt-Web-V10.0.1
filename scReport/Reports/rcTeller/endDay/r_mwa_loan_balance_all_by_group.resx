  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT sc_lon_m_rule.loan_group_code,   
       count(  sc_lon_m_contract.loan_contract_no ) as count_contract,   
       sum(sc_lon_m_loan_card.principal_balance  ) as principal_balance
         
         ,( select  count(membership_no)
            from	  sc_mem_m_membership_registered
            where	  (sc_mem_m_membership_registered.member_group_no between '0000' and '9500') 
            and    (member_status_code &lt;&gt;'3')) as c_count_mem
          
        ,(  select 	nvl(sum(sc_mem_m_share_mem.share_stock),0)   
            from 	sc_mem_m_share_mem,   	
                  sc_mem_m_membership_registered  
            where ( sc_mem_m_membership_registered.membership_no = sc_mem_m_share_mem.membership_no ) 
            and   (sc_mem_m_membership_registered.member_status_code  = '0') 
            and  	(sc_mem_m_membership_registered.member_group_no  not in ('a8000', 'a8100'))) as c_share_stock_mem_code_0
            
         ,( select 	nvl(sum(sc_mem_m_share_mem.share_stock),0)  
            from 	sc_mem_m_share_mem,   
                  sc_mem_m_membership_registered  
            Where ( sc_mem_m_membership_registered.membership_no = sc_mem_m_share_mem.membership_no ) 
            and		(sc_mem_m_membership_registered.member_group_no  = 'a8000')) as c_share_stock_mem_code_1
            
          ,case loan_group_code when '01' then 'เงินกู้ฉุกเฉิน' when '02' then 'เงินกู้สามัญ' when '03' then 'เงินกู้พิเศษ' end as c_loan_group_code
            
FROM sc_lon_m_loan_card,   
         sc_lon_m_rule,   
         sc_lon_m_contract,   
         sc_mem_m_membership_registered  
WHERE  1 = 2
GROUP BY sc_lon_m_rule.loan_group_code   </value>
  </data>

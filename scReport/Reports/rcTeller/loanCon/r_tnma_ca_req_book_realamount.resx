  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>select tab.*
from (
select '0' as sort
,loan_requestment_no
,loan_contract_no as description
,principal_balance_of_loan as pricipal_balance
,interest_amount
,(principal_balance_of_loan + interest_amount) as total
from sc_lon_m_loan_history
where 1=1
and clear_target = '1'
and loan_requestment_no = '!loan_requestment_no!'

union

select '1' as sort
,loan_requestment_no
,'ซื้อหุ้น' as description
,0 as pricipal_balance
,0 as interest_amount
,buy_share as total
from sc_lon_m_loan_request
where 1=1
and loan_requestment_no = '!loan_requestment_no!'

union

select '2' as sort
,sc_lon_m_req_fee.loan_requestment_no
,sc_lon_m_ucf_fee.fee_name as description
,0 as pricipal_balance
,0 as interest_amount
,sc_lon_m_req_fee.amount as total
from sc_lon_m_req_fee
,sc_lon_m_ucf_fee
where 1=1
and sc_lon_m_req_fee.fee_type = sc_lon_m_ucf_fee.fee_type
and loan_requestment_no = '!loan_requestment_no!'

union

select '3' as sort
,sc_lon_m_loan_request_mpaid.loan_requestment_no
,'เงินฝาก' as description
,0 as pricipal_balance
,0 as interest_amount
,sum(sc_lon_m_loan_request_mpaid.paid_amount) as total
from sc_lon_m_loan_request_mpaid
where 1=1
and sc_lon_m_loan_request_mpaid.type_pay_money = 'TRD'
and loan_requestment_no = '!loan_requestment_no!'
group by sc_lon_m_loan_request_mpaid.loan_requestment_no
union

select '4' as sort
,sc_lon_m_loan_request.loan_requestment_no
,'ประมาณการ ดบ. งวดแรก 31 วัน' as description
,0 as pricipal_balance
,0 as interest_amount
,sc_lon_m_loan_request.interest_first as total
from sc_lon_m_loan_request
where 1=1
and loan_requestment_no = '!loan_requestment_no!'

) tab
where 1=1
/*WHERE*/
--and (tab.sort = '3' or tab.loan_requestment_no = '6710000005')</value>

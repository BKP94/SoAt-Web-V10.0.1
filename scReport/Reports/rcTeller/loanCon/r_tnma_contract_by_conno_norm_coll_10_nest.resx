  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>select sc_lon_m_contract_coll.ref_own_no
,sc_lon_m_contract.loan_contract_no
,sc_lon_m_contract_coll.collateral_description
,pka_com_function.fp_get_member_position_name( sc_lon_m_contract_coll.ref_own_no ) as position
,sc_mem_m_ucf_member_group.member_group_no
,pka_com_function.fp_get_group_name_mem(sc_lon_m_contract_coll.ref_own_no) as group_name
,sc_mem_m_membership_registered.salary_amount

--ที่อยู่ปัจจุบัน
,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no, '0' , 6 ) as address_no
,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no, '0' , 8 ) as moo
,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no, '0' , 7 ) as mooban
,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no, '0' , 10 ) as soi
,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no, '0' , 9 ) as road
,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no, '0' , 11 ) as tambol
,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no, '0' , 12 ) as district
,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no, '0' , 13 ) as province
,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no, '0' , 14 ) as postcode
,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no, '0' , 15 ) as telephone

,pka_com_function.fp_get_district_name( sc_mem_m_ucf_member_group.province_code , sc_mem_m_ucf_member_group.district_code ) as group_district 
,sc_lon_m_contract_coll.collateral_no
from sc_lon_m_contract
,si_security_user
,sc_lon_m_contract_coll
,sc_mem_m_membership_registered
,sc_mem_m_member_work_info
,sc_mem_m_ucf_member_group
,sc_mem_m_ucf_member_group_addr

where si_security_user.user_id = sc_lon_m_contract.appove_officer
and sc_lon_m_contract.loan_contract_no = sc_lon_m_contract_coll.loan_contract_no
and sc_mem_m_membership_registered.membership_no = sc_lon_m_contract_coll.ref_own_no
and sc_mem_m_member_work_info.membership_no = sc_lon_m_contract_coll.ref_own_no
and sc_mem_m_membership_registered.member_group_no = sc_mem_m_ucf_member_group.member_group_no
and sc_mem_m_ucf_member_group.member_group_no = sc_mem_m_ucf_member_group_addr.member_group_no

/*WHERE*/
--and sc_lon_m_contract.loan_contract_no = 'ส6801085'
order by sc_lon_m_contract.loan_contract_no , sc_lon_m_contract_coll.collateral_no</value>

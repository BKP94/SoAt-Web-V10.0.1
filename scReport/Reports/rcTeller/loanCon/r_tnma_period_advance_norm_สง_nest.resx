  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT  
        sum(DECODE(tab.row_no ,1  ,period_payment_amount ,'' )) as seq_no_1
    ,   sum(DECODE(tab.row_no ,2  ,period_payment_amount ,'' )) as seq_no_2
    ,   sum(DECODE(tab.row_no ,3  ,period_payment_amount ,'' )) as seq_no_3
    ,   sum(DECODE(tab.row_no ,4  ,period_payment_amount ,'' )) as seq_no_4
    ,   sum(DECODE(tab.row_no ,5  ,period_payment_amount ,'' )) as seq_no_5
    ,   sum(DECODE(tab.row_no ,6  ,period_payment_amount ,'' )) as seq_no_6
    ,   sum(DECODE(tab.row_no ,7  ,period_payment_amount ,'' )) as seq_no_7
    ,   sum(DECODE(tab.row_no ,8  ,period_payment_amount ,'' )) as seq_no_8
    ,   sum(DECODE(tab.row_no ,9  ,period_payment_amount ,'' )) as seq_no_9
    ,   sum(DECODE(tab.row_no ,10 ,period_payment_amount ,'' )) as seq_no_10
    ,   sum(DECODE(tab.row_no ,11 ,period_payment_amount ,'' )) as seq_no_11
    ,   sum(DECODE(tab.row_no ,12 ,period_payment_amount ,'' )) as seq_no_12
    ,   sum(DECODE(tab.row_no ,13 ,period_payment_amount ,'' )) as seq_no_13
    ,   sum(DECODE(tab.row_no ,14 ,period_payment_amount ,'' )) as seq_no_14
    ,   sum(DECODE(tab.row_no ,15 ,period_payment_amount ,'' )) as seq_no_15
    ,   sum(DECODE(tab.row_no ,16 ,period_payment_amount ,'' )) as seq_no_16
    ,   sum(DECODE(tab.row_no ,17 ,period_payment_amount ,'' )) as seq_no_17
    ,   sum(DECODE(tab.row_no ,18 ,period_payment_amount ,'' )) as seq_no_18
    ,   sum(DECODE(tab.row_no ,19 ,period_payment_amount ,'' )) as seq_no_19
    ,   sum(DECODE(tab.row_no ,20 ,period_payment_amount ,'' )) as seq_no_20
    ,   sum(DECODE(tab.row_no ,21 ,period_payment_amount ,'' )) as seq_no_21
    ,   sum(DECODE(tab.row_no ,22 ,period_payment_amount ,'' )) as seq_no_22
    ,   sum(DECODE(tab.row_no ,23 ,period_payment_amount ,'' )) as seq_no_23
    ,   sum(DECODE(tab.row_no ,24 ,period_payment_amount ,'' )) as seq_no_24
    ,   sum(DECODE(tab.row_no ,25 ,period_payment_amount ,'' )) as seq_no_25
    
FROM
    (
        select sc_lon_m_contract.loan_contract_no,
        sc_lon_m_loan_request_step_pay.effective_date,
        sc_lon_m_loan_request_step_pay.period_step as period_last,
        sc_lon_m_loan_request_step_pay.period_payment as period_payment_amount
        , ROW_NUMBER() OVER (PARTITION BY sc_lon_m_contract.loan_contract_no  ORDER BY sc_lon_m_loan_request_step_pay.period_step) AS row_no
        
        from sc_lon_m_loan_request_step_pay
        ,sc_lon_m_contract
        
        where 1=1
        and trim(sc_lon_m_contract.loan_requestment_no) = trim(sc_lon_m_loan_request_step_pay.loan_requestment_no)
        /*WHERE*/
            --and     sc_lon_m_contract.loan_contract_no = 'สง6900014'
        FETCH FIRST 25 ROWS ONLY
        
    ) TAB</value>

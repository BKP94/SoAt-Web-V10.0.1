  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT sc_lon_m_loan_request.loan_requestment_no ,
sc_lon_m_loan_request.requestment_date ,
PKA_COM_FUNCTION.fp_get_thaidate( sc_lon_m_loan_request.requestment_date ) AS requestment_date_tdate ,
sc_lon_m_loan_request.loan_type ,
sc_lon_m_loan_request.membership_no ,
PKA_COM_FUNCTION.fp_get_member_name( sc_lon_m_loan_request.membership_no ) AS membername ,
sc_lon_m_loan_request.loan_request_amount ,
sc_lon_m_loan_request.mem_request_amount ,
sc_lon_m_loan_request.period_payment_amount ,
sc_lon_m_loan_request.loan_installment_amount ,
sc_lon_m_loan_request.begining_of_contract ,
sc_lon_m_loan_request.remark ,
sc_lon_m_loan_request.start_keep_date ,
sc_lon_m_loan_request.salary_amount ,
sc_lon_m_loan_request.total_old_loan ,
sc_lon_m_loan_request.total_oldint ,
sc_lon_m_loan_request.loan_payment_type_code ,
sc_lon_m_loan_request.entry_id ,
sc_lon_m_loan_request.fee_amount ,
sc_lon_m_loan_request.total_share_value ,
sc_lon_m_loan_request.entry_date ,
sc_lon_m_loan_request.approve_status ,
sc_lon_m_loan_request.cancel_status ,
sc_lon_m_loan_request.approve_id ,
sc_lon_m_loan_request.interest_first ,
sc_lon_m_loan_request.buy_share ,
sc_lon_m_loan_request.max_loan_permit ,
sc_lon_m_loan_request.contract_code ,
sc_lon_m_loan_request.monthshare ,
sc_lon_m_loan_request.monthdep,
sc_lon_m_loan_request.monthloan,
sc_lon_m_loan_request.other_amount,
--sc_lon_m_loan_request.rev_amount ,
0.00 as rev_amount ,
--sc_lon_m_loan_request.exp_amount ,
0.00 as exp_amount ,
sc_lon_m_loan_request.bank_code  ,
sc_lon_m_loan_request.bank_acc_no ,
--sc_lon_m_loan_request.period_share ,
'' as period_share ,
sc_lon_m_loan_request.document_status ,

  sc_lon_m_rule.loan_type_description ,


  TRUNC( pka_lon_reqsrv.fp_calc_install_m_live(sc_lon_m_loan_request.membership_no,sc_lon_m_loan_request.requestment_date)/12 ) AS age_MEM_LOAN

,sc_com_m_ucf_money_type.money_type_id
,sc_com_m_ucf_money_type.money_type_name


,nvl( (  SELECT sum( sc_lon_m_req_loan_clear_ext.paid_amount  )
    FROM sc_lon_m_req_loan_clear_ext  
   WHERE sc_lon_m_req_loan_clear_ext.loan_requestment_no =   sc_lon_m_loan_request.loan_requestment_no ), 0 )  as paid_amount_ext
, sc_mem_m_ucf_member_group.member_group_name

,nvl( ( select sum( paid_amount)  
		from sc_lon_m_loan_request_mpaid
		,sc_com_m_ucf_money_type
		where loan_requestment_no = sc_lon_m_loan_request.loan_requestment_no
		and type_pay_money = money_type_id
		and account_type = 'SET'
		and money_type_id = '180'
 ), 0 )  as ext_amount
,	(	select nvl(sc_lon_m_req_coll.req_amount , 0)
		from	sc_lon_m_req_coll
		where sc_lon_m_req_coll.loan_requestment_no	=	sc_lon_m_loan_request.loan_requestment_no
		and sc_lon_m_req_coll.collateral_type_code  = '03'
	)	as req_amount_dep

,(  	select   sc_lon_m_ucf_loan_obj.loan_objective_description
    	from 	sc_lon_m_ucf_loan_obj
  	 where ( sc_lon_m_ucf_loan_obj.loan_type = sc_lon_m_loan_request.loan_type ) and  
         		  ( sc_lon_m_ucf_loan_obj.loan_objective_code 	= sc_lon_m_loan_request.loan_objective_code ) 
) as loan_objective_description

, '' as rowno
FROM sc_lon_m_loan_request ,
  sc_mem_m_membership_registered ,
  sc_mem_m_ucf_member_group ,
  sc_lon_m_rule ,
  si_security_user
,sc_com_m_ucf_money_type

WHERE 1 = 2
--( sc_lon_m_loan_request.membership_no          		= sc_mem_m_membership_registered.membership_no )
--AND ( sc_mem_m_membership_registered.member_group_no = sc_mem_m_ucf_member_group.member_group_no )
--AND ( sc_lon_m_loan_request.loan_type               	 			= sc_lon_m_rule.loan_type )
--AND ( sc_lon_m_loan_request.entry_id                  					= security_users.names )
--AND ( sc_lon_m_loan_request.cancel_status  = '0' )
--AND  ( sc_lon_m_loan_request.type_pay_money 				= sc_com_m_ucf_money_type.money_type_id )</value>

  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT PKA_COM_FUNCTION.fp_get_member_name( sc_lon_m_loan_request.membership_no ) as membername ,
sc_lon_m_loan_request.membership_no ,
sc_lon_m_loan_request.loan_type ,
sc_lon_m_loan_request.crem_code,
sc_lon_m_loan_request.crem_status,
sc_lon_m_loan_request.interest_first,
'' as request_amount,
(select regis_date from sc_doc_regis where sc_doc_regis.regis_no = sc_lon_m_loan_request.loan_requestment_no) as regis_date,
sc_lon_m_loan_request.loan_requestment_no ,
sc_lon_m_loan_request.requestment_date ,
sc_lon_m_loan_request.max_loan_permit,
sc_lon_m_loan_request.crem_amount,
	nvl((select sc_lon_m_req_fee.amount
		from sc_lon_m_req_fee
		where ( sc_lon_m_req_fee.loan_requestment_no = sc_lon_m_loan_request.loan_requestment_no
		and fee_type = '05' )) ,0)as amount,
    
    nvl((select sc_lon_m_req_fee.real_amount
		from sc_lon_m_req_fee
		where ( sc_lon_m_req_fee.loan_requestment_no = sc_lon_m_loan_request.loan_requestment_no
		and fee_type = '05' )) ,0)as real_amount ,
'' as fund_ret_old,
'' as tdate_requestment_date ,
'' as money_type_name,
'' as rowno 
   ,( select nvl(sum(fund_new),0)
    from sc_lon_m_req_fund_new
    where sc_lon_m_req_fund_new.loan_requestment_no = sc_lon_m_loan_request.loan_requestment_no
    ) as fund_new

    ,(  select nvl(sum(fund_real),0) + nvl(sum(fund_int),0)
    from sc_lon_m_req_fund_ret
    where sc_lon_m_req_fund_ret.loan_requestment_no = sc_lon_m_loan_request.loan_requestment_no
    and fund_ret &gt; 0
    ) as fund_ret

    , ( select nvl(sum(fund_real),0) + nvl(sum(fund_int),0)
    from sc_lon_m_req_fund_ret
    where sc_lon_m_req_fund_ret.loan_requestment_no = sc_lon_m_loan_request.loan_requestment_no
    and fund_ret &gt; 0
    and deposit_account_no = 'NEW'
    ) as fund_ret_old

    ,(  select nvl(sum(fund_real),0) + nvl(sum(fund_int),0)
    from sc_lon_m_req_fund_ret
    where sc_lon_m_req_fund_ret.loan_requestment_no = sc_lon_m_loan_request.loan_requestment_no
    and fund_ret &gt; 0
    and deposit_account_no &lt;&gt; 'NEW'
    ) as fund_ret_50,
pka_lon_reqsrv.fp_rule_loanpermit_levelcustom(sc_lon_m_loan_request.loan_type ,sc_lon_m_loan_request.membership_no ,to_date(sysdate) ,'loan_by_salary') as recoverable,
sc_lon_m_loan_request.begining_of_contract ,
sc_lon_m_loan_request.loan_payment_type_code ,
sc_lon_m_loan_request.loan_request_amount ,
sc_lon_m_loan_request.loan_installment_amount ,
sc_lon_m_loan_request.period_payment_amount ,
sc_lon_m_loan_request.start_keep_date ,

sc_lon_m_loan_request_mpaid.bank_code,
    sc_lon_m_loan_request_mpaid.bank_acc_no ,
    sc_lon_m_loan_request_mpaid.type_pay_money,
    (select sc_com_m_ucf_money_type.money_type_name from sc_com_m_ucf_money_type where sc_com_m_ucf_money_type.money_type_id = sc_lon_m_loan_request_mpaid.type_pay_money) as money_type_name ,

sc_lon_m_loan_request.salary_amount ,
sc_lon_m_loan_request.entry_id ,
sc_lon_m_loan_request.total_old_loan ,
sc_lon_m_loan_request.total_oldint ,

sc_mem_m_ucf_member_group.member_group_no,   
sc_mem_m_ucf_member_group.member_group_name,   
sc_mem_m_ucf_member_group.member_group_control ,
sc_mem_m_ucf_member_group.control_id


,sc_lon_m_loan_request.buy_share
,sc_lon_m_loan_request.fee_amount
,sc_lon_m_rule.ref_contract_no
,sc_mem_m_share_mem.share_stock
,null as loan_type_description


FROM 	sc_lon_m_loan_request ,
sc_mem_m_membership_registered ,       
sc_mem_m_ucf_member_group ,
sc_lon_m_rule ,
sc_mem_m_share_mem,
sc_lon_m_loan_request_mpaid
WHERE 1 = 2
--( sc_mem_m_membership_registered.member_group_no 	= sc_mem_m_ucf_member_group.member_group_no ) 
--and		(sc_lon_m_loan_request.entry_id = security_users.names) 
--and          	( sc_mem_m_membership_registered.membership_no 	= sc_lon_m_loan_request.membership_no ) 
--and          	( sc_lon_m_loan_request.loan_type 							= sc_lon_m_rule.loan_type ) 
--and 		( sc_mem_m_membership_registered.membership_no 	= sc_mem_m_share_mem.membership_no ) 

</value>

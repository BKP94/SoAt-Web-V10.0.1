  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>    SELECT sc_lon_m_loan_request.loan_requestment_no
,sc_mem_m_membership_registered.membership_no
    ,sc_com_m_branch.branch_name
    ,      '' as coll_description ---การค้ำ
    ,       (select prename from sc_mem_m_ucf_prename  where prename_code = sc_mem_m_membership_registered.prename_code ) ||sc_mem_m_membership_registered.member_name  ||' '||sc_mem_m_membership_registered.member_surname as member_name
    ,       sc_mem_m_membership_registered.member_group_no ||':'||sc_mem_m_membership_registered.membership_no as group_memno
    ,       (select sc_mem_m_ucf_member_group.member_group_name from sc_mem_m_ucf_member_group where sc_mem_m_ucf_member_group.member_group_no = sc_mem_m_membership_registered.member_group_no)  as member_group_name
    ,       sc_lon_m_loan_request.loan_request_amount
    ,       sc_lon_m_loan_request.period_payment_amount
    ,       (select sum(sc_lon_m_req_fund_ret.fund_ret)
              from  sc_lon_m_req_fund_ret
              where sc_lon_m_req_fund_ret.loan_requestment_no = sc_lon_m_loan_request.loan_requestment_no) as fund_ret --กองทุเก่า
    ,       (select sum(sc_lon_m_req_fund_new.fund_add)
              from  sc_lon_m_req_fund_new
              where sc_lon_m_req_fund_new.loan_requestment_no = sc_lon_m_loan_request.loan_requestment_no) as fund_add  --กองทุนใหม่
    ,       '' as insure  --ค่าเบี้ยประกัน
    ,       '' as cream_amount --ค่า ฌปนกิจ
    ,       sc_lon_m_loan_request.interest_first
    ,       sc_lon_m_loan_request.buy_share
    ,       sc_lon_m_contract.real_recieve
    
    ,       sc_lon_m_loan_request.total_old_loan
    ,       sc_lon_m_loan_request.total_oldint
    FROM sc_lon_m_loan_request ,
    sc_lon_m_contract,
    sc_mem_m_membership_registered,
    sc_com_m_branch
    WHERE 1=2
    /*WHERE*/
    ORDER BY sc_lon_m_loan_request.branch_id ASC,
    sc_lon_m_loan_request.loan_requestment_no ASC,
    sc_lon_m_loan_request.membership_no ASC</value>

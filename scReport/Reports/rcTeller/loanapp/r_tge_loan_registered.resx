  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT sc_acc_m_account_master.account_id,   
         sc_acc_m_account_master.account_name,   
         sc_lon_m_contract.branch_id ,
        sc_lon_m_contract.begining_of_contract,
         sc_lon_m_rule.ref_contract_no,   
         ( SELECT  rule.loan_type_description  FROM sc_lon_m_rule rule   WHERE rule.loan_type = sc_lon_m_rule.ref_contract_no ) as loan_type_description,   
        
         sc_lon_m_contract.loan_contract_no,   
         sc_lon_m_contract.membership_no,   
         sc_lon_m_ucf_loan_payment_type.loan_payment_type_desc,   
         sc_lon_m_contract.period_payment_amount,   
         sc_lon_m_contract.loan_installment_amount,   
         sc_lon_m_contract.loan_approve_amount,   
         pka_com_function.fp_get_member_name( sc_lon_m_contract.membership_no )   as memname  
  
,(    SELECT sum(  sc_com_m_receipt_item.item_amount  )
    FROM sc_com_m_receipt,   
         sc_com_m_receipt_item,   
         sc_com_m_ucf_receipt_item_type  
   WHERE ( sc_com_m_receipt.receipt_no = sc_com_m_receipt_item.receipt_no ) and  
         ( sc_com_m_receipt_item.item_type_id = sc_com_m_ucf_receipt_item_type.item_type_id ) and  
         ( sc_com_m_receipt.loan_contract_no = sc_lon_m_contract.loan_contract_no ) AND  
         ( sc_com_m_receipt.receipt_status = '0' ) 
) as sum_item_amount
,sc_lon_m_contract.real_recieve
/*ให้เงินสดขึ้นก่อน*/
,(case when sc_com_m_ucf_money_type.money_type_id = 'CSH' then '_A'
else sc_com_m_ucf_money_type.money_type_id
end
)as money_type_sort
,sc_com_m_ucf_money_type.money_type_id
,sc_com_m_ucf_money_type.money_type_name
,sc_lon_m_loan_request.total_old_loan
,sc_lon_m_loan_request.total_oldint
    FROM sc_lon_m_rule,   
         sc_acc_m_account_master,   
         sc_lon_m_contract,   
         sc_lon_m_ucf_loan_payment_type  ,
          sc_com_m_branch
,sc_lon_m_contract_multi_paid
,sc_com_m_ucf_money_type
,sc_lon_m_loan_request
   WHERE ( sc_lon_m_rule.account_id = sc_acc_m_account_master.account_id ) and  
         ( sc_lon_m_rule.loan_type = sc_lon_m_contract.loan_type ) and  
         ( sc_lon_m_contract.loan_payment_type_code = sc_lon_m_ucf_loan_payment_type.loan_payment_type_code ) and          
          (sc_lon_m_loan_request.loan_requestment_no = sc_lon_m_contract.loan_requestment_no ) and
         ( sc_lon_m_contract.create_loan_status = '1' )   and
         ( sc_com_m_branch.branch_id = sc_lon_m_contract.branch_id ) 
and sc_lon_m_contract_multi_paid.loan_contract_no = sc_lon_m_contract.loan_contract_no
and sc_lon_m_contract_multi_paid.type_pay_money = sc_com_m_ucf_money_type.money_type_id
and  sc_lon_m_contract_multi_paid.seq_no = 1
and  sc_lon_m_rule.invest_status = '0'
    
/*WHERE*/
--and    sc_acc_m_account_master.account_id  = '115120' 
and     sc_com_m_branch.branch_id = '01'
--and     sc_lon_m_contract.begining_of_contract =  '03 พ.ย. 2022'

ORDER BY sc_com_m_branch.branch_id ASC ,
sc_lon_m_contract.begining_of_contract ASC ,
 sc_lon_m_rule.ref_contract_no ASC ,  
         sc_lon_m_contract.loan_contract_no ASC</value>

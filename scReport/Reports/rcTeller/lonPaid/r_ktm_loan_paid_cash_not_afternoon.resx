  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT PKA_COM_FUNCTION.fp_get_member_name( sc_lon_m_contract.membership_no ) as membername ,
    sc_lon_m_contract.membership_no ,
    sc_mem_m_ucf_member_group.member_group_type,
    sc_lon_m_loan_request.crem_amount,
    FPB_GET_LOAN_TYPE_REF(  sc_lon_m_contract.loan_type ) as loan_type ,
    FPB_GET_LOAN_TYPE_DESC( FPB_GET_LOAN_TYPE_REF(  sc_lon_m_contract.loan_type ))  as loan_type_description ,
    '' as fund_new,
    '' as fund_ret,
    '' as fund_int_50,

    '' as fund_ret_old,

    ''  as fund_ret_50,
    '' as thia_begining_of_contract,
    sc_lon_m_contract.loan_requestment_no ,
    sc_lon_m_contract.begining_of_contract ,
    sc_lon_m_contract.loan_payment_type_code ,
    sc_lon_m_contract.loan_approve_amount ,
    sc_lon_m_contract.loan_installment_amount ,
    sc_lon_m_contract.period_payment_amount ,
    sc_lon_m_contract.start_keep_date ,
    sc_lon_m_contract.real_recieve ,
    sc_lon_m_contract.loan_contract_no ,
    sc_lon_m_contract.appove_officer ,    
    sc_lon_m_contract.rec_rep_status,

    sc_lon_m_contract_multi_paid.type_pay_money, 
     sc_lon_m_contract_multi_paid.bank_acc_no , 

    sc_lon_m_loan_request.salary_amount ,
    sc_lon_m_loan_request.entry_id ,

    sc_com_m_branch.branch_id ,
    sc_com_m_branch.branch_name ,


    sc_mem_m_ucf_member_group.member_group_no,
    sc_mem_m_ucf_member_group.member_group_name,
    sc_mem_m_ucf_member_group.member_group_control ,
    sc_mem_m_ucf_member_group.control_id

    ,sc_com_m_ucf_money_type.sort_order
    ,sc_com_m_ucf_money_type.money_type_id
    ,sc_com_m_ucf_money_type.money_type_name
    ,sc_lon_m_contract.paid_loan_id

    ,(  	SELECT   sum( sc_com_m_receipt_item.principal_amount )
    FROM 	sc_com_m_receipt,
    sc_com_m_receipt_item
    WHERE ( sc_com_m_receipt.receipt_no = sc_com_m_receipt_item.receipt_no ) and
    ( sc_com_m_receipt.loan_contract_no = sc_lon_m_contract.loan_contract_no ) AND
    ( sc_com_m_receipt.money_type_id = 'CLR' ) AND
    ( sc_com_m_receipt.receipt_status = '0' )
    ) as principal_amount
    ,(  	SELECT   sum( sc_com_m_receipt_item.interest_amount )
    FROM 	sc_com_m_receipt,
    sc_com_m_receipt_item
    WHERE ( sc_com_m_receipt.receipt_no = sc_com_m_receipt_item.receipt_no ) and
    ( sc_com_m_receipt.loan_contract_no = sc_lon_m_contract.loan_contract_no ) AND
    ( sc_com_m_receipt.money_type_id = 'CLR' ) AND
    ( sc_com_m_receipt.receipt_status = '0' )
    ) as interest_amount
    ,(  	SELECT   sum( sc_com_m_receipt_item.item_amount )
    FROM 	sc_com_m_receipt,
    sc_com_m_receipt_item
    WHERE ( sc_com_m_receipt.receipt_no = sc_com_m_receipt_item.receipt_no ) and
    ( sc_com_m_receipt.loan_contract_no = sc_lon_m_contract.loan_contract_no ) AND
    ( sc_com_m_receipt.money_type_id = 'CLR' ) AND
    ( sc_com_m_receipt.receipt_status = '0' )
    ) as item_amount
    ,si_security_user.user_name as paid_name
    ,sc_lon_m_rule.account_id
, '' as account_name
    FROM 	sc_lon_m_loan_request ,
    sc_mem_m_membership_registered ,
    sc_mem_m_ucf_member_group ,
    sc_lon_m_rule ,
    sc_lon_m_contract     ,
    sc_com_m_branch  ,
    sc_com_m_ucf_money_type
    ,si_security_user 
    ,sc_lon_m_contract_multi_paid
    WHERE 	( sc_mem_m_membership_registered.member_group_no 	= sc_mem_m_ucf_member_group.member_group_no )
    and          	( sc_lon_m_contract.loan_requestment_no 				= sc_lon_m_loan_request.loan_requestment_no )
    and          	( sc_mem_m_membership_registered.membership_no 	= sc_lon_m_contract.membership_no )
    and          	( sc_lon_m_contract.loan_type 							= sc_lon_m_rule.loan_type )
    and          	( sc_com_m_branch.branch_id 							= sc_lon_m_contract.paid_loan_br )   
    and		sc_com_m_ucf_money_type.money_type_id =  sc_lon_m_contract_multi_paid.type_pay_money
    and		si_security_user.user_id  =     sc_lon_m_contract.paid_loan_id
    and		sc_lon_m_contract_multi_paid.type_pay_money not in (  'CSH' , 'ATM' ) 
    and		sc_lon_m_contract.rec_rep_status = '1'
    and		sc_lon_m_contract_multi_paid.loan_contract_no = sc_lon_m_contract.loan_contract_no
    
    /*WHERE*/
and 1=2
order by sc_lon_m_contract.begining_of_contract ,
sc_com_m_branch.branch_id ,
sc_lon_m_rule.account_id ,
sc_lon_m_contract.loan_type,
sc_lon_m_contract.loan_contract_no</value>

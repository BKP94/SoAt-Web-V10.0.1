  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>  SELECT
sc_com_m_ucf_receipt_item_type.group_item  as group_item
,sc_com_m_ucf_receipt_item_type.item_type_name
,'' as rowno
,'' as case_item_type_name
,sum( sc_com_m_receipt_item.principal_amount ) as  principal_amount   
,sum( sc_com_m_receipt_item.interest_amount ) as interest_amount   
,sum( sc_com_m_receipt_item.item_amount ) as item_amount   
,count( sc_com_m_receipt.receipt_no ) as c_count   

,sc_com_m_receipt.receipt_date   as receipt_date
,sc_com_m_branch.branch_id   as branch_id
,sc_com_m_branch.branch_name as branch_name

,sc_com_m_receipt_item.item_type_id as item_type_id
, decode(  sc_com_m_ucf_receipt_item_type.group_item , 'LON' , FPB_GET_LOAN_TYPE_DESC( FPB_GET_LOAN_TYPE_REF(  sc_com_m_receipt_item.loan_type )) , sc_com_m_ucf_receipt_item_type.item_type_name )  as loan_type_des


FROM sc_com_m_receipt   
,sc_com_m_receipt_item   
,sc_com_m_ucf_money_type   
,sc_com_m_branch  
,sc_com_m_ucf_receipt_item_type
,security_users

,sc_lon_m_contract
,sc_lon_m_rule


WHERE 1 = 2
GROUP BY  sc_com_m_ucf_receipt_item_type.group_item
,decode(  sc_com_m_ucf_receipt_item_type.group_item , 'LON' , FPB_GET_LOAN_TYPE_DESC( FPB_GET_LOAN_TYPE_REF(  sc_com_m_receipt_item.loan_type )) , sc_com_m_ucf_receipt_item_type.item_type_name )  
,sc_com_m_receipt.receipt_date   
,sc_com_m_branch.branch_id   
,sc_com_m_branch.branch_name   
,sc_com_m_receipt_item.item_type_id
,sc_com_m_ucf_receipt_item_type.item_type_name

</value>

  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>select sum(tab.row_memno)over( partition by (receipt_date) order by tab.receipt_date ,tab.branch_id ,tab.sort_order ,tab.money_type_id ,tab.entry_id , tab.receipt_no ,tab.sort_group_item ,tab.loan_type) as rowno,  tab.*
    from ( SELECT decode(lag(sc_com_m_receipt.receipt_no,1,null)over(  partition by (sc_com_m_receipt.receipt_date)  order by sc_com_m_receipt.receipt_date ,sc_com_m_branch.branch_id ,sc_com_m_ucf_money_type.sort_order
    ,sc_com_m_receipt.money_type_id ,sc_com_m_receipt.entry_id , sc_com_m_receipt.receipt_no  ,( case group_item  when 'SHR' then 1 when 'LON'  then  5 else  99 end ) ,
    decode(  sc_com_m_ucf_receipt_item_type.group_item , 'LON' ,  FPB_GET_LOAN_TYPE_REF(  sc_com_m_receipt_item.loan_type ) , sc_com_m_receipt_item.loan_type ) ) ,sc_com_m_receipt.receipt_no,0,1) as row_memno
    ,sc_com_m_receipt.receipt_date  as receipt_date
    ,sc_com_m_receipt.receipt_no  as receipt_no
    ,sc_mem_m_membership_registered.membership_no    as membership_no
    ,PKA_COM_FUNCTION.fp_get_member_name( sc_mem_m_membership_registered.membership_no ) as membername
    ,sc_com_m_receipt.receipt_status  as receipt_status
    ,( case group_item  when 'SHR' then 1 when 'LON'  then  5 else  99 end ) as sort_group_item
    ,sc_com_m_ucf_receipt_item_type.group_item  as group_item

    ,case
    when  sc_com_m_ucf_receipt_item_type.group_item = 'LON' then
    sc_com_m_receipt_item.description||
    ( select ' (*)' from sc_lon_m_loan_card
      where loan_contract_no = trim( sc_com_m_receipt_item.description )
      and loan_code &lt;&gt; '0' )
    when  sc_com_m_ucf_receipt_item_type.group_item = 'ISP' then
    sc_com_m_receipt_item.description
    else
    sc_com_m_receipt_item.description
    end 	as 		description

    ,sc_com_m_receipt.entry_id as entry_id

    ,sc_com_m_ucf_money_type.sort_order as sort_order
    ,sc_com_m_receipt.money_type_id as money_type_id
    ,sc_com_m_ucf_money_type.money_type_name  as money_type_name

    ,sc_com_m_branch.branch_id  as branch_id
    ,sc_com_m_branch.branch_name  as branch_name

    ,decode( sc_com_m_receipt.receipt_status , '0' , sc_com_m_receipt_item.principal_amount , 0  ) as principal_amount
    ,decode( sc_com_m_receipt.receipt_status , '0' , sc_com_m_receipt_item.interest_amount , 0  ) as interest_amount
    ,decode( sc_com_m_receipt.receipt_status , '0' , sc_com_m_receipt_item.item_amount , 0  ) as item_amount
    ,sc_com_m_receipt.ppm_status as ppm_status
    ,sc_com_m_receipt.keep_monthly as keep_monthly
    , decode(  sc_com_m_ucf_receipt_item_type.group_item , 'LON' ,  FPB_GET_LOAN_TYPE_REF(  sc_com_m_receipt_item.loan_type ) , sc_com_m_receipt_item.loan_type )  as loan_type
    ,(  	select sum( item_amount )
    from	sc_com_m_receipt_item
    where	receipt_no = sc_com_m_receipt.receipt_no ) as sum_rec
    ,sc_com_m_receipt_item.balance
    ,sc_com_m_receipt.cancel_date
    ,to_tdate(sc_com_m_receipt.cancel_date) as tdate_cancel_date
    ,sc_com_m_receipt.cancel_id
    ,nvl(sc_com_m_receipt.money_trans_return,0) as money_trans_return

    ,	sc_mem_m_ucf_member_group.member_group_no
    ,	sc_mem_m_ucf_member_group.member_group_name

    FROM sc_mem_m_membership_registered,
    sc_mem_m_ucf_member_group,
    sc_com_m_receipt,
    sc_com_m_receipt_item,
    sc_com_m_ucf_money_type,
    sc_com_m_branch  ,
    sc_com_m_ucf_receipt_item_type
    ,si_security_user
    WHERE 1=2
    /*WHERE*/
    )tab

  </value>

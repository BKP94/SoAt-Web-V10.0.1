  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT  SUM(tabmain."ลำดับ")over(order by tabmain."วันที่โอน" ,tabmain."ทะเบียนสมาชิก") AS "ลำดับที่" , 
        (case when "ลำดับ" = 1   then "วันที่โอน"
        else null
        end )as "วันที่โอนหนี้",
    
        tabmain.*
from(

      select (CASE
          WHEN "ทะเบียนสมาชิก" = lag("ทะเบียนสมาชิก")over(partition BY "วันที่โอน" order by "วันที่โอน" ,"ทะเบียนสมาชิก")
          THEN 0
          ELSE 1
          END) AS "ลำดับ" ,
      
          
          tabcal.* 
      from  (
              SELECT 
                      ----ส่วนสมาชิก----
                    sc_lon_m_trans_loan_coll_head.membership_no as "ทะเบียนสมาชิก",
                     pka_com_function.fp_get_member_name(sc_lon_m_trans_loan_coll_head.membership_no) AS "ชื่อสมาชิก",
                    sc_lon_m_trans_loan_coll_head.loan_contract_no as "เลขสัญญา",
                          sc_lon_m_trans_loan_coll_head.transfer_date  as "วันที่โอน",
                          
                    ----ส่วนผู้ค้ำ---
                    sc_lon_m_trans_loan_coll_det.collateral_no as "ทะเบียนคนค้ำ",
                    (select  member_group_no from  sc_mem_m_membership_registered where sc_mem_m_membership_registered.membership_no = sc_lon_m_trans_loan_coll_det.collateral_no ) as "หน่วยคนค้ำ",
                    pka_com_function.fp_get_member_name(sc_lon_m_trans_loan_coll_det.collateral_no)  AS "ชื่อคนค้ำ",
                    
                    ---ส่วนสัญญา---
                    sc_lon_m_trans_loan_coll_det.new_contract_no as "เลขสัญญาใหม่",
                    sc_lon_m_trans_loan_coll_det.loan_transfer_amount  as "เงินต้นโอน",
                    sc_lon_m_trans_loan_coll_det.int_arrear as "ดอกเบี้ยโอน" ,
                    sc_lon_m_trans_loan_coll_det.fee_amount as "ค่าธรรมเนียม" ,
                    sc_lon_m_trans_loan_coll_det.loan_transfer_amount + sc_lon_m_trans_loan_coll_det.int_arrear + sc_lon_m_trans_loan_coll_det.fee_amount as "รวมโอน",
                    sc_lon_m_trans_loan_coll_det.period_payment as "ชำระต่องวด", 
                    sc_lon_m_trans_loan_coll_det.start_keep_date as "วันที่เริ่มเเก็บ"
                    
              --      sc_lon_m_trans_loan_coll_det.transfer_doc_no as "เลขที่โอน",
              --      sc_lon_m_trans_loan_coll_det.drop_loan_status as "สถานะการงด",
              --      sc_lon_m_trans_loan_coll_det.loan_type as "ประเภทเงินกู้",
              --      sc_lon_m_trans_loan_coll_det.int_arrear as "ดอกเบี้ยโอน" ,
              --      sc_lon_m_trans_loan_coll_det.period_payment as "ชำระต่องวด",    
              --      sc_lon_m_trans_loan_coll_det.interest_rate as "เรทดอกเบี้ย"
                  
                  FROM sc_lon_m_trans_loan_coll_det ,
                  sc_lon_m_trans_loan_coll_head
                  WHERE (sc_lon_m_trans_loan_coll_det.transfer_doc_no = sc_lon_m_trans_loan_coll_head.transfer_doc_no)
                  AND (sc_lon_m_trans_loan_coll_head.transfer_status = '0')
                  
              /*WHERE*/
                  ORDER BY sc_lon_m_trans_loan_coll_head.transfer_date,
                  sc_lon_m_trans_loan_coll_head.membership_no ,
                  sc_lon_m_trans_loan_coll_head.loan_contract_no
    
      )tabcal
)tabmain</value>

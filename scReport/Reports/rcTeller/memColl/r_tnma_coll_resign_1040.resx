  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>select sc_lon_m_loan_card.membership_no
    ,pka_com_function.fp_get_member_name(sc_lon_m_loan_card.membership_no) as mem_name
    ,pka_com_function.fp_get_member_group(sc_lon_m_loan_card.membership_no) as member_group_no
    ,pka_com_function.fp_get_group_name(pka_com_function.fp_get_member_group(sc_lon_m_loan_card.membership_no)) as member_group_name
    ,sc_lon_m_loan_card.loan_contract_no
    ,sc_lon_m_loan_card.principal_balance
    ,sc_lon_m_contract_coll.ref_own_no
    ,pka_com_function.fp_get_member_sharestock(sc_lon_m_loan_card.membership_no) as sharestock
    ,pka_com_function.fp_get_member_name(sc_lon_m_contract_coll.ref_own_no) as coll_name
    ,sc_mem_m_membership_registered.member_group_no as coll_group_no
    ,pka_com_function.fp_get_group_name(sc_mem_m_membership_registered.member_group_no) as coll_group_name
    ,pka_com_function.fp_get_thaidate(sc_mem_m_membership_registered.resignation_approve_date) as resignation_approve_date_thai

,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no,'1',6)as address_no
    ,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no,'1',7)as mooban
    ,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no,'1',8)as moo
    ,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no,'1',9)as road
    ,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no,'1',10)as soi
    ,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no,'1',11)as tambol
    ,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no,'1',12)as district
    ,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no,'1',13)as province
    ,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no,'1',14)as postcode
    ,pka_com_function.fp_get_member_address_letter(sc_lon_m_contract_coll.ref_own_no,'1',15)as telephone
,sc_lon_m_loan_card.contact_status
from sc_lon_m_contract_coll
,sc_lon_m_loan_card
,sc_mem_m_membership_registered

where sc_lon_m_contract_coll.loan_contract_no = sc_lon_m_loan_card.loan_contract_no
and sc_lon_m_contract_coll.ref_own_no = sc_mem_m_membership_registered.membership_no
and sc_lon_m_contract_coll.collateral_type_code = '01'
and sc_mem_m_membership_registered.member_status_code = '3'
and sc_lon_m_loan_card.principal_balance &gt; 0
/*WHERE*/
--and sc_mem_m_membership_registered.resignation_approve_date &lt;= to_date('06/09/2025','dd/mm/yyyy')
--and sc_mem_m_membership_registered.resign_code = '1040'

order by sc_mem_m_membership_registered.resignation_approve_date
,sc_lon_m_loan_card.membership_no</value>

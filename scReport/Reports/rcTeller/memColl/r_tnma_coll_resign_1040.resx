  <data name="c_address.Expression" xml:space="preserve">
    <value>Iif(IsNull([ADDRESS_NO]),''  ,'เลขที่ ' + [ADDRESS_NO] ) +
Iif(IsNull([MOO]),''  ,' หมู่ที่ ' + [MOO] ) +
Iif(IsNull([SOI]),''  ,' ซอย ' + [SOI] ) +
Iif(IsNull([MOOBAN]),''  ,' หมู่บ้าน ' + [MOOBAN] ) +
Iif(IsNull([ROAD]),''  ,' ถนน ' + [ROAD] )</value>

  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>select  sc_mem_m_membership_registered.membership_no ,
pka_com_function.fp_get_member_name(sc_mem_m_membership_registered.membership_no)  as member_name,
sc_mem_m_ucf_member_type.mem_type_desc,
sc_mem_m_membership_registered.other_code as grade,
sc_mem_m_ucf_member_group.member_group_no,
sc_mem_m_ucf_member_group.member_group_name,
sc_mem_m_membership_registered.date_of_birth ,
sc_mem_m_membership_registered.sex ,
substr(pka_lon_reqsrv.fp_calc_agetext_m_live(sc_mem_m_membership_registered.membership_no),1,30) as age_life_text ,
sc_mem_m_ucf_marriage_status.marriage_status,
pka_com_function.fp_form_idcard (sc_mem_m_membership_registered.id_card)as id_card,
substr(pka_lon_reqsrv.fp_calc_agetext(pka_lon_reqsrv.fp_calc_install_m_age(sc_mem_m_membership_registered.membership_no)),1,30) as age_mem_text,
sc_mem_m_membership_registered.approve_date ,
nvl((select description
    from sc_mem_m_ucf_shareloan_status
    where shareloan_code  = sc_mem_m_membership_registered.shareloan_code
    ),'[ไม่ระบุ]') as shareloan_code,
( select salary_amount 
from sc_mem_m_member_work_info 
where membership_no = sc_mem_m_membership_registered.membership_no
) as salary_amount,

(select position_long 
from sc_mem_m_member_work_info 
where sc_mem_m_member_work_info.membership_no = sc_mem_m_membership_registered.membership_no 
) as position_long,

decode( sc_mem_m_membership_registered.marriage_status 
                  , '1' , (   select sc_mem_m_ucf_prename.prename || sc_mem_m_member_spouse_info.spouse_name || '  ' || sc_mem_m_member_spouse_info.spouse_surname
      from sc_mem_m_member_spouse_info
      ,sc_mem_m_ucf_prename
      where sc_mem_m_member_spouse_info.prename_code = sc_mem_m_ucf_prename.prename_code
      and sc_mem_m_member_spouse_info.membership_no = sc_mem_m_membership_registered.membership_no
       ) 
,' ' ) as spouse_name,

sc_mem_m_share_mem.share_amount,
( case sc_mem_m_share_mem.drop_status when '0' then 'ปกติ' when '1' then 'งดส่ง' when '2' then 'เปลี่ยนแปลงชำระ' end ) as drop_status,
sc_mem_m_share_mem.share_stock,
sc_mem_m_member_bank_accno.bank_id,
pka_com_function.fp_form( sc_mem_m_member_bank_accno.bank_acc_no , 'XXX-X-XXXXX-X' ) as bank_acc_no,
--fpa_mobile_get_active(sc_mem_m_membership_registered.telephone) as telephone,
sc_mem_m_member_address.telephone

from sc_mem_m_membership_registered,
sc_mem_m_ucf_member_group,
sc_mem_m_ucf_member_type,
sc_mem_m_ucf_marriage_status,
sc_mem_m_member_work_info,
sc_mem_m_share_mem,
sc_mem_m_member_bank_accno,
sc_mem_m_member_address
where 1 = 2
/*WHERE*/
--and sc_mem_m_membership_registered.membership_no = '004671'</value>

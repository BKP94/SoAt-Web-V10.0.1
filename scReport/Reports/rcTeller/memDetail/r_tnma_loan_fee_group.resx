  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>select sc_mem_m_ucf_member_group.member_group_control
,pka_com_function.fp_get_group_name(sc_mem_m_ucf_member_group.member_group_control) as member_group_control_name
,sc_lon_m_contract.loan_type
,(select sc_lon_m_rule.loan_type_description from sc_lon_m_rule where loan_type = sc_lon_m_contract.loan_type) as loan_type_description
,sum(sc_lon_m_req_fee.amount) as amount
,sc_lon_m_req_fee.fee_type
,(select fee_name from sc_lon_m_ucf_fee where fee_type = sc_lon_m_req_fee.fee_type) as fee_name
--,sum((select sum(interest_first) from sc_lon_m_loan_request where loan_requestment_no = sc_lon_m_contract.loan_requestment_no)) as interest_first
from sc_lon_m_req_fee
,sc_lon_m_contract
,sc_mem_m_membership_registered
,sc_mem_m_ucf_member_group
where sc_lon_m_req_fee.loan_requestment_no = sc_lon_m_contract.loan_requestment_no
and sc_lon_m_contract.membership_no = sc_mem_m_membership_registered.membership_no
and sc_mem_m_membership_registered.member_group_no = sc_mem_m_ucf_member_group.member_group_no


/*---------------------[ วันที่ ]------------------------*/
--and sc_lon_m_contract.begining_of_contract between to_date('2025-8-15 0:0:0','yyyy-mm-dd hh24:mi:ss') and to_date('2025-8-15 0:0:0','yyyy-mm-dd hh24:mi:ss')

/*---------------------[ ประเภทเงินกู้ ]------------------------*/
--and sc_lon_m_contract.loan_type = 'ว'
/*WHERE*/
--and sc_mem_m_membership_registered.membership_no = '010256'

group by sc_mem_m_ucf_member_group.member_group_control
,sc_lon_m_contract.loan_type
,sc_lon_m_req_fee.fee_type

order by sc_mem_m_ucf_member_group.member_group_control
,sc_lon_m_req_fee.fee_type asc</value>

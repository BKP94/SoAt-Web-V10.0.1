  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>    SELECT  pka_mem_newmem.fp_member_name(sc_mem_m_application_form.application_form_no) as memname,
    sc_mem_m_app_work_info.salary_amount,
    sc_mem_m_app_work_info.academic_salary,
    sc_mem_m_app_work_info.group_position,
    sc_mem_m_app_work_info.working_date,
    sc_mem_m_app_work_info.salary_id,
    sc_mem_m_app_share.share_monthly,
    sc_mem_m_ucf_member_group.member_group_no,
    sc_mem_m_ucf_member_group.member_group_name,
    sc_mem_m_ucf_member_group.member_group_control,
    sc_mem_m_ucf_member_group.control_id,
    sc_mem_m_application_form.application_form_no,
    sc_mem_m_application_form.apply_date,
    PKA_COM_FUNCTION.fp_get_thaidate( sc_mem_m_application_form.apply_date , 'DD/MM/YYYY') as apply_date_tdate,
    TRUNC( pka_lon_reqsrv.fp_calc_install_m_live(sc_mem_m_application_form.date_of_birth,sc_mem_m_application_form.apply_date)/12 ) as age,
    sc_mem_m_application_form.sex,
    sc_mem_m_application_form.approve_status,
    sc_mem_m_application_form.hum_id,
    sc_mem_m_ucf_application_type.appl_type_name,
    sc_mem_m_application_form.appl_type_code,
    sc_mem_m_ucf_application_type.application_fee,
    sc_mem_m_ucf_member_type.mem_type_code,
    sc_mem_m_ucf_member_type.mem_type_desc


    ,sc_mem_m_membership_registered.membership_no
    ,(select sc_mem_m_ucf_group_position.description
    from sc_mem_m_ucf_group_position
    where sc_mem_m_app_work_info.group_position = sc_mem_m_ucf_group_position.group_position ) as group_pos_name
 --,(select sum(insurance_approve) 
--from sc_mem_m_app_member_insurance
--where sc_mem_m_application_form.application_form_no  = sc_mem_m_app_member_insurance.application_form_no  ) insurance_approve
    , NVL(sc_mem_m_app_work_info.position_long,'ไม่ระบุ') AS position_name
    , sc_mem_m_ucf_salary_level.level_name
    , sc_mem_m_app_work_info.level_code
    , sc_mem_m_application_form.date_of_birth
    , sc_mem_m_application_form.entry_id
,  (select max(trim(sc_mem_m_membership_registered.id_card))
  from sc_mem_m_membership_registered
  where trim(sc_mem_m_membership_registered.id_card)  in (select (sc_mem_m_application_form.hum_id)
                                                          from sc_mem_m_application_form
                                                          where sc_mem_m_application_form.approve_status = '2')) as hum_id_card
    ,sc_mem_m_membership_registered.id_card
    
    ,(select  member_group_major
      from    sc_mem_m_ucf_groupmajor
      where   sc_mem_m_ucf_groupmajor.member_group_major = sc_mem_m_ucf_member_group.member_group_major
      ) as member_group_major
      
      ,(select  group_major_name
      from    sc_mem_m_ucf_groupmajor
      where   sc_mem_m_ucf_groupmajor.member_group_major = sc_mem_m_ucf_member_group.member_group_major
      ) as group_major_name
    FROM sc_mem_m_application_form,
    sc_mem_m_app_work_info,
    sc_mem_m_ucf_prename,
    sc_mem_m_app_share,
    sc_mem_m_ucf_member_group,
    sc_mem_m_ucf_application_type,
    sc_mem_m_ucf_member_type  ,
    sc_mem_m_membership_registered ,
    sc_mem_m_ucf_salary_level 
    WHERE 1=2
    /*WHERE*/</value>

  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT sc_mem_m_membership_registered.membership_no,
    sc_mem_m_resign_requestment.entry_id,
    pka_com_function.fp_get_user_name(sc_mem_m_resign_requestment.entry_id) as user_name,
    PKA_COM_FUNCTION.fp_get_thaidate( sc_mem_m_resign_requestment.resign_date ) as resign_date ,
    PKA_COM_FUNCTION.fp_get_member_name( sc_mem_m_resign_requestment.membership_no ) as membername,

    sc_mem_m_ucf_resign_cause.resign_cause_name,

    sc_mem_m_ucf_member_group.member_group_no,
    sc_mem_m_ucf_member_group.member_group_name,
    sc_mem_m_ucf_member_group.member_group_control ,
    sc_mem_m_ucf_member_group.control_id,

    sc_com_m_branch.branch_id,
    sc_com_m_branch.branch_name,
    sc_cnt_m_coop.manager_name

   -- ,sc_mem_m_membership_registered.resignation_approve_date

    ,sc_mem_m_ucf_member_type.mem_type_code
    ,sc_mem_m_ucf_member_type.mem_type_desc

    , nvl( (  SELECT   sum( sc_com_m_receipt.recept_amount )
    FROM sc_com_m_receipt
    WHERE 	sc_com_m_receipt.membership_no = sc_mem_m_membership_registered.membership_no
    AND   	sc_com_m_receipt.money_type_id = 'TNL'
    AND   	sc_com_m_receipt.receipt_status = '0'  ) , 0 )  as tnl_amount

    , nvl( (  SELECT   sum( sc_mem_m_share_withdraw_det.share_withdraw )
    FROM sc_mem_m_share_withdraw_head,
    sc_mem_m_share_withdraw_det
    WHERE 	sc_mem_m_share_withdraw_head.withdraw_doc_no = sc_mem_m_share_withdraw_det.withdraw_doc_no
    AND 		sc_mem_m_share_withdraw_head.membership_no = sc_mem_m_membership_registered.membership_no
    AND   		sc_mem_m_share_withdraw_head.withdraw_status = '0'  ) , 0 )  as wd_amount

   , nvl( (  SELECT   sum( sc_mem_m_share_withdraw_det.share_stock - sc_mem_m_share_withdraw_det.share_withdraw )
    FROM sc_mem_m_share_withdraw_head,
    sc_mem_m_share_withdraw_det
    WHERE 	sc_mem_m_share_withdraw_head.withdraw_doc_no = sc_mem_m_share_withdraw_det.withdraw_doc_no
    AND 		sc_mem_m_share_withdraw_head.membership_no = sc_mem_m_membership_registered.membership_no
    AND   		sc_mem_m_share_withdraw_head.withdraw_status = '0'  ) , 0 )  as share_balance
   
    , nvl (( select sum(sc_com_m_receipt_item.balance )
        from sc_com_m_receipt ,sc_com_m_receipt_item 
        where sc_com_m_receipt.receipt_no = sc_com_m_receipt_item.receipt_no
        and   sc_com_m_receipt.membership_no = sc_mem_m_membership_registered.membership_no
        and   sc_com_m_receipt.money_type_id = 'TNL' 
        and   	sc_com_m_receipt.receipt_status = '0' ),0 ) as loan_balance

    FROM  sc_mem_m_resign_requestment,
    sc_mem_m_resign_share,
    sc_mem_m_ucf_resign_cause,
    sc_mem_m_ucf_member_group,
    sc_cnt_m_coop,
    sc_com_m_branch
    ,sc_mem_m_membership_registered

    ,sc_mem_m_ucf_member_type
    WHERE  1 = 2
    --and sc_mem_m_membership_registered.resignation_approve_date between to_date('!op_date_1!') and to_date('!op_date_2!')
    /*WHERE*/
    --and sc_mem_m_resign_requestment.membership_no = '002258'</value>

  <data name="balancejing.Expression" xml:space="preserve">
    <value>[LOAN_APPROVE_AMOUNT] 
- Iif(IsNull([TOTAL_OLD_LOAN]),0  ,[TOTAL_OLD_LOAN] ) 
- Iif(IsNull([TOTAL_OLDINT]),0  ,[TOTAL_OLDINT] )
- Iif(IsNull([BUY_SHARE]),0  ,[BUY_SHARE] )
- Iif(IsNull([FEE_AMOUNT]),0  ,[FEE_AMOUNT] )</value>

  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT SC_MEM_M_UCF_PRENAME.prename || sc_mem_m_membership_registered.member_name || '  ' || sc_mem_m_membership_registered.member_surname AS c_name
	,SC_LON_M_CONTRACT.MEMBERSHIP_NO
	,SC_LON_M_CONTRACT.loan_contract_no
	,SC_LON_M_CONTRACT.real_recieve
	,SC_LON_M_CONTRACT.loan_approve_amount
	,SC_LON_M_CONTRACT.share_coll_amount
	,SC_LON_M_CONTRACT.loan_installment_amount
	,SC_LON_M_CONTRACT.period_payment_amount
	,SC_MEM_M_UCF_MEMBER_GROUP_a.member_group_no
	,SC_MEM_M_UCF_MEMBER_GROUP_a.member_group_name
	,SC_LON_M_LOAN_REQUEST.total_old_loan
	,SC_LON_M_LOAN_REQUEST.total_oldint
	,SC_LON_M_LOAN_REQUEST.buy_share
	,SC_LON_M_LOAN_REQUEST.total_share_value
	,SC_LON_M_LOAN_REQUEST.fee_amount
	,SC_MEM_M_UCF_MEMBER_GROUP_b.member_group_name
	,sc_cnt_m_coop.coop_name
	,SC_MEM_M_UCF_MEMBER_GROUP_a.member_group_control
	,SC_LON_M_RULE.loan_type_description
      ,SC_LON_M_LOAN_REQUEST.remark
	--,SC_LON_M_LOAN_REQUEST.bank_code
	--,SC_LON_M_LOAN_REQUEST.bank_acc_no
    ,sc_acc_m_ucf_bank.bank_name
    , ( select sum(sc_com_m_receipt_item.interest_amount)
    from sc_com_m_receipt
    ,sc_com_m_receipt_item
    where sc_com_m_receipt.receipt_no = sc_com_m_receipt_item.receipt_no
    and sc_com_m_receipt.loan_contract_no = sc_lon_m_contract.loan_contract_no
    and sc_com_m_receipt.receipt_status = '0'
    and sc_com_m_receipt_item.item_type_id = 'PL'
    ) as interest_amount_new
 ,(
    SELECT 
        DECODE(sc_lon_m_loan_request_mpaid.bank_code, 
               '006', 'กรุงไทย', 
               '025', 'กรุงศรี', 
		   '000', 'บัญชีสหกรณ์ฯ',
               '') 
    FROM sc_lon_m_loan_request_mpaid
    WHERE sc_lon_m_loan_request_mpaid.loan_requestment_no = sc_lon_m_loan_request.loan_requestment_no
) AS bank_code

 
,(select sc_lon_m_loan_request_mpaid.bank_acc_no
   from sc_lon_m_loan_request_mpaid
    where sc_lon_m_loan_request_mpaid.loan_requestment_no = sc_lon_m_loan_request.loan_requestment_no) as bank_acc_no
,pka_com_function.fp_get_thaidate('!approve_date_1!','dd/mm/yyyy') as approve_date1
,pka_com_function.fp_get_thaidate('!approve_date_2!','dd/mm/yyyy') as approve_date2
,pka_com_function.fp_get_thaidate(sc_lon_m_contract.approve_date,'dd/mm/yyyy') as approve_date
FROM SC_LON_M_CONTRACT
	,sc_mem_m_membership_registered
	,SC_MEM_M_UCF_MEMBER_GROUP SC_MEM_M_UCF_MEMBER_GROUP_a
	,SC_MEM_M_UCF_PRENAME
	,SC_LON_M_LOAN_REQUEST
	,SC_MEM_M_UCF_MEMBER_GROUP SC_MEM_M_UCF_MEMBER_GROUP_b
	,sc_cnt_m_coop
	,SC_LON_M_RULE
   ,sc_acc_m_ucf_bank
WHERE (sc_mem_m_membership_registered.member_group_no = SC_MEM_M_UCF_MEMBER_GROUP_a.member_group_no)
    and sc_acc_m_ucf_bank.bank_id = SC_LON_M_LOAN_REQUEST.bank_code
	AND (sc_mem_m_membership_registered.prename_code = SC_MEM_M_UCF_PRENAME.prename_code)
	AND (SC_LON_M_CONTRACT.loan_requestment_no = SC_LON_M_LOAN_REQUEST.loan_requestment_no)
	AND (SC_LON_M_CONTRACT.loan_type = SC_LON_M_LOAN_REQUEST.loan_type)
	AND (SC_LON_M_CONTRACT.MEMBERSHIP_NO = sc_mem_m_membership_registered.membership_no)
	AND (SC_MEM_M_UCF_MEMBER_GROUP_a.member_group_control = SC_MEM_M_UCF_MEMBER_GROUP_b.member_group_no)
	AND (SC_LON_M_CONTRACT.loan_type = SC_LON_M_RULE.loan_type)
	AND (SC_LON_M_CONTRACT.rec_rep_status = '1')
    /*WHERE*/
 -- and ( SC_LON_M_CONTRACT.loan_contract_no between :as_bcon and :as_econ ) </value>
  </data>

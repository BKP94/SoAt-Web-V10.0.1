  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>   SELECT 	sc_mem_m_membership_registered.membership_no,
    PKA_COM_FUNCTION.fp_get_member_name( sc_mem_m_membership_registered.membership_no ) as membername  ,
    sc_mem_m_membership_registered.mem_type ,
    sc_mem_m_ucf_member_group.member_group_no,
    sc_mem_m_ucf_member_group.member_group_name,
    sc_mem_m_ucf_member_group.member_group_control,
    sc_mem_m_ucf_member_group.control_id
    ,sc_mem_m_share_mem.share_stock
    ,pka_lon_reqsrv.fp_calc_agetext_m_age(sc_mem_m_membership_registered.membership_no) as agetext_member
    ,pka_lon_reqsrv.fp_calc_agetext_m_live(sc_mem_m_membership_registered.membership_no) as agetext_live
    ,pka_com_function.fp_get_thaidate( sc_mem_m_membership_registered.approve_date ,'DD MONTH YYYY') as t_approve_date
    ,pka_com_function.fp_get_thaidate(sysdate , 'SD MONTH YYYY') as sysdate_tdate
    ,sc_mem_m_membership_registered.date_of_birth
    ,sc_mem_m_share_mem.period_recrieve
    , sc_mem_m_share_mem.share_amount
    ,sc_mem_m_share_mem.drop_status
, 	( select sc_mem_m_capital_stock_detail.dividend
		from sc_mem_m_capital_stock_detail
		where sc_mem_m_membership_registered.membership_no = sc_mem_m_capital_stock_detail.membership_no
		and sc_mem_m_capital_stock_detail.account_year = (select max(stock_detail.account_year)
		from sc_mem_m_capital_stock_detail stock_detail
		where sc_mem_m_membership_registered.membership_no = stock_detail.membership_no )) as dividend
	,	( select sc_mem_m_capital_stock_detail.average_return
		from sc_mem_m_capital_stock_detail
		where sc_mem_m_membership_registered.membership_no = sc_mem_m_capital_stock_detail.membership_no
		and sc_mem_m_capital_stock_detail.account_year = (select max(stock_detail.account_year)
		from sc_mem_m_capital_stock_detail stock_detail
		where sc_mem_m_membership_registered.membership_no = stock_detail.membership_no )) as average_return
    , PKA_COM_FUNCTION.fp_get_loan_balance_by_mem(sc_mem_m_membership_registered.membership_no) as loan_balance
    

    ,   sc_mem_m_membership_registered.id_card 
     , sc_mem_m_member_work_info.salary_amount
   , PKA_COM_FUNCTION.fp_get_member_address(sc_mem_m_membership_registered.membership_no , 0) as home
    FROM 		sc_mem_m_membership_registered,
    sc_mem_m_ucf_member_group  ,
    sc_mem_m_share_mem ,
    sc_mem_m_member_work_info
    WHERE 	( sc_mem_m_membership_registered.member_group_no 		= 	sc_mem_m_ucf_member_group.member_group_no ) and
    sc_mem_m_share_mem.membership_no = sc_mem_m_membership_registered.membership_no
    and sc_mem_m_member_work_info.membership_no = sc_mem_m_membership_registered.membership_no
    /*WHERE*/
  </value>

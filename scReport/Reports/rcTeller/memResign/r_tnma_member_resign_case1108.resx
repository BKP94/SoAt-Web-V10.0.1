  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>SELECT sc_mem_m_resign_requestment.MEMBERSHIP_NO
	,sc_mem_m_resign_requestment.RESIGN_DATE
	,sc_mem_m_ucf_resign_cause.resign_cause_code
    ,sc_mem_m_ucf_resign_cause.resign_cause_name
	,pka_com_function.fp_get_member_name(sc_mem_m_resign_requestment.MEMBERSHIP_NO) as memname
    ,pka_lon_reqsrv.fp_calc_agetext(sc_mem_m_membership_registered.date_of_birth) as agetext
	,SC_MEM_M_MEMBERSHIP_REGISTERED.MEMBER_GROUP_NO
	,SC_MEM_M_UCF_MEMBER_GROUP.MEMBER_GROUP_NAME
	,sc_mem_m_resign_requestment.REMARK
	,sc_mem_m_resign_share.SHR_VALUE
	--,sc_mem_m_resign_requestment.DIFFERENT_SHARELOAN
    ,sc_mem_m_ucf_member_group.member_group_control
    ,pka_com_function.fp_get_group_name(sc_mem_m_ucf_member_group.member_group_control) as group_control_name
    ,sc_mem_m_resign_requestment.RESIGN_DOC_NO
    ,sc_mem_m_resign_requestment.RESIGN_CODE
    ,SC_MEM_M_MEMBERSHIP_REGISTERED.RESIGNATION_APPROVE_DATE
    ,SC_MEM_M_UCF_MEMBER_GROUP.KEEPING_GROUP
    ,SC_MEM_M_MEMBERSHIP_REGISTERED.mem_type
    ,SC_MEM_M_MEMBERSHIP_REGISTERED.sex
   

    ,(select sc_mem_m_member_member_refer.membership_no_ref
      from sc_mem_m_member_member_refer
      where SC_MEM_M_MEMBERSHIP_REGISTERED.membership_no = sc_mem_m_member_member_refer.membership_no 
      and   sc_mem_m_member_member_refer.membership_no_ref like '02%') as membership_no_ref
      


    FROM sc_mem_m_resign_requestment 
    ,sc_mem_m_ucf_resign_cause
    ,SC_MEM_M_MEMBERSHIP_REGISTERED
    ,SC_MEM_M_UCF_PRENAME
    ,SC_MEM_M_UCF_MEMBER_GROUP
    ,sc_mem_m_resign_share
    WHERE (sc_mem_m_resign_requestment.RESIGN_CODE = sc_mem_m_ucf_resign_cause.resign_cause_code)
    AND (sc_mem_m_resign_requestment.MEMBERSHIP_NO = SC_MEM_M_MEMBERSHIP_REGISTERED.MEMBERSHIP_NO)
    AND (SC_MEM_M_MEMBERSHIP_REGISTERED.PRENAME_CODE = SC_MEM_M_UCF_PRENAME.PRENAME_CODE)
    AND (SC_MEM_M_MEMBERSHIP_REGISTERED.MEMBER_GROUP_NO = SC_MEM_M_UCF_MEMBER_GROUP.MEMBER_GROUP_NO)
    AND (sc_mem_m_resign_requestment.RESIGN_DOC_NO = sc_mem_m_resign_share.RESIGN_DOC_NO)
    AND (sc_mem_m_resign_requestment.approve_result &lt;&gt; '0')
and sc_mem_m_resign_requestment.cancel_status &lt;&gt; 1
and sc_mem_m_ucf_resign_cause.resign_cause_code = '1108'

/*---------------------[  วันที่บันทึก  ]------------------------*/
-- and sc_mem_m_membership_registered.resignation_approve_date between to_date('2025-10-1 0:0:0','yyyy-mm-dd hh24:mi:ss') and to_date('2025-10-1 0:0:0','yyyy-mm-dd hh24:mi:ss')

/*---------------------[  เหตุผล  ]------------------------*/
 
 order by sc_mem_m_ucf_member_group.member_group_control
 , sc_mem_m_resign_requestment.MEMBERSHIP_NO  
 asc</value>
  </data>

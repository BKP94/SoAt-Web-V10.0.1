  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>select sc_mem_m_ucf_member_group.member_group_no ,
    sc_mem_m_ucf_member_group.member_group_name,
    (select prename from sc_mem_m_ucf_prename where prename_code = sc_mem_m_membership_registered.prename_code)||sc_mem_m_membership_registered.member_name||' '||sc_mem_m_membership_registered.member_surname  as member_name,
    tm.*
from (
    select sc_mem_m_membership_registered.membership_no,
        nvl(sum(sc_mem_m_share_mem.share_stock),0) as share_stock,
        nvl(sum(decode(sc_lon_m_rule.loan_group_code,'01',sc_lon_m_loan_card.principal_balance,0)),0) as loan_01,
        nvl(sum(decode(sc_lon_m_rule.loan_group_code,'02',sc_lon_m_loan_card.principal_balance,0)),0) as loan_02,
        nvl(sum(decode(sc_lon_m_rule.loan_group_code,'03',sc_lon_m_loan_card.principal_balance,0)),0) as loan_03,
        nvl(sum(decode(sc_lon_m_rule.loan_group_code,'01',1,0)),0) as count_01,
        nvl(sum(decode(sc_lon_m_rule.loan_group_code,'02',1,0)),0) as count_02,
        nvl(sum(decode(sc_lon_m_rule.loan_group_code,'03',1,0)),0) as count_03
    from sc_mem_m_membership_registered,sc_mem_m_share_mem,sc_lon_m_loan_card,sc_lon_m_rule
    where sc_mem_m_membership_registered.membership_no = sc_mem_m_share_mem.membership_no
    and sc_mem_m_share_mem.share_stock &gt; 0
    and sc_mem_m_membership_registered.membership_no = sc_lon_m_loan_card.membership_no
    and sc_lon_m_loan_card.principal_balance &gt; 0
    and sc_lon_m_loan_card.loan_type = sc_lon_m_rule.loan_type
    group by sc_mem_m_membership_registered.membership_no
    union all
    select sc_mem_m_membership_registered.membership_no ,
        sc_mem_m_share_mem.share_stock,0,0,0,0,0,0
    from sc_mem_m_membership_registered , sc_mem_m_share_mem
    where sc_mem_m_membership_registered.membership_no = sc_mem_m_share_mem.membership_no
    and sc_mem_m_share_mem.share_stock &gt; 0
    and not exists(select null from sc_lon_m_loan_card where principal_balance &gt; 0 and membership_no = sc_mem_m_membership_registered.membership_no)
) tm ,sc_mem_m_membership_registered , sc_mem_m_ucf_member_group
where sc_mem_m_membership_registered.membership_no = tm.membership_no 
and sc_mem_m_membership_registered.member_group_no = sc_mem_m_ucf_member_group.member_group_no
/*WHERE*/
and 1 = 2
order by sc_mem_m_ucf_member_group.member_group_no,
    sc_mem_m_membership_registered.membership_no</value>

  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>select  sc_mem_m_membership_registered.member_group_no
,   sc_lon_m_loan_card.membership_no 
,  pka_com_function.fp_get_member_name (sc_lon_m_loan_card.membership_no ) as mem_name
,   sc_lon_m_loan_card.loan_type
,   sc_lon_m_loan_card.loan_contract_no 
,   sc_lon_m_loan_card_detail.loan_payment_date 
,   sc_lon_m_loan_card_detail.item_type_code
,   sc_lon_m_loan_card_detail.principal_balance
,  (TO_DATE('30/11/2025','DD/MM/YYYY')-TO_DATE(sc_lon_m_loan_card_detail.loan_payment_date,'DD/MM/YYYY')) as date_cal
,   pka_com_function.fp_get_thaidate(to_date('01/11/2025','DD/MM/YYYY'))as last_cal
,   pka_com_function.fp_get_thaidate(to_date('30/11/2025','DD/MM/YYYY'))as balance_date

,  (select  sc_lon_m_int_step_rate.loan_interest_rate
      from   sc_lon_m_int_step_rate  
  Where     sc_lon_m_int_step_rate.loan_type = sc_lon_m_rule.loan_type
  and  sc_lon_m_int_step_rate.effective_date =(Select   Max( rate.effective_date ) 
                from   sc_lon_m_int_step_rate  rate
                where   rate.effective_date  &lt;= sc_lon_m_loan_card_detail.loan_payment_date
                and     rate.loan_type = sc_lon_m_int_step_rate.loan_type   
                   )
  ) as loan_interest_rate

,        pka_lon_intsrv.fp_calint(sc_lon_m_loan_card.loan_contract_no, TO_DATE('30/11/2025','DD/MM/YYYY') , sc_lon_m_loan_card_detail.principal_balance , sc_lon_m_loan_card_detail.loan_payment_date ,  'PL' ) as int_calc

from sc_lon_m_loan_card
,  sc_lon_m_loan_card_detail
,  sc_lon_m_rule
,  sc_mem_m_membership_registered

where sc_lon_m_rule.loan_type = sc_lon_m_loan_card.loan_type
and  sc_lon_m_loan_card.loan_contract_no = sc_lon_m_loan_card_detail.loan_contract_no
and  sc_lon_m_loan_card.membership_no  = sc_mem_m_membership_registered.membership_no
and  sc_lon_m_loan_card.principal_balance  &gt; 0
and sc_lon_m_loan_card_detail.item_type_code = 'PM' 
and sc_lon_m_loan_card_detail.loan_payment_date between TO_DATE('01/11/2025','DD/MM/YYYY')  and TO_DATE('30/11/2025','DD/MM/YYYY')</value>

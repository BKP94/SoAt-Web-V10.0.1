  <data name="customSqlQuery1.Sql" xml:space="preserve">
    <value>select  sum(tab.row_memno)over(partition by tab.member_group_no order by tab.member_group_no , tab.contact_status , tab.membership_no , tab.loan_contract_no ) as rowno,  tab.*
from    ( SELECT    decode(lag(sc_lon_m_loan_card.membership_no,1,null)over( order by sc_mem_m_ucf_member_group.member_group_no , sc_lon_m_loan_card.contact_status , sc_lon_m_loan_card.membership_no , sc_lon_m_loan_card.loan_contract_no ) ,sc_lon_m_loan_card.membership_no ,0,1 ) as row_memno
,       sc_mem_m_ucf_member_group.member_group_no 
,       sc_mem_m_ucf_member_group.member_group_name 
,       sc_mem_m_ucf_member_group.member_group_control 
,       sc_mem_m_ucf_prename.prename  
,       sc_mem_m_membership_registered.member_name 
,       sc_mem_m_membership_registered.member_surname 
,       pka_com_function.fp_form( sc_lon_m_loan_card.loan_contract_no , 'XX-XXXXXXXXX' ) as loan_contract_no
,       sc_lon_m_loan_card.year_total_interest 
,       sc_lon_m_loan_card.interest_arrear_year 
,       sc_lon_m_loan_card.loan_type 
,       sc_lon_m_loan_card.membership_no 
,       sc_lon_m_loan_card.begin_balance 
,       sc_lon_m_loan_card.contact_status 
,       pka_com_function.fp_get_thaidate( sc_lon_m_loan_card.last_calcint_date , 'dd/mm/yyyy' ) as last_calcint_date

,       (select max( pka_com_function.fp_get_thaidate( loan_detail.loan_payment_date ,'dd/mm/yyyy' ) )
        from    sc_lon_m_loan_card_detail   loan_detail
        ,       sc_lon_m_loan_card loan_card
        where   ( loan_card.loan_contract_no = loan_detail.loan_contract_no )
        and     ( loan_card.loan_contract_no = sc_lon_m_loan_card.loan_contract_no )
        and     ( loan_detail.loan_payment_date &lt;= '!last_calcint_date_1!' ) 
        )  as  interest_to
    
,       '!last_calcint_date_1!'  as  loan_payment_date
,       pka_lon_intsrv.fp_calint(sc_lon_m_loan_card.loan_contract_no  , '!last_calcint_date_1!' ) as calcint  
,       nvl( sc_lon_m_loan_card.interest_arrear,0 ) as interest_arrear

,       (select nvl(max(interest_arrear_bal),0)
        from    sc_lon_m_loan_card_detail
        where   loan_contract_no = sc_lon_m_loan_card.loan_contract_no
        and     seq_no = (select max(seq_no)
                         from    sc_lon_m_loan_card_detail tab
                         where   loan_contract_no = sc_lon_m_loan_card_detail.loan_contract_no
                         and     loan_payment_date &lt;= '!last_calcint_date_1!' 
                         )
        ) as interest_arrear_bal
        
,       (select pka_com_function.fp_get_thaidate( max(interest_to) , 'dd/mm/yyyy' )
        from    sc_lon_m_loan_card_detail
        where   loan_contract_no = sc_lon_m_loan_card.loan_contract_no
        and     seq_no = (select max(seq_no)
                         from    sc_lon_m_loan_card_detail tab
                         where   loan_contract_no = sc_lon_m_loan_card_detail.loan_contract_no
                         and     loan_payment_date &lt;= '!last_calcint_date_1!' 
                         )
        ) as last_interest_tdate       

,       (select nvl(max(principal_balance),0)
        from    sc_lon_m_loan_card_detail
        where   loan_contract_no = sc_lon_m_loan_card.loan_contract_no
        and     seq_no = (select max(seq_no)
                         from    sc_lon_m_loan_card_detail tab
                         where   loan_contract_no = sc_lon_m_loan_card_detail.loan_contract_no
                         and     loan_payment_date &lt;= '!last_calcint_date_1!' 
                         )
        ) as principal_balance        

FROM    sc_lon_m_loan_card 
,       sc_mem_m_membership_registered 
,       sc_mem_m_ucf_member_group 
,       sc_mem_m_ucf_prename     
WHERE   1=2   
/*WHERE*/
ORDER BY sc_mem_m_ucf_member_group.member_group_no
,        sc_lon_m_loan_card.contact_status
,        sc_lon_m_loan_card.membership_no 
,        sc_lon_m_loan_card.loan_contract_no
) tab</value>

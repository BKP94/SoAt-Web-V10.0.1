@inject IConfiguration Config
@inject NavigationManager Nav

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @* base href = path ของ PathBase (dev ราก = "/", IIS sub-app = "/scTeller/") — รวมจาก NavigationManager *@
    <base href="@(new Uri(Nav.BaseUri).AbsolutePath)" />
    @* DevExpress theme (Bootstrap 5) — เปลี่ยน theme ที่ appsettings "DevExpress:Theme" จุดเดียว *@
    <!-- Prompt font (self-host, intranet-friendly) -->
    <link rel="stylesheet" href="fonts/prompt.css" />
    <!-- Bootstrap Icons (self-host, intranet-friendly) — ใช้ class bi bi-* ได้ทุกที่ (inline / DevExpress IconCssClass) -->
    <link rel="stylesheet" href="icons/bootstrap-icons.min.css" />
    @if (string.Equals(Config["DevExpress:Theme"], "fluent", StringComparison.OrdinalIgnoreCase))
    {
        @DxResourceManager.RegisterTheme(Themes.Fluent)
    }
    else
    {
        <link rel="stylesheet" href="_content/DevExpress.Blazor.Themes/@(Config["DevExpress:Theme"] ?? "office-white").bs5.min.css" />
    }
    <ResourcePreloader />
    @* favicon = โลโก้ SO-AT (emblem) จุดเดียวจาก RCL SoAt.Blazor *@
    <link rel="icon" type="image/png" href="@Assets["_content/SoAt.Blazor/favicon.png"]" />
    @* มาตรฐานปุ่ม action กลาง (soat-btn) — จุดเดียวจาก RCL SoAt.Blazor *@
    <link rel="stylesheet" href="@Assets["_content/SoAt.Blazor/soat.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["scTeller.styles.css"]" />
    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

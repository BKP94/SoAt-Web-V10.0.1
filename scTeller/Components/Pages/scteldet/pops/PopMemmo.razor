@using SoAt.Application.ScTeller
@inject IScteldetService Svc
@inject sc.dbFactory DbFactory

@* ── PopMemmo — บันทึกข้อความ (เลียน legacy scteldet/pops/popMemmo.ascx) — read-only ──
   grid sc_mem_m_member_memo (cancel_status='0' order seq_no) — reuse GetCommentLogAsync + CommentLogDto
   band "งด" (ฉ/ส/พ/ค้ำ) + ปรับฯ + band "บันทึกข้อมูล" (วันที่บันทึก/ผู้บันทึก)
   grid ใน popup: nb-pop-scroll จำกัดความสูง + scroll (เลียน VerticalScrollableHeight=480) *@

<DxPopup Visible="Visible" VisibleChanged="OnVisibleChanged" HeaderText="บันทึกข้อความ"
         Width="1100px" ShowFooter="true" CloseOnEscape="true">
    <BodyContentTemplate Context="pop">
        <div class="nb-pop-scroll">
            <DxGrid Data="_rows" PageSize="0" ShowAllRows="true"
                    ColumnResizeMode="GridColumnResizeMode.NextColumn">
                <Columns>
                    <DxGridDataColumn Caption="#" Name="seq" Width="40px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                        <CellDisplayTemplate>@(context.VisibleIndex + 1)</CellDisplayTemplate>
                        <FooterTemplate>@string.Format(">: {0:n0} รายการ", _rows.Count)</FooterTemplate>
                    </DxGridDataColumn>
                        <DxGridDataColumn Caption="รหัส" Width="90px">
                            <CellDisplayTemplate>@sc.combo.text(sc.combo.sc_mem_m_ucf_memo2, ((CommentLogDto)context.DataItem).MemoCode)</CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn Caption="รายละเอียด" FieldName="MemoDetail" />
                        <DxGridBandColumn Caption="งด">
                            <Columns>
                                <DxGridDataColumn Caption="ฉ" Width="34px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                                    <CellDisplayTemplate><DxCheckBox Checked="@(((CommentLogDto)context.DataItem).DropEmer == "1")" ReadOnly="true" /></CellDisplayTemplate>
                                </DxGridDataColumn>
                                <DxGridDataColumn Caption="ส" Width="34px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                                    <CellDisplayTemplate><DxCheckBox Checked="@(((CommentLogDto)context.DataItem).DropNorm == "1")" ReadOnly="true" /></CellDisplayTemplate>
                                </DxGridDataColumn>
                                <DxGridDataColumn Caption="พ" Width="34px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                                    <CellDisplayTemplate><DxCheckBox Checked="@(((CommentLogDto)context.DataItem).DropSpec == "1")" ReadOnly="true" /></CellDisplayTemplate>
                                </DxGridDataColumn>
                                <DxGridDataColumn Caption="ค้ำ" Width="34px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                                    <CellDisplayTemplate><DxCheckBox Checked="@(((CommentLogDto)context.DataItem).DropColl == "1")" ReadOnly="true" /></CellDisplayTemplate>
                                </DxGridDataColumn>
                            </Columns>
                        </DxGridBandColumn>
                        <DxGridDataColumn Caption="ปรับฯ" Width="45px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                            <CellDisplayTemplate><DxCheckBox Checked="@(((CommentLogDto)context.DataItem).LonRestruc == "1")" ReadOnly="true" /></CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridBandColumn Caption="บันทึกข้อมูล">
                            <Columns>
                                <DxGridDataColumn Caption="วันที่บันทึก" Width="165px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                                    <CellDisplayTemplate>@sc.value.toStringTH(((CommentLogDto)context.DataItem).EntryDate, true)</CellDisplayTemplate>
                                </DxGridDataColumn>
                                <DxGridDataColumn Caption="ผู้บันทึก" Width="80px" AllowSort="false">
                                    <CellDisplayTemplate>@sc.combo.text(sc.combo.si_security_user, ((CommentLogDto)context.DataItem).EntryId)</CellDisplayTemplate>
                                </DxGridDataColumn>
                            </Columns>
                        </DxGridBandColumn>
                </Columns>
                <EmptyDataAreaTemplate>— ไม่มีบันทึกข้อความ —</EmptyDataAreaTemplate>
                <TotalSummary>
                    <DxGridSummaryItem SummaryType="GridSummaryItemType.Count" FooterColumnName="seq" />
                </TotalSummary>
            </DxGrid>
        </div>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton Text="ปิดหน้าจอ" RenderStyle="ButtonRenderStyle.Danger"
                  CssClass="soat-btn soat-btn--danger" Click="Close" />
    </FooterContentTemplate>
</DxPopup>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public string? MembershipNo { get; set; }

    private List<CommentLogDto> _rows = new();
    private string? _loadedKey;

    protected override async Task OnParametersSetAsync()
    {
        if (!Visible) { _loadedKey = null; return; }
        if (string.IsNullOrEmpty(MembershipNo)) { _rows = new(); return; }

        if (MembershipNo == _loadedKey) return;
        _loadedKey = MembershipNo;

        await using (var db = DbFactory.create())
            await sc.combo.warmAsync(db, sc.combo.sc_mem_m_ucf_memo2, sc.combo.si_security_user);

        _rows = await Svc.GetCommentLogAsync(MembershipNo);
    }

    private Task Close() => CloseInternal();

    private async Task OnVisibleChanged(bool visible)
    {
        Visible = visible;
        await VisibleChanged.InvokeAsync(visible);
    }

    private async Task CloseInternal()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
    }
}

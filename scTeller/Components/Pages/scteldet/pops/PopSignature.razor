@using SoAt.Application.ScTeller
@inject IScteldetService Svc

@* ── PopSignature — แสดงรูปลายเซ็น (เลียน legacy scteldet/pops/popSignature.ascx) ──
   binary image จาก sc_mem_m_member_signature.mem_signature → render base64
   โหลดบน OnParametersSetAsync (guard Visible + key เปลี่ยน) *@

<DxPopup Visible="Visible" VisibleChanged="OnVisibleChanged" HeaderText="แสดงรูปลายเซ็น"
         Width="700px" Height="450px" ShowFooter="true" CloseOnEscape="true">
    <BodyContentTemplate Context="pop">
        <div class="nb-sign-wrap">
            @if (!string.IsNullOrEmpty(_imgBase64))
            {
                <img class="nb-sign-img" src="data:image/jpeg;base64,@_imgBase64" alt="ลายเซ็น" />
            }
            else
            {
                <div class="nb-empty">— ไม่พบรูปลายเซ็น —</div>
            }
        </div>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton Text="ปิดหน้าจอ" RenderStyle="ButtonRenderStyle.Danger"
                  CssClass="soat-btn soat-btn--danger" Click="Close" />
    </FooterContentTemplate>
</DxPopup>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public string? MembershipNo { get; set; }

    private string? _imgBase64;
    private string? _loadedKey;

    protected override async Task OnParametersSetAsync()
    {
        if (!Visible) { _loadedKey = null; return; }
        if (string.IsNullOrEmpty(MembershipNo)) { _imgBase64 = null; return; }

        if (MembershipNo == _loadedKey) return;
        _loadedKey = MembershipNo;

        var bytes = await Svc.GetMemberSignatureAsync(MembershipNo);
        _imgBase64 = bytes is { Length: > 0 } ? Convert.ToBase64String(bytes) : null;
    }

    private Task Close() => CloseInternal();

    private async Task OnVisibleChanged(bool visible)
    {
        Visible = visible;
        await VisibleChanged.InvokeAsync(visible);
    }

    private async Task CloseInternal()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
    }
}

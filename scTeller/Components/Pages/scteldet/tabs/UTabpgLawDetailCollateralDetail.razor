@using SoAt.Application.ScTeller
@inject IScteldetService Svc

@* ── popLaw sub 2: รายละเอียดผู้ค้ำประกัน (legacy u_tabpg_law_detail_collateral_detail) — read-only ──
   grid sc_law_prosec_defendants; defendant_type M/C/G/P → inline text *@

@if (string.IsNullOrEmpty(ProsecNo))
{
    <div class="nb-empty">— ไม่มีข้อมูล —</div>
}
else
{
    <DxGrid Data="_rows" PageSize="0" ShowAllRows="true"
            ColumnResizeMode="GridColumnResizeMode.NextColumn">
        <Columns>
            <DxGridDataColumn Caption="ลำดับการฟ้อง" Name="seq" Width="120px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@(((LawCollateralDetailDto)context.DataItem).ItemOrder)</CellDisplayTemplate>
                <FooterTemplate>@_rows.Count รายการ</FooterTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เลขทะเบียน" FieldName="MembershipNo" Width="110px" TextAlignment="GridTextAlignment.Center" />
            <DxGridDataColumn Caption="ชื่อสมาชิก/ชื่อจำเลย" FieldName="DefendantName" />
            <DxGridDataColumn Caption="ประเภทจำเลย" Width="150px">
                <CellDisplayTemplate>@DefType(((LawCollateralDetailDto)context.DataItem).DefendantType)</CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
        <EmptyDataAreaTemplate>— ไม่มีรายละเอียดผู้ค้ำประกัน —</EmptyDataAreaTemplate>
        <TotalSummary>
            <DxGridSummaryItem SummaryType="GridSummaryItemType.Count" FooterColumnName="seq" />
        </TotalSummary>
    </DxGrid>
}

@code {
    [Parameter] public string? ProsecNo { get; set; }

    private string? _loadedFor;
    private List<LawCollateralDetailDto> _rows = new();

    protected override async Task OnParametersSetAsync()
    {
        if (ProsecNo == _loadedFor) return;
        _loadedFor = ProsecNo;
        if (string.IsNullOrEmpty(_loadedFor)) { _rows = new(); return; }
        _rows = await Svc.GetLawCollateralDetailAsync(_loadedFor);
    }

    private static string DefType(string? v) => v switch
    {
        "M" => "ผู้กู้หลัก",
        "C" => "ผู้ค้ำประกัน",
        "G" => "ทายาท",
        "P" => "บุคคลภายนอก",
        _ => v ?? ""
    };
}

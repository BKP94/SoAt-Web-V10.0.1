@using SoAt.Application.ScTeller
@inject IScteldetService Svc
@inject sc.dbFactory DbFactory

@* ── popup popLoan_detail sub-tab 3: รายการค้ำประกัน (legacy u_tabpg_loan_detail_coll_detail gvLoanColl) — read-only ──
   ⚠ grid รอง gvCollOther (getCalcCollUsed คำนวณ runtime) DEFERRED — ยังไม่ port *@

@if (string.IsNullOrEmpty(LoanContractNo))
{
    <div class="nb-empty">— ไม่มีข้อมูล —</div>
}
else if (_rows.Count == 0)
{
    <div class="nb-empty">— ไม่มีรายการค้ำประกัน —</div>
}
else
{
    <DxGrid Data="_rows" PageSize="0" ShowAllRows="true"
            ColumnResizeMode="GridColumnResizeMode.NextColumn">
        <Columns>
            <DxGridDataColumn Caption="ที่" Width="50px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                <CellDisplayTemplate>@(context.VisibleIndex + 1)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="หลักประกัน" Width="130px">
                <CellDisplayTemplate>@sc.combo.text(sc.combo.sc_lon_m_ucf_collateral_type2, ((LoanDetailCollDto)context.DataItem).CollateralTypeCode)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เลขอ้างอิง" FieldName="RefOwnNo" Width="100px" />
            <DxGridDataColumn Caption="รายละเอียด" FieldName="CollateralDescription" MinWidth="160" />
            <DxGridDataColumn Caption="ค้ำประกัน" Width="110px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((LoanDetailCollDto)context.DataItem).UsedAmount)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เก็บผู้ค้ำ" Width="80px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@(((LoanDetailCollDto)context.DataItem).KeepCollStatus == "1" ? "✔" : "")</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เรียกเก็บฐานผู้ค้ำ" Width="120px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((LoanDetailCollDto)context.DataItem).KeepCollAmount)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="หมายเหตุ" FieldName="Remark" MinWidth="120" />
        </Columns>
    </DxGrid>
}

@code {
    [Parameter] public string? LoanContractNo { get; set; }

    private string? _loadedFor;
    private List<LoanDetailCollDto> _rows = new();

    protected override async Task OnParametersSetAsync()
    {
        if (LoanContractNo == _loadedFor) return;
        _loadedFor = LoanContractNo;
        if (string.IsNullOrEmpty(_loadedFor)) { _rows = new(); return; }

        await using (var db = DbFactory.create())
            await sc.combo.warmAsync(db, sc.combo.sc_lon_m_ucf_collateral_type2);

        _rows = await Svc.GetLoanDetailCollAsync(_loadedFor);
    }
}

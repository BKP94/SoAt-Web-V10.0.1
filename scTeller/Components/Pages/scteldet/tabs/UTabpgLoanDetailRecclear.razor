@using SoAt.Application.ScTeller
@inject IScteldetService Svc

@* ── popup popLoan_detail sub-tab 6: รายการหักกลบ (legacy u_tabpg_loan_detail_recclear) — read-only ──
   head = ใบเสร็จ (form) + item grid. จำนวนเงินรวม (item_amount) มี footer sum *@

@if (string.IsNullOrEmpty(LoanContractNo))
{
    <div class="nb-empty">— ไม่มีข้อมูล —</div>
}
else if (_head is null && _rows.Count == 0)
{
    <div class="nb-empty">— ไม่มีรายการหักกลบ —</div>
}
else
{
    @if (_head is not null)
    {
        <DxFormLayout CssClass="nb-tab-form">
            <DxFormLayoutItem Caption="เลขที่ใบเสร็จ" ColSpanMd="6">
                <span class="nb-ro">@_head.ReceiptNo</span>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="วันที่ใบเสร็จ" ColSpanMd="6">
                <span class="nb-ro" style="text-align:center;">@sc.value.toStringTH(_head.ReceiptDate)</span>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="วันที่คิดดอกเบี้ย" ColSpanMd="6">
                <span class="nb-ro" style="text-align:center;">@sc.value.toStringTH(_head.CalcintDate)</span>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="ผู้บันทึก" ColSpanMd="6">
                <span class="nb-ro">@_head.EntryId</span>
            </DxFormLayoutItem>
        </DxFormLayout>
    }

    <div style="margin-top:12px;"></div>
    <DxGrid Data="_rows" PageSize="0" ShowAllRows="true"
            ColumnResizeMode="GridColumnResizeMode.NextColumn">
        <Columns>
            <DxGridDataColumn Caption="ที่" Width="50px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                <CellDisplayTemplate>@(context.VisibleIndex + 1)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="รหัส" FieldName="ItemType" Width="60px" TextAlignment="GridTextAlignment.Center" />
            <DxGridDataColumn Caption="รายละเอียด" FieldName="Description" MinWidth="150" />
            <DxGridDataColumn Caption="งวด" Width="60px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@sc.value.toStringF(((LoanDetailRecclearItemDto)context.DataItem).Period, sc.att.datatype.Integer)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เงินต้น" Width="105px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((LoanDetailRecclearItemDto)context.DataItem).PrincipalAmount)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ดอกเบี้ย" Width="105px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((LoanDetailRecclearItemDto)context.DataItem).InterestAmount)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="จำนวนเงินรวม" FieldName="ItemAmount" Width="110px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((LoanDetailRecclearItemDto)context.DataItem).ItemAmount)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="คงเหลือ" Width="105px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((LoanDetailRecclearItemDto)context.DataItem).Balance)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ดอกเบี้ยคืน" Width="105px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((LoanDetailRecclearItemDto)context.DataItem).InterestReturn)</CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
        <EmptyDataAreaTemplate>— ไม่มีรายการหักกลบ —</EmptyDataAreaTemplate>
        <TotalSummary>
            <DxGridSummaryItem SummaryType="GridSummaryItemType.Sum" FieldName="ItemAmount" DisplayText="{0:n2}" />
        </TotalSummary>
    </DxGrid>
}

@code {
    [Parameter] public string? LoanContractNo { get; set; }

    private string? _loadedFor;
    private LoanDetailRecclearHeadDto? _head;
    private List<LoanDetailRecclearItemDto> _rows = new();

    protected override async Task OnParametersSetAsync()
    {
        if (LoanContractNo == _loadedFor) return;
        _loadedFor = LoanContractNo;
        if (string.IsNullOrEmpty(_loadedFor)) { _head = null; _rows = new(); return; }

        _head = await Svc.GetLoanDetailRecclearHeadAsync(_loadedFor);
        _rows = await Svc.GetLoanDetailRecclearItemAsync(_loadedFor);
    }
}

@using SoAt.Application.ScTeller
@inject IScteldetService Svc

@* ── G7 Tab 10: ประวัติเปลี่ยนที่อยู่ (legacy u_tabpg_mem_detail_addresshistory) — viewer read-only ──
   pre_edit/post_edit ประกอบเป็นข้อความที่อยู่เต็มใน SQL (Oracle DECODE → PG CASE) *@

@if (string.IsNullOrEmpty(Model.MembershipNo))
{
    <div class="nb-empty">— ยังไม่ได้เลือกสมาชิก —</div>
}
else
{
    <DxGrid Data="_rows" PageSize="0" ShowAllRows="true"
            ColumnResizeMode="GridColumnResizeMode.NextColumn">
        <Columns>
            <DxGridDataColumn Caption="ลำดับ" Name="seq" Width="55px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                <CellDisplayTemplate>@(context.VisibleIndex + 1)</CellDisplayTemplate>
                <FooterTemplate>@_rows.Count รายการ</FooterTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="วันที่" Width="110px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@sc.value.toStringTH(((AddressHistoryDto)context.DataItem).OperateDate)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ประเภทที่อยู่" Width="110px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@AddrType(((AddressHistoryDto)context.DataItem).AddressType)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ที่อยู่ก่อนเปลี่ยน" FieldName="PreEdit" Width="360px" />
            <DxGridDataColumn Caption="ที่อยู่หลังเปลี่ยน" FieldName="PostEdit" Width="360px" />
            <DxGridDataColumn Caption="ผู้ทำรายการ" FieldName="EntryId" Width="110px" TextAlignment="GridTextAlignment.Center" />
            <DxGridDataColumn Caption="วันที่บันทึก" Width="110px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@sc.value.toStringTH(((AddressHistoryDto)context.DataItem).EntryDate)</CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
        <EmptyDataAreaTemplate>— ไม่มีประวัติการเปลี่ยนที่อยู่ —</EmptyDataAreaTemplate>
        <TotalSummary>
            <DxGridSummaryItem SummaryType="GridSummaryItemType.Count" FooterColumnName="seq" />
        </TotalSummary>
    </DxGrid>
}

@code {
    [Parameter, EditorRequired] public ScteldetModel Model { get; set; } = default!;

    private string? _loadedFor;
    private List<AddressHistoryDto> _rows = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Model.MembershipNo == _loadedFor) return;
        _loadedFor = Model.MembershipNo;
        if (string.IsNullOrEmpty(_loadedFor)) { _rows = new(); return; }
        _rows = await Svc.GetAddressHistoryAsync(_loadedFor);
    }

    private static string AddrType(string? v) => v switch
    {
        "0" => "ปัจจุบัน",
        "1" => "ทะเบียนบ้าน",
        "2" => "ที่ทำงาน",
        _   => v ?? ""
    };
}

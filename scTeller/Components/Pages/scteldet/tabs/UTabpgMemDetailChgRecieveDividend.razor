@using SoAt.Application.ScTeller
@inject IScteldetService Svc

@* ── G7 Tab: ประวัติเปลี่ยนวิธีจ่ายปันผล (legacy u_tabpg_mem_detail_chg_recieve_dividend) ──
   grid sc_mem_edit_recieve_dividend — read-only (ชื่อวิธีมาจาก subquery sc_com_m_ucf_money_type)
   ไม่มีสีแถวพิเศษ *@

@if (string.IsNullOrEmpty(Model.MembershipNo))
{
    <div class="nb-empty">— ยังไม่ได้เลือกสมาชิก —</div>
}
else
{
    <DxGrid Data="_rows" PageSize="0" ShowAllRows="true"
            ColumnResizeMode="GridColumnResizeMode.NextColumn">
        <Columns>
            <DxGridDataColumn Caption="ลำดับ" Name="seq" Width="60px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                <CellDisplayTemplate>@(context.VisibleIndex + 1)</CellDisplayTemplate>
                <FooterTemplate>@string.Format("รวม : {0} รายการ", _rows.Count)</FooterTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="วันที่ดำเนินการ" Width="130px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@sc.value.toStringTH(((ChgRecieveDividendDto)context.DataItem).OperateDate)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="วิธีจ่ายปันผล (เดิม)" Width="220px">
                <CellDisplayTemplate>@FmtMethod(((ChgRecieveDividendDto)context.DataItem).PreMethodRecieveDividend, ((ChgRecieveDividendDto)context.DataItem).PreMethodRecieveDividendName)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="วิธีจ่ายปันผล (ใหม่)" Width="220px">
                <CellDisplayTemplate>@FmtMethod(((ChgRecieveDividendDto)context.DataItem).MethodRecieveDividend, ((ChgRecieveDividendDto)context.DataItem).MethodRecieveDividendName)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ผู้ทำรายการ" FieldName="EntryId" Width="150px" />
        </Columns>
        <EmptyDataAreaTemplate>— ไม่มีประวัติเปลี่ยนวิธีจ่ายปันผล —</EmptyDataAreaTemplate>
        <TotalSummary>
            <DxGridSummaryItem SummaryType="GridSummaryItemType.Count" FooterColumnName="seq" />
        </TotalSummary>
    </DxGrid>
}

@code {
    [Parameter, EditorRequired] public ScteldetModel Model { get; set; } = default!;

    private string? _loadedFor;
    private List<ChgRecieveDividendDto> _rows = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Model.MembershipNo == _loadedFor) return;
        _loadedFor = Model.MembershipNo;
        if (string.IsNullOrEmpty(_loadedFor)) { _rows = new(); return; }
        _rows = await Svc.GetChgRecieveDividendAsync(_loadedFor);
    }

    private static string FmtMethod(string? code, string? name)
        => string.IsNullOrEmpty(code) ? "" : $"{code} - {name}";
}

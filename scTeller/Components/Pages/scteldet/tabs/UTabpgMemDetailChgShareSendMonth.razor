@using SoAt.Application.ScTeller
@inject IScteldetService Svc

@* ── G7 Tab 4: เปลี่ยนยอดส่งหุ้นรายเดือน (legacy u_tabpg_mem_detail_chg_share_send_month) — viewer read-only ──
   view_tel_det_chg WHERE loan_contract_no = 'SHR' *@

@if (string.IsNullOrEmpty(Model.MembershipNo))
{
    <div class="nb-empty">— ยังไม่ได้เลือกสมาชิก —</div>
}
else
{
    <DxGrid Data="_rows" PageSize="0" ShowAllRows="true"
            ColumnResizeMode="GridColumnResizeMode.NextColumn">
        <Columns>
            <DxGridDataColumn Caption="ลำดับ" Name="seq" Width="55px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                <CellDisplayTemplate>@(context.VisibleIndex + 1)</CellDisplayTemplate>
                <FooterTemplate>@_rows.Count รายการ</FooterTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="วันที่" Width="110px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@sc.value.toStringTH(((SendMonthChgDto)context.DataItem).ApproveDate)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ยอดส่งหุ้นเดิม" Width="130px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((SendMonthChgDto)context.DataItem).PeriodOld)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ยอดส่งหุ้นใหม่" Width="130px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((SendMonthChgDto)context.DataItem).PeriodNew)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="หมายเหตุ" FieldName="ReasonDesc" Width="260px" />
        </Columns>
        <EmptyDataAreaTemplate>— ไม่มีประวัติการเปลี่ยนยอดส่งหุ้นรายเดือน —</EmptyDataAreaTemplate>
        <TotalSummary>
            <DxGridSummaryItem SummaryType="GridSummaryItemType.Count" FooterColumnName="seq" />
        </TotalSummary>
    </DxGrid>
}

@code {
    [Parameter, EditorRequired] public ScteldetModel Model { get; set; } = default!;

    private string? _loadedFor;
    private List<SendMonthChgDto> _rows = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Model.MembershipNo == _loadedFor) return;
        _loadedFor = Model.MembershipNo;
        if (string.IsNullOrEmpty(_loadedFor)) { _rows = new(); return; }
        _rows = await Svc.GetShareSendMonthChgAsync(_loadedFor);
    }
}

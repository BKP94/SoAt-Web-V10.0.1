@using SoAt.Application.ScTeller
@inject IScteldetService Svc
@inject sc.dbFactory DbFactory

@* ── G5 Tab 2: ข้อมูลเครดิต (legacy u_tabpg_mem_detail_credit) — viewer read-only ──
   grid sc_mem_m_member_credit; รหัส = combo sc_mem_m_ucf_credit_management ("code - desc") *@

@if (string.IsNullOrEmpty(Model.MembershipNo))
{
    <div class="nb-empty">— ยังไม่ได้เลือกสมาชิก —</div>
}
else
{
    <DxGrid Data="_rows" PageSize="0" ShowAllRows="true"
            ColumnResizeMode="GridColumnResizeMode.NextColumn">
        <Columns>
            <DxGridDataColumn Caption="รหัส" Name="seq" Width="260px">
                <CellDisplayTemplate>@sc.combo.text(sc.combo.sc_mem_m_ucf_credit_management, ((CreditDto)context.DataItem).CreditCode)</CellDisplayTemplate>
                <FooterTemplate>@_rows.Count รายการ</FooterTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="รายละเอียด" FieldName="CreditDesc" Width="400px" />
        </Columns>
        <EmptyDataAreaTemplate>— ไม่มีข้อมูลเครดิต —</EmptyDataAreaTemplate>
        <TotalSummary>
            <DxGridSummaryItem SummaryType="GridSummaryItemType.Count" FooterColumnName="seq" />
        </TotalSummary>
    </DxGrid>
}

@code {
    [Parameter, EditorRequired] public ScteldetModel Model { get; set; } = default!;

    private string? _loadedFor;
    private List<CreditDto> _rows = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Model.MembershipNo == _loadedFor) return;
        _loadedFor = Model.MembershipNo;
        if (string.IsNullOrEmpty(_loadedFor)) { _rows = new(); return; }

        await using (var db = DbFactory.create())
            await sc.combo.warmAsync(db, sc.combo.sc_mem_m_ucf_credit_management);

        _rows = await Svc.GetCreditAsync(_loadedFor);
    }
}

@using SoAt.Application.ScTeller
@inject IScteldetService Svc
@inject sc.dbFactory DbFactory

@* ── G7 Tab 13: ประวัติเปลี่ยนเงินเดือน (legacy u_tabpg_mem_detail_history_salary) — viewer read-only ──
   entry_br แสดงชื่อสาขา (sc.combo.sc_com_m_branch) *@

@if (string.IsNullOrEmpty(Model.MembershipNo))
{
    <div class="nb-empty">— ยังไม่ได้เลือกสมาชิก —</div>
}
else
{
    <DxGrid Data="_rows" PageSize="0" ShowAllRows="true"
            ColumnResizeMode="GridColumnResizeMode.NextColumn">
        <Columns>
            <DxGridDataColumn Caption="ลำดับ" Name="seq" Width="55px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                <CellDisplayTemplate>@(context.VisibleIndex + 1)</CellDisplayTemplate>
                <FooterTemplate>@_rows.Count รายการ</FooterTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="วันที่" Width="105px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@sc.value.toStringTH(((HistorySalaryDto)context.DataItem).OperateDate)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เงินเดือนเดิม" Width="110px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((HistorySalaryDto)context.DataItem).PreSalaryAmount)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เงินเดือนใหม่" Width="110px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((HistorySalaryDto)context.DataItem).SalaryAmount)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เงินวิทยฐานะเดิม" Width="120px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((HistorySalaryDto)context.DataItem).PreAcademicSalary)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เงินวิทยฐานะใหม่" Width="120px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((HistorySalaryDto)context.DataItem).AcademicSalary)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ค่าตอบแทนเดิม" Width="115px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((HistorySalaryDto)context.DataItem).PreRemunerationAmount)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ค่าตอบแทนใหม่" Width="115px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((HistorySalaryDto)context.DataItem).RemunerationAmount)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เงินได้จริงเดิม" Width="115px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((HistorySalaryDto)context.DataItem).PreSalaryReal)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เงินได้จริงใหม่" Width="115px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((HistorySalaryDto)context.DataItem).SalaryReal)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ผู้ทำรายการ" FieldName="EntryId" Width="105px" TextAlignment="GridTextAlignment.Center" />
            <DxGridDataColumn Caption="สาขา" Width="140px">
                <CellDisplayTemplate>@sc.combo.text(sc.combo.sc_com_m_branch, ((HistorySalaryDto)context.DataItem).EntryBr)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="วันที่บันทึก" Width="105px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@sc.value.toStringTH(((HistorySalaryDto)context.DataItem).EntryDate)</CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
        <EmptyDataAreaTemplate>— ไม่มีประวัติการเปลี่ยนเงินเดือน —</EmptyDataAreaTemplate>
        <TotalSummary>
            <DxGridSummaryItem SummaryType="GridSummaryItemType.Count" FooterColumnName="seq" />
        </TotalSummary>
    </DxGrid>
}

@code {
    [Parameter, EditorRequired] public ScteldetModel Model { get; set; } = default!;

    private string? _loadedFor;
    private List<HistorySalaryDto> _rows = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Model.MembershipNo == _loadedFor) return;
        _loadedFor = Model.MembershipNo;
        if (string.IsNullOrEmpty(_loadedFor)) { _rows = new(); return; }
        await using (var db = DbFactory.create())
            await sc.combo.warmAsync(db, sc.combo.sc_com_m_branch);
        _rows = await Svc.GetHistorySalaryAsync(_loadedFor);
    }
}

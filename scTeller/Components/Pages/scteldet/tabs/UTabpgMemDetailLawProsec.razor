@using SoAt.Application.ScTeller
@using scTeller.Components.Pages.scteldet.pops
@inject IScteldetService Svc
@inject sc.dbFactory DbFactory

@* ── G6 Tab 6: ดำเนินคดี (legacy u_tabpg_mem_detail_law_prosec) — viewer read-only ──
   grid sc_law_prosecutions + popup popLaw 11 sub-tab (ActiveTabIndex เริ่มที่ 1 = รายละเอียดผู้ค้ำประกัน)
   double-click แถว หรือ 🔍 → เปิด popup ส่ง prosec_no ลง sub-tab *@

@if (string.IsNullOrEmpty(Model.MembershipNo))
{
    <div class="nb-empty">— ยังไม่ได้เลือกสมาชิก —</div>
}
else
{
    <DxGrid Data="_rows" PageSize="0" ShowAllRows="true"
            ColumnResizeMode="GridColumnResizeMode.NextColumn"
            RowDoubleClick="OnRowDoubleClick">
        <Columns>
            <DxGridDataColumn Caption="#" Name="seq" Width="35px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                <CellDisplayTemplate>@(context.VisibleIndex + 1)</CellDisplayTemplate>
                <FooterTemplate>@string.Format("{0} รายการ", _rows.Count)</FooterTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เลขที่แฟ้ม" FieldName="ProsecNo" Width="93px" TextAlignment="GridTextAlignment.Center" />
            <DxGridDataColumn Caption="วันส่งคดี" Width="97px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@sc.value.toStringTH(((LawProsecDto)context.DataItem).OperateDate)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="วันที่ฟ้อง" Width="97px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@sc.value.toStringTH(((LawProsecDto)context.DataItem).ProsecDate)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ตง.ก่อนฟ้อง" Width="125px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((LawProsecDto)context.DataItem).AllPrincipalBalance)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ดบ.ก่อนฟ้อง" Width="125px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((LawProsecDto)context.DataItem).AllInterestArrear)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ทุนทรัพย์ฟ้อง" Width="125px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((LawProsecDto)context.DataItem).AllAssetAmount)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ทนาย" FieldName="Lawyer" Width="140px" />
            <DxGridDataColumn Caption="ศาลที่รับฟ้อง" FieldName="CourtName" Width="150px" />
            <DxGridDataColumn Caption="สาเหตุพ้นสภาพ" Width="140px">
                <CellDisplayTemplate>@sc.combo.text(sc.combo.sc_mem_m_ucf_resign_cause, ((LawProsecDto)context.DataItem).ResignCode)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="สถานะ" Width="64px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@(((LawProsecDto)context.DataItem).CancelStatus == "1" ? "ยกเลิกแล้ว" : "ปกติ")</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="" Width="42px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                <CellDisplayTemplate>
                    <button type="button" class="nb-linkbtn" @onclick="() => Open((LawProsecDto)context.DataItem)">🔍</button>
                </CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
        <EmptyDataAreaTemplate>— ไม่มีข้อมูลการดำเนินคดี —</EmptyDataAreaTemplate>
        <TotalSummary>
            <DxGridSummaryItem SummaryType="GridSummaryItemType.Count" FooterColumnName="seq" />
        </TotalSummary>
    </DxGrid>
}

<PopLawDetail @bind-Visible="_popVisible" ProsecNo="@_selectedProsec" HeaderText="@_popHeader" />

@code {
    [Parameter, EditorRequired] public ScteldetModel Model { get; set; } = default!;

    private string? _loadedFor;
    private List<LawProsecDto> _rows = new();

    private bool _popVisible;
    private string? _selectedProsec;
    private string _popHeader = "รายละเอียดการดำเนินคดี";

    protected override async Task OnParametersSetAsync()
    {
        if (Model.MembershipNo == _loadedFor) return;
        _loadedFor = Model.MembershipNo;
        if (string.IsNullOrEmpty(_loadedFor)) { _rows = new(); return; }

        await using (var db = DbFactory.create())
            await sc.combo.warmAsync(db, sc.combo.sc_mem_m_ucf_resign_cause);

        _rows = await Svc.GetLawProsecAsync(_loadedFor);
    }

    private void OnRowDoubleClick(GridRowClickEventArgs e)
    {
        if (e.Grid.GetDataItem(e.VisibleIndex) is LawProsecDto r) Open(r);
    }

    private void Open(LawProsecDto r)
    {
        _selectedProsec = r.ProsecNo;
        _popHeader = $"รายละเอียดการดำเนินคดี — เลขที่แฟ้ม {r.ProsecNo}";
        _popVisible = true;
    }
}

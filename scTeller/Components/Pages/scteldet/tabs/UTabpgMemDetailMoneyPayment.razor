@using SoAt.Application.ScTeller
@inject IScteldetService Svc

@* ── G4 Tab 1: การจ่ายเงิน (legacy u_tabpg_mem_detail_money_payment) — viewer read-only ──
   1 ใบเสร็จ = หลายรายการ; ฟิลด์ระดับใบเสร็จ (ประเภทเงิน/เงินโอน/ซื้อหุ้น/รวมชำระ/เงินคืน)
   โชว์เฉพาะแถวแรกของใบเสร็จ (service ทำ decode getrow=1 → null แถวถัดไป → toStringF=null="")
   ประเภทเงิน = money_name + "(" + bank_name + ")" เฉพาะเมื่อมี bank_name (เลียน HtmlDataCellPrepared) *@

@if (string.IsNullOrEmpty(Model.MembershipNo))
{
    <div class="nb-empty">— ยังไม่ได้เลือกสมาชิก —</div>
}
else
{
    <DxGrid Data="_rows" PageSize="0" ShowAllRows="true"
            ColumnResizeMode="GridColumnResizeMode.NextColumn">
        <Columns>
            <DxGridDataColumn Caption="#" Name="seq" Width="40px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                <CellDisplayTemplate>@(context.VisibleIndex + 1)</CellDisplayTemplate>
                <FooterTemplate>@_rows.Count รายการ</FooterTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="วันที่ใบเสร็จ" Width="100px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@sc.value.toStringTH(((MoneyPaymentDto)context.DataItem).ReceiptDate)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เลขที่ใบเสร็จ" FieldName="ReceiptNo" Width="100px" />
            <DxGridDataColumn Caption="วันที่โอน" Width="100px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@sc.value.toStringTH(((MoneyPaymentDto)context.DataItem).TransDate)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ประเภทเงิน" Width="250px">
                <CellDisplayTemplate>@MoneyType((MoneyPaymentDto)context.DataItem)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เงินโอน" Width="120px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((MoneyPaymentDto)context.DataItem).MoneyTrans)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ซื้อหุ้น" Width="120px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((MoneyPaymentDto)context.DataItem).BuyShare)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เลขที่สัญญา" FieldName="LoanContractNo" Width="120px" />
            <DxGridDataColumn Caption="เงินต้น" Width="120px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((MoneyPaymentDto)context.DataItem).PrincipalAmount)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ดบ." Width="120px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((MoneyPaymentDto)context.DataItem).InterestAmount)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="จำนวนเงิน" Width="120px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((MoneyPaymentDto)context.DataItem).ItemAmount)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="รวมชำระ" Width="120px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((MoneyPaymentDto)context.DataItem).TotalPayment)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เงินคืน" Width="120px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((MoneyPaymentDto)context.DataItem).MoneyReturn)</CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
        <EmptyDataAreaTemplate>— ไม่มีรายการจ่ายเงิน —</EmptyDataAreaTemplate>
        <TotalSummary>
            <DxGridSummaryItem SummaryType="GridSummaryItemType.Count" FooterColumnName="seq" />
        </TotalSummary>
    </DxGrid>
}

@code {
    [Parameter, EditorRequired] public ScteldetModel Model { get; set; } = default!;

    private string? _loadedFor;
    private List<MoneyPaymentDto> _rows = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Model.MembershipNo == _loadedFor) return;
        _loadedFor = Model.MembershipNo;
        if (string.IsNullOrEmpty(_loadedFor)) { _rows = new(); return; }
        _rows = await Svc.GetMoneyPaymentAsync(_loadedFor);
    }

    // ประเภทเงิน — โชว์เฉพาะเมื่อมี bank_name (เลียน gvDetail_HtmlDataCellPrepared; ' ' placeholder → blank)
    private static string MoneyType(MoneyPaymentDto r)
        => !string.IsNullOrWhiteSpace(r.BankName) ? $"{r.MoneyName}({r.BankName})" : "";
}

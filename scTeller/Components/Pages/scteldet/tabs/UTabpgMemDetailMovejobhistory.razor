@using SoAt.Application.ScTeller
@inject IScteldetService Svc

@* ── G7 Tab 12: ประวัติย้ายหน่วยงาน (legacy u_tabpg_mem_detail_movejobhistory) — viewer read-only ──
   legacy DOC_EDIT = MAX(doc_no) subquery; ตาราง migrate มี column doc_edit เก็บไว้แล้ว → ใช้ตรง (บันทึกเบี่ยง) *@

@if (string.IsNullOrEmpty(Model.MembershipNo))
{
    <div class="nb-empty">— ยังไม่ได้เลือกสมาชิก —</div>
}
else
{
    <DxGrid Data="_rows" PageSize="0" ShowAllRows="true"
            ColumnResizeMode="GridColumnResizeMode.NextColumn">
        <Columns>
            <DxGridDataColumn Caption="ลำดับ" Name="seq" Width="55px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                <CellDisplayTemplate>@(context.VisibleIndex + 1)</CellDisplayTemplate>
                <FooterTemplate>@_rows.Count รายการ</FooterTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="วันที่ย้าย" Width="110px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@sc.value.toStringTH(((MoveJobHistoryDto)context.DataItem).OperateDate)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="เลขที่คำขอ" FieldName="DocEdit" Width="130px" TextAlignment="GridTextAlignment.Center" />
            <DxGridDataColumn Caption="หน่วยงานเดิม" Width="280px">
                <CellDisplayTemplate>@GroupText((MoveJobHistoryDto)context.DataItem, true)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="หน่วยงานใหม่" Width="280px">
                <CellDisplayTemplate>@GroupText((MoveJobHistoryDto)context.DataItem, false)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ผู้ทำรายการ" FieldName="EntryId" Width="110px" TextAlignment="GridTextAlignment.Center" />
            <DxGridDataColumn Caption="วันที่บันทึก" Width="110px" TextAlignment="GridTextAlignment.Center">
                <CellDisplayTemplate>@sc.value.toStringTH(((MoveJobHistoryDto)context.DataItem).EntryDate)</CellDisplayTemplate>
            </DxGridDataColumn>
        </Columns>
        <EmptyDataAreaTemplate>— ไม่มีประวัติการย้ายหน่วยงาน —</EmptyDataAreaTemplate>
        <TotalSummary>
            <DxGridSummaryItem SummaryType="GridSummaryItemType.Count" FooterColumnName="seq" />
        </TotalSummary>
    </DxGrid>
}

@code {
    [Parameter, EditorRequired] public ScteldetModel Model { get; set; } = default!;

    private string? _loadedFor;
    private List<MoveJobHistoryDto> _rows = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Model.MembershipNo == _loadedFor) return;
        _loadedFor = Model.MembershipNo;
        if (string.IsNullOrEmpty(_loadedFor)) { _rows = new(); return; }
        _rows = await Svc.GetMoveJobHistoryAsync(_loadedFor);
    }

    private static string GroupText(MoveJobHistoryDto r, bool pre)
    {
        var no = pre ? r.PreMemberGroupNo : r.MemberGroupNo;
        var nm = pre ? r.PreMemberGroupName : r.MemberGroupName;
        if (string.IsNullOrWhiteSpace(no)) return "";
        return string.IsNullOrWhiteSpace(nm) ? no! : $"{no} - {nm}";
    }
}

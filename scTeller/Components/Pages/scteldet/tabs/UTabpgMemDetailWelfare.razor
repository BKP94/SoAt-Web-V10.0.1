@using SoAt.Application.ScTeller
@inject IScteldetService Svc

@* ── G2 Tab 1: สวัสดิการ (legacy u_tabpg_mem_detail_welfare — view_tel_mem_wef) ──
   read-only grid เรียงตามวันอนุมัติล่าสุด + สรุปจำนวนรายการท้ายตาราง *@

@if (string.IsNullOrEmpty(Model.MembershipNo))
{
    <div class="nb-empty">— ยังไม่ได้เลือกสมาชิก —</div>
}
else
{
    <DxGrid Data="_rows" PageSize="0" ShowAllRows="true"
            ColumnResizeMode="GridColumnResizeMode.NextColumn">
        <Columns>
            <DxGridDataColumn Caption="#" Name="seq" Width="44px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                <CellDisplayTemplate>@(context.VisibleIndex + 1)</CellDisplayTemplate>
                <FooterTemplate>จำนวน @_rows.Count รายการ</FooterTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ประเภท" FieldName="WefType" Width="80px" TextAlignment="GridTextAlignment.Center" />
            <DxGridDataColumn Caption="รายการสวัสดิการ" FieldName="WefDesc" />
            <DxGridDataColumn Caption="วันที่ทำรายการ" Width="120px">
                <CellDisplayTemplate>@sc.value.toStringTH(((WelfareDto)context.DataItem).OperateDate)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="ยอดเงินที่ได้รับ" Width="130px" TextAlignment="GridTextAlignment.Right">
                <CellDisplayTemplate>@sc.value.toStringF(((WelfareDto)context.DataItem).TotalReceive)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="สถานะอนุมัติ" FieldName="ApproveStatus" Width="100px" TextAlignment="GridTextAlignment.Center" />
            <DxGridDataColumn Caption="วันที่อนุมัติ" Width="120px">
                <CellDisplayTemplate>@sc.value.toStringTH(((WelfareDto)context.DataItem).ApproveDate)</CellDisplayTemplate>
            </DxGridDataColumn>
            <DxGridDataColumn Caption="รายละเอียด" FieldName="WefDetail" />
        </Columns>
        <EmptyDataAreaTemplate>— ไม่มีข้อมูลสวัสดิการ —</EmptyDataAreaTemplate>
        <TotalSummary>
            <DxGridSummaryItem SummaryType="GridSummaryItemType.Count" FooterColumnName="seq" />
        </TotalSummary>
    </DxGrid>
}

@code {
    [Parameter, EditorRequired] public ScteldetModel Model { get; set; } = default!;

    private string? _loadedFor;
    private List<WelfareDto> _rows = new();

    protected override async Task OnParametersSetAsync()
    {
        if (Model.MembershipNo == _loadedFor) return;
        _loadedFor = Model.MembershipNo;
        if (string.IsNullOrEmpty(_loadedFor)) { _rows = new(); return; }
        _rows = await Svc.GetWelfareAsync(_loadedFor);
    }
}

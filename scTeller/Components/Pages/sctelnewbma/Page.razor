@page "/sctelnewbma"
@page "/sctelnewbma/{ApplicationFormNo}"
@rendermode InteractiveServer
@using System.Security.Claims
@using SoAt.Application.ScTeller
@using scTeller.Components.Pages.sctelnewbma.pops
@inject ISctelnewbmaService Svc
@inject NavigationManager Nav

@* ── sctelnewbma — หน้าสมัครสมาชิก ────────────────────────────────────────────────
   โครงมาตรฐาน (PageRegions): Header + Tabs + Operate (ไม่มี Detail)
   Index ถือ model (_form/_lookups) แล้วส่งลง child component ผ่าน [Parameter]
   Operate raise EventCallback กลับมาให้ Index จัดการ (New/Open/Save/Cancel) *@

<PageTitle>สมัครสมาชิก — scTeller</PageTitle>

<div class="nb-titlebar">
    <div>
        <h1 class="nb-title">สมัครสมาชิก</h1>
        <span class="nb-sub">@(IsEdit ? $"แก้ไขใบสมัครเลขที่ {ApplicationFormNo}" : "บันทึกใบสมัครสมาชิกใหม่")</span>
    </div>
    <a class="nb-back" href=".">← กลับหน้าหลัก</a>
</div>

@if (_lookups is null)
{
    <div class="nb-loading">กำลังโหลดข้อมูล…</div>
}
else
{
    <PageRegions>
        <HeaderContent>
            <PanHead Form="_form" Lookups="_lookups" />
        </HeaderContent>
        <TabsContent>
            <PanTabs Form="_form" Lookups="_lookups" />
        </TabsContent>
        <OperateContent>
            <PanOperate Busy="_saving" OnNew="NewForm_Click" OnOpen="Open" OnSave="Save" OnCancel="Cancel" />
        </OperateContent>
    </PageRegions>

    <PopOpen @bind-Visible="_openVisible" OnSelected="OnOpenSelected" />
}

@* กล่องข้อความ modal กลางจอ (ผลบันทึก/validation) — เลียน legacy sc.message *@
<ScMessage @ref="_msg" />

@code {
    [Parameter] public string? ApplicationFormNo { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool IsEdit => !string.IsNullOrWhiteSpace(ApplicationFormNo);

    private SctelnewbmaLookupsDto? _lookups;
    private ApplicationFormDto _form = NewForm();

    private bool   _saving;
    private bool   _openVisible;   // popup ค้นหา/เปิดใบสมัคร (PopOpen)
    private ScMessage _msg = default!;   // กล่องข้อความ modal กลางจอ
    private string? _loadError;          // error ตอนโหลด (แสดงหลัง render แรก)

    private string _userId   = "";
    private string _branchId = "";

    protected override async Task OnInitializedAsync()
    {
        _lookups = await Svc.GetLookupsAsync();

        if (AuthState is not null)
        {
            var user = (await AuthState).User;
            // login id (user_id) สำหรับ session var app.login_id → trigger เขียนลง entry_id varchar(16)
            // ห้ามใช้ Identity.Name (= DisplayName/user_name ชื่อเต็ม ยาวเกิน 16 → 22001 value too long)
            _userId   = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
            _branchId = user.FindFirst("branch_id")?.Value ?? "";
        }

        if (IsEdit)
        {
            var existing = await Svc.GetApplicationAsync(ApplicationFormNo!);
            if (existing is null)
                _loadError = $"ไม่พบใบสมัครเลขที่ {ApplicationFormNo}";
            else
            {
                _form = existing;
                EnsureSubObjects(_form);
            }
        }
    }

    // error ตอนโหลด → แสดงเป็น modal หลัง render แรก (modal ต้องมี component พร้อมก่อน)
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _loadError is not null)
        {
            var err = _loadError;
            _loadError = null;
            await _msg.Error(err);
        }
    }

    // ── Operate: บันทึก ───────────────────────────────────────────────────────────
    private async Task Save()
    {
        if (!Validate(out var error))
        {
            await _msg.Error(error);
            return;
        }

        _saving = true;
        try
        {
            // WorkInfo/Spouse/Own skip-empty + bank row-skip จัดที่ DTO (ISaveRowFilter) — ไม่ต้อง massage ที่นี่
            var result = IsEdit
                ? await Svc.UpdateApplicationAsync(ApplicationFormNo!, _form, _userId)
                : await Svc.CreateApplicationAsync(_form, _userId, _branchId);

            _saving = false;
            await _msg.Success($"{result.Message} (เลขที่ {result.ApplicationFormNo})");

            // สร้างใหม่ → ไปหน้าแก้ไขใบนั้น (หลังผู้ใช้กดตกลงในกล่องข้อความ)
            // ใช้ path แบบ relative (ไม่มี / นำหน้า) ให้ต่อ base href ของ IIS sub-app เอง
            if (!IsEdit)
                Nav.NavigateTo($"sctelnewbma/{result.ApplicationFormNo}");
        }
        catch (Exception ex)
        {
            await _msg.Error($"เกิดข้อผิดพลาด: {ex.Message}");
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Operate: เพิ่มใหม่ (ล้างฟอร์ม) ─────────────────────────────────────────────
    private void NewForm_Click()
    {
        if (IsEdit) { Nav.NavigateTo("sctelnewbma"); return; }
        _form = NewForm();
    }

    // ── Operate: เปิด / ค้นหา → popup PopOpen ──────────────────────────────────────
    private void Open() => _openVisible = true;

    // เลือกใบสมัครจาก popup → นำทางไปหน้าแก้ไขใบนั้น
    private void OnOpenSelected(string applicationFormNo) =>
        Nav.NavigateTo($"sctelnewbma/{applicationFormNo}");

    // ── Operate: ยกเลิก → กลับหน้าหลัก ─────────────────────────────────────────────
    private void Cancel() => Nav.NavigateTo("");

    // ── validation ────────────────────────────────────────────────────────────────
    private bool Validate(out string error)
    {
        if (string.IsNullOrWhiteSpace(_form.MemberName))    { error = "กรุณากรอกชื่อ"; return false; }
        if (string.IsNullOrWhiteSpace(_form.MemberSurname)) { error = "กรุณากรอกนามสกุล"; return false; }
        if (string.IsNullOrWhiteSpace(_form.MemType))       { error = "กรุณาเลือกประเภทสมาชิก"; return false; }
        if (_form.RecrieveGains.Count > 0 && _form.RecrieveGains.Sum(g => g.GainPercent ?? 0m) != 100m)
        {
            error = "สัดส่วนผู้รับผลประโยชน์ต้องรวมเป็น 100%"; return false;
        }
        error = "";
        return true;
    }

    // ── model lifecycle ─────────────────────────────────────────────────────────────
    private static ApplicationFormDto NewForm()
    {
        var f = new ApplicationFormDto { ApplyDate = DateTime.Today };
        EnsureSubObjects(f);
        return f;
    }

    private static void EnsureSubObjects(ApplicationFormDto f)
    {
        f.AddressCurrent ??= new AppAddressDto { AddressType = "0" };
        f.AddressHome    ??= new AppAddressDto { AddressType = "1" };
        f.AddressWork    ??= new AppAddressDto { AddressType = "2" };
        f.WorkInfo       ??= new AppWorkInfoDto();
        f.SpouseInfo     ??= new AppSpouseInfoDto();   // tab ข้อมูลครอบครัว (คู่สมรส)
        f.OwnInfo        ??= new AppOwnInfoDto();       // tab ข้อมูลการส่งหุ้น/โอน (รับโอน)
    }
}

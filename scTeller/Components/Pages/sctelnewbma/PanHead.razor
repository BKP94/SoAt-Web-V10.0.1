@using SoAt.Application.ScTeller
@using scTeller.Components.Pages.sctelnewbma.pops
@inject ISctelnewbmaService Svc

@* ── PanHead (Header region) ของ sctelnewbma ─────────────────────────────────────
   ข้อมูลหลักของผู้สมัครทั้งหมด (ส่วนตัว / ที่อยู่ / งาน / หุ้น / ผู้รับผล / รูป)
   เป็น dumb component — Page ถือ model แล้วส่ง Form ลงมา ([Parameter])
   (combo lookups โหลดเองในแต่ละ <ScCombo> ผ่าน sc.combo — ไม่รับ list จาก Page)
   field logic (cascading จังหวัด, เพิ่ม/ลบแถว, อัปโหลดรูป) แก้ลงบน Form ตรง (reference)
   format/value ทุกตัวมาจาก sc.* (mask/value) ตาม Coding Guideline *@

<DxFormLayout>
    <DxFormLayoutGroup Caption="ข้อมูลใบสมัคร ทดสอบ" ColSpanMd="12">
        <DxFormLayoutItem Caption="วันที่สมัคร" ColSpanMd="4">
            <DxDateEdit @bind-Date="Form.ApplyDate" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="ประเภทการสมัคร" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_application_type" @bind-Value="Form.ApplTypeCode" NullText="— เลือก —" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="ประเภทสมาชิก" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_member_type" @bind-Value="Form.MemType" NullText="— เลือก —" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="กลุ่มสมาชิก" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_member_group" Value="@Form.MemberGroupNo"
                     ValueChanged="@(v => OnMemberGroupChanged(v))" NullText="— เลือก —" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="กลุ่มเลือกตั้ง" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_election_group" @bind-Value="Form.ElectionGroup" NullText="— เลือก —" />
        </DxFormLayoutItem>
    </DxFormLayoutGroup>

    <DxFormLayoutGroup Caption="ชื่อ-สกุล (ไทย)" ColSpanMd="12">
        <DxFormLayoutItem Caption="คำนำหน้า" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_prename" Value="@Form.PrenameCode"
                     ValueChanged="@(v => OnPrenameChanged(v))" NullText="— เลือก —" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="ชื่อ" ColSpanMd="4">
            <DxTextBox Text="@Form.MemberName" TextChanged="@(async (string v) => { Form.MemberName = v; await OnNameChanged(); })" NullText="ชื่อ" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="นามสกุล" ColSpanMd="4">
            <DxTextBox Text="@Form.MemberSurname" TextChanged="@(async (string v) => { Form.MemberSurname = v; await OnNameChanged(); })" NullText="นามสกุล" />
        </DxFormLayoutItem>
    </DxFormLayoutGroup>

    <DxFormLayoutGroup Caption="ชื่อ-สกุล (อังกฤษ)" ColSpanMd="12">
        <DxFormLayoutItem Caption="Prename" ColSpanMd="4">
            <DxTextBox @bind-Text="Form.PrenameEng" NullText="Mr./Mrs./Ms." />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="Name" ColSpanMd="4">
            <DxTextBox @bind-Text="Form.NameEng" NullText="Name" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="Surname" ColSpanMd="4">
            <DxTextBox @bind-Text="Form.SurnameEng" NullText="Surname" />
        </DxFormLayoutItem>
    </DxFormLayoutGroup>

    <DxFormLayoutGroup Caption="ข้อมูลส่วนบุคคล" ColSpanMd="12">
        <DxFormLayoutItem Caption="เลขบัตรประชาชน" ColSpanMd="4">
            <ScInput Value="Form.HumId" ValueChanged="OnHumIdChanged" TValue="string"
                     Mask="@sc.mask.maskIdCard" NullText="x-xxxx-xxxxx-xx-x" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="วันเกิด" ColSpanMd="4">
            <DxDateEdit Date="Form.DateOfBirth" DateChanged="@((DateTime? d) => OnDateOfBirthChanged(d))" NullText="เลือกวันเกิด" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="อายุ" ColSpanMd="4">
            <DxTextBox Text="@Form.AgeText" ReadOnly="true" NullText="—" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="เพศ" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sex" @bind-Value="Form.Sex" NullText="— เลือก —" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="สถานภาพสมรส" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_marriage_status" @bind-Value="Form.MarriageStatus" NullText="— เลือก —" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="สัญชาติ" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_nationality" Value="@Form.NationalityCode"
                     ValueChanged="@(v => OnNationalityChanged(v))" NullText="— เลือก —" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="กรุ๊ปเลือด" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_blood" @bind-Value="Form.BloodCode" NullText="— เลือก —" />
        </DxFormLayoutItem>
    </DxFormLayoutGroup>

    <DxFormLayoutGroup Caption="ข้อมูลบัตรประชาชน" ColSpanMd="12">
        <DxFormLayoutItem Caption="เลขหลังบัตร (Laser)" ColSpanMd="4">
            <DxTextBox @bind-Text="Form.IdCardNumber" NullText="JTxxxxxxxxx" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="วันออกบัตร" ColSpanMd="4">
            <DxDateEdit @bind-Date="Form.IdCardDate" NullText="วันออกบัตร" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="วันหมดอายุ" ColSpanMd="4">
            <DxDateEdit @bind-Date="Form.IdCardEnddate" NullText="วันหมดอายุ" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="สถานที่ออกบัตร" ColSpanMd="12">
            <DxTextBox @bind-Text="Form.IdCardOrganize" NullText="อำเภอ/เขต ที่ออกบัตร" />
        </DxFormLayoutItem>
    </DxFormLayoutGroup>

    <DxFormLayoutGroup Caption="การติดต่อ" ColSpanMd="12">
        <DxFormLayoutItem Caption="โทรศัพท์มือถือ" ColSpanMd="4">
            <DxTextBox @bind-Text="Form.MobileNumber" NullText="08x-xxx-xxxx" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="อีเมล" ColSpanMd="4">
            <DxTextBox @bind-Text="Form.Email" NullText="name@example.com" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="หมายเหตุ" ColSpanMd="12">
            <DxMemo @bind-Text="Form.Remark" Rows="2" NullText="หมายเหตุเพิ่มเติม" />
        </DxFormLayoutItem>
    </DxFormLayoutGroup>

    @* ── ที่อยู่ (3 ชุด) — คัดลอกระหว่างปัจจุบัน ↔ ทะเบียนบ้าน เท่านั้น (ที่ทำงานไม่มีปุ่ม) ── *@
    @AddressBlock("ที่อยู่ปัจจุบัน", Form.AddressCurrent!,
        ("ทะเบียนบ้าน", Form.AddressHome!))
    @AddressBlock("ที่อยู่ตามทะเบียนบ้าน", Form.AddressHome!,
        ("ปัจจุบัน", Form.AddressCurrent!))
    @AddressBlock("ที่อยู่ที่ทำงาน", Form.AddressWork!)

    @* ── การทำงาน / หุ้น ───────────────────────────────────────────── *@
    <DxFormLayoutGroup Caption="ข้อมูลการทำงาน" ColSpanMd="12">
        <DxFormLayoutItem Caption="วันที่เริ่มงาน" ColSpanMd="4">
            <DxDateEdit @bind-Date="Work.WorkingDate" NullText="วันที่เริ่มงาน" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="รหัสหน่วยจ่ายเงินเดือน" ColSpanMd="4">
            <DxTextBox @bind-Text="Work.SalaryId" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="ประเภทงาน" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_group_position" Value="@Work.GroupPosition"
                     ValueChanged="@(v => Work.GroupPosition = v)" NullText="— เลือก —" />
        </DxFormLayoutItem>
        @* ตำแหน่งอื่นๆ — โชว์เฉพาะประเภทงาน = "00" (legacy change_group_position: GROUP_OTHER visibility) *@
        @if (Work.GroupPosition == "00")
        {
            <DxFormLayoutItem Caption="ระบุประเภทงานอื่นๆ" ColSpanMd="4">
                <DxTextBox @bind-Text="Work.GroupOther" NullText="ระบุประเภทงานอื่นๆ" />
            </DxFormLayoutItem>
        }
        <DxFormLayoutItem Caption="ตำแหน่ง" ColSpanMd="@(Work.GroupPosition == "00" ? 4 : 8)">
            <DxTextBox @bind-Text="Work.PositionLong" NullText="ชื่อตำแหน่งเต็ม" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="ระดับ" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_salary_level" Value="@(Work.LevelCode?.ToString())"
                     ValueChanged="@(v => OnLevelChanged(v))" NullText="— ระดับ —" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="ขั้น" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_salary_rate" Args="@(new object?[] { Work.LevelCode })"
                     Value="@(Work.SalaryRateCode?.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture))"
                     ValueChanged="@(v => OnSalaryRateChanged(v))" NullText="— ขั้น —" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="เงินเดือน" ColSpanMd="4">
            <ScInput Col="@sc.css.col.Decimal" Value="Work.SalaryAmount" TValue="decimal?"
                     ValueChanged="@(async (decimal? v) => { Work.SalaryAmount = v; await OnSalaryChanged(); })" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="เงินวิทยฐานะ" ColSpanMd="4">
            <ScInput Col="@sc.css.col.Decimal" Value="Work.AcademicSalary" TValue="decimal?"
                     ValueChanged="@(async (decimal? v) => { Work.AcademicSalary = v; await OnSalaryChanged(); })" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="เงินประจำตำแหน่ง" ColSpanMd="4">
            <ScInput Col="@sc.css.col.Decimal" Value="Work.RemunerationAmount" TValue="decimal?"
                     ValueChanged="@(async (decimal? v) => { Work.RemunerationAmount = v; await OnSalaryChanged(); })" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="เงินได้จริง" ColSpanMd="4">
            <ScInput Col="@sc.css.col.Decimal" @bind-Value="Work.SalaryReal" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="วันสิ้นสุดสัญญา" ColSpanMd="4">
            <DxDateEdit @bind-Date="Work.EndingcontractDate" NullText="วันสิ้นสุดสัญญา" />
        </DxFormLayoutItem>
    </DxFormLayoutGroup>

    <DxFormLayoutGroup Caption="การส่งหุ้น" ColSpanMd="12">
        <DxFormLayoutItem Caption="หุ้น (หน่วย)" ColSpanMd="4">
            @* legacy share_monthly_hoon: 1 หน่วย = 10 บาท → set ส่งหุ้นรายเดือน *@
            <ScInput Col="@sc.css.col.Integer" Value="ShareHoon" ValueChanged="OnShareHoonChanged" TValue="int?" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="ส่งหุ้นรายเดือน (บาท)" ColSpanMd="4">
            <ScInput Col="@sc.css.col.Decimal" Value="Form.ShareMonthly" ValueChanged="OnShareMonthlyChanged" TValue="decimal?" />
        </DxFormLayoutItem>
    </DxFormLayoutGroup>
</DxFormLayout>

@* ── ผู้รับผลประโยชน์ ─────────────────────────────────────────────────────────── *@
<div class="nb-grid-head" style="margin-top:24px">
    <h3 class="nb-h3">รายชื่อผู้รับผลประโยชน์</h3>
    <DxButton Text="+ เพิ่มรายชื่อ" RenderStyle="ButtonRenderStyle.Primary" Click="AddGain" />
</div>
@if (Form.RecrieveGains.Count == 0)
{
    <div class="nb-empty">ยังไม่มีรายชื่อผู้รับผลประโยชน์</div>
}
else
{
    <table class="nb-table">
        <thead>
            <tr>
                <th style="width:48px">#</th>
                <th>คำนำหน้า</th>
                <th>ชื่อ</th>
                <th>นามสกุล</th>
                <th style="width:170px">เลขบัตรประชาชน</th>
                <th>ความเกี่ยวข้อง</th>
                <th style="width:120px">สัดส่วน (%)</th>
                <th style="width:56px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var g in Form.RecrieveGains)
            {
                var row = g;
                <tr>
                    <td class="nb-seq">@row.SeqNo</td>
                    <td>
                        <ScCombo Combo="@sc.combo.sc_mem_m_ucf_prename" @bind-Value="row.PrenameCode" NullText="—" />
                    </td>
                    <td><DxTextBox @bind-Text="row.GainName" /></td>
                    <td><DxTextBox @bind-Text="row.GainSurname" /></td>
                    <td>
                        <ScInput Value="row.GainIdCard" TValue="string" Mask="@sc.mask.maskIdCard" NullText="x-xxxx-xxxxx-xx-x"
                                 ValueChanged="@(async (string v) => await OnGainIdCardChanged(row, v))" />
                    </td>
                    <td>
                        <ScCombo Combo="@sc.combo.sc_mem_m_ucf_concern" @bind-Value="row.ConcernCode" NullText="—" />
                    </td>
                    <td>
                        @* พิมพ์ 50 = 50% ตรงๆ (DxSpinEdit ไม่ fill-from-right) — โชว์ "50.00 %" ผ่าน sc.mask *@
                        <DxSpinEdit @bind-Value="row.GainPercent" DisplayFormat="@sc.mask.maskPercent2"
                                    ShowSpinButtons="false" MinValue="0m" CssClass="col-decimal" />
                    </td>
                    <td><DxButton Text="ลบ" RenderStyle="ButtonRenderStyle.Danger" Click="() => RemoveGain(row)" /></td>
                </tr>
            }
        </tbody>
    </table>
    <div class="nb-sum @(GainPercentTotal == 100 ? "nb-sum--ok" : "nb-sum--warn")">
        รวมสัดส่วน: @sc.value.toString(GainPercentTotal)% @(GainPercentTotal == 100 ? "✓" : "(ต้องรวมเป็น 100%)")
    </div>
}

@* ── สมาชิกอ้างอิง ────────────────────────────────────────────────────────────── *@
<div class="nb-grid-head" style="margin-top:24px">
    <h3 class="nb-h3">สมาชิกผู้อ้างอิง</h3>
    <DxButton Text="+ เพิ่มรายชื่อ" RenderStyle="ButtonRenderStyle.Primary" Click="AddRefer" />
</div>
@if (Form.MemberRefers.Count == 0)
{
    <div class="nb-empty">ยังไม่มีสมาชิกอ้างอิง</div>
}
else
{
    <table class="nb-table">
        <thead>
            <tr>
                <th style="width:48px">#</th>
                <th style="width:180px">เลขสมาชิก</th>
                <th>ชื่อ-สกุล</th>
                <th>ความเกี่ยวข้อง</th>
                <th style="width:56px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Form.MemberRefers)
            {
                var row = m;
                <tr>
                    <td class="nb-seq">@row.SeqNo</td>
                    <td>
                        <DxTextBox Text="row.MembershipNo" NullText="เลขสมาชิก"
                                   TextChanged="@(async (string v) => await OnReferMemnoChanged(row, v))" />
                    </td>
                    <td><DxTextBox @bind-Text="row.MemberName" NullText="ชื่อ-สกุล" /></td>
                    <td>
                        <ScCombo Combo="@sc.combo.sc_mem_m_ucf_concern" @bind-Value="row.ConcernCode" NullText="—" />
                    </td>
                    <td><DxButton Text="ลบ" RenderStyle="ButtonRenderStyle.Danger" Click="() => RemoveRefer(row)" /></td>
                </tr>
            }
        </tbody>
    </table>
}

@* ── รูปถ่าย / ลายเซ็น ────────────────────────────────────────────────────────── *@
<h3 class="nb-h3" style="margin-top:24px">รูปถ่าย / ลายเซ็น</h3>
<div class="nb-imgrow" style="margin-top:12px">
    <div class="nb-imgcell">
        <span class="nb-sub">รูปถ่าย</span>
        @if (Form.PictureBase64 is not null)
        {
            <img class="nb-img" src="data:image/*;base64,@Form.PictureBase64" alt="รูปถ่าย" />
        }
        else
        {
            <div class="nb-img nb-img--empty">ยังไม่มีรูป</div>
        }
        <InputFile OnChange="@(e => OnImage(e, isSignature: false))" accept="image/*" />
    </div>
    <div class="nb-imgcell">
        <span class="nb-sub">ลายเซ็น</span>
        @if (Form.SignatureBase64 is not null)
        {
            <img class="nb-img" src="data:image/*;base64,@Form.SignatureBase64" alt="ลายเซ็น" />
        }
        else
        {
            <div class="nb-img nb-img--empty">ยังไม่มีลายเซ็น</div>
        }
        <InputFile OnChange="@(e => OnImage(e, isSignature: true))" accept="image/*" />
    </div>
</div>

@* ── address sub-form (ใช้ซ้ำ 3 ที่อยู่) ─────────────────────────────────────────── *@
@{
    RenderFragment AddressBlock(string title, AppAddressDto a, params (string label, AppAddressDto src)[] sources) =>
    @<DxFormLayoutGroup Caption="@title" ColSpanMd="12">
        @if (sources.Length > 0)
        {
            <DxFormLayoutItem Caption="คัดลอกจาก" ColSpanMd="12">
                <div class="nb-addr-copy">
                    @foreach (var s in sources)
                    {
                        var from = s.src;
                        <DxButton Text="@($"คัดลอก {s.label}")" RenderStyle="ButtonRenderStyle.Secondary"
                                  RenderStyleMode="ButtonRenderStyleMode.Outline" SizeMode="SizeMode.Small"
                                  Click="@(() => CopyAddress(from, a))" />
                    }
                </div>
            </DxFormLayoutItem>
        }
        <DxFormLayoutItem Caption="บ้านเลขที่" ColSpanMd="3">
            <DxTextBox @bind-Text="a.AddressNo" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="หมู่" ColSpanMd="3">
            <DxTextBox @bind-Text="a.Moo" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="หมู่บ้าน/อาคาร" ColSpanMd="6">
            <DxTextBox @bind-Text="a.Mooban" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="ซอย" ColSpanMd="6">
            <DxTextBox @bind-Text="a.Soi" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="ถนน" ColSpanMd="6">
            <DxTextBox @bind-Text="a.Road" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="จังหวัด" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_province" Value="@a.ProvinceCode"
                     ValueChanged="@(v => OnProvinceChanged(a, v))" NullText="— เลือกจังหวัด —" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="อำเภอ/เขต" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_district" Args="@(new object?[] { a.ProvinceCode })"
                     Value="@a.DistrictCode" ValueChanged="@(v => OnDistrictChanged(a, v))"
                     NullText="— เลือกอำเภอ —" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="ตำบล/แขวง" ColSpanMd="4">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_subdistrict" Args="@(new object?[] { a.DistrictCode })"
                     @bind-Value="a.Tambol" NullText="— เลือกตำบล —" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="รหัสไปรษณีย์" ColSpanMd="4">
            <DxTextBox @bind-Text="a.Postcode" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="โทรศัพท์" ColSpanMd="4">
            <DxTextBox @bind-Text="a.Telephone" />
        </DxFormLayoutItem>
    </DxFormLayoutGroup>;
}

@code {
    [Parameter, EditorRequired] public ApplicationFormDto Form { get; set; } = default!;

    // กล่องข้อความกลาง (cascade จาก Page) — เลียน sc.message/sc.notify ของ legacy
    [CascadingParameter] public ScMessage? Msg { get; set; }
    // popup รายชื่อ ปปง. (cascade จาก Page) — legacy popValidateAML
    [CascadingParameter] public PopValidateAML? Aml { get; set; }

    // alias ของ Form.WorkInfo (Index รับประกันว่าไม่ null ผ่าน EnsureSubObjects)
    private AppWorkInfoDto Work => Form.WorkInfo!;

    // ── value-change: คำนำหน้า → เพศ + สถานภาพสมรส (legacy change_prename_code) ──────
    private async Task OnPrenameChanged(string? value)
    {
        Form.PrenameCode = value;
        var d = await Svc.GetPrenameDefaultAsync(value ?? "");
        Form.Sex            = d.Sex;
        Form.MarriageStatus = d.MarriageStatus;
    }

    // ── value-change: กลุ่มสมาชิก → กลุ่มช่วยเลือกตั้ง (legacy change_member_group_no) ──
    private async Task OnMemberGroupChanged(string? value)
    {
        Form.MemberGroupNo = value;
        Form.ElectionGroup = await Svc.GetElectionHelpGroupAsync(value ?? "");
    }

    // ── value-change: วันเกิด → อายุ + เตือนถ้าอายุ < 20 (legacy change_date_of_birth) ──
    private async Task OnDateOfBirthChanged(DateTime? date)
    {
        Form.DateOfBirth = date;
        if (date is null) { Form.AgeText = null; return; }

        Form.AgeText = await Svc.CalcAgeTextAsync(date.Value);

        // อายุยังไม่ถึง 20 ปีบริบูรณ์ → เตือน (ดึงจำนวนปีจากข้อความหน้า "ปี")
        var ageText = Form.AgeText ?? "";
        var yearOld = ageText.Contains("ปี")
            ? sc.value.toInteger(ageText[..ageText.IndexOf("ปี")]) : 0;
        if (yearOld < 20 && Msg is not null)
            await Msg.Info($"ผู้สมัครเกิดวันที่ {sc.value.toStringTH(date)}, อายุ {ageText}<br>อายุยังไม่ถึง 20 ปี บริบูรณ์");
    }

    // ── value-change: เลขบัตร ปชช. (legacy change_hum_id + ofValidateHumid) ──────────
    private string? _humIdOld;
    private async Task OnHumIdChanged(string? v)
    {
        Form.HumId = v;
        var digits = sc.mask.ofDigits(v);

        // 0000000000000 = bypass (ใช้สมัครนิติบุคคล) — ไม่ต้องเช็ค
        if (digits == "0000000000000") { _humIdOld = v; return; }

        // เช็คเฉพาะสัญชาติไทย (01) ตาม legacy
        if (Form.NationalityCode == "01")
        {
            if (!sc.value.isValidIdCard(digits))
            {
                Form.HumId = _humIdOld;
                if (Msg is not null) await Msg.Error($"เลขบัตรประชาชน: {v} ,ไม่ถูกต้อง");
                return;
            }

            var r = await Svc.ValidateHumIdAsync(digits, Form.ApplyDate ?? DateTime.Today);
            if (r.AmlMatch)
            {
                // legacy เปิด popup ปปง. (popValidateAML) แล้วไม่ให้ใช้เลขนี้
                Form.HumId = "";
                if (Aml is not null) await Aml.ShowAsync("popHumID", "", "", digits);
            }
            else if (!r.AllowRegister)
            {
                Form.HumId = "";
                if (Msg is not null && !string.IsNullOrWhiteSpace(r.Message)) await Msg.Error(r.Message);
            }
            else if (!string.IsNullOrWhiteSpace(r.Message))
            {
                Form.ApplTypeCode = "M";   // เคยเป็นสมาชิก/ค้ำ → ประเภทการสมัคร = ย้าย (M)
                if (Msg is not null) await Msg.Info(r.Message);
            }
        }
        _humIdOld = v;
    }

    // เปลี่ยนสัญชาติ → re-validate เลขบัตร (legacy change_nationality_code)
    private async Task OnNationalityChanged(string? v)
    {
        Form.NationalityCode = v;
        await OnHumIdChanged(Form.HumId);
    }

    // ── value-change: ชื่อ-สกุล → เช็คซ้ำ/ปปง. (legacy change_name + of_validate_name) ──
    private async Task OnNameChanged()
    {
        var name = Form.MemberName ?? "";
        var surname = Form.MemberSurname ?? "";
        if (name == "" || surname == "") return;

        var r = await Svc.ValidateNameAsync(name, surname);
        if (Msg is not null && !string.IsNullOrWhiteSpace(r.Message))
            await Msg.Info(r.Message);
        if (r.AmlMatch && Aml is not null)
            await Aml.ShowAsync("popName", name, surname, "");
    }

    // ── value-change: เงินเดือน(รวม) → คำนวณหุ้นใหม่ (legacy change_salary_amount) ─────
    private async Task OnSalaryChanged()
    {
        var total = (Work.SalaryAmount ?? 0) + (Work.AcademicSalary ?? 0) + (Work.RemunerationAmount ?? 0);
        var r = await Svc.UpdateShareMonthlyAsync(Form.MemType ?? "", Form.MemberGroupNo ?? "", "salary_amount", 0, total);
        Form.ShareMonthly = r.ShareMonthly;
        Work.SalaryReal   = total;
    }

    // ── value-change: กรอกหุ้นเอง → เช็คเศษ + min/max (legacy change_share_monthly) ────
    private async Task OnShareMonthlyChanged(decimal? v)
    {
        var newValue = v ?? 0;

        // ค่าหุ้นต้องไม่มีเศษ (หาร 10 ลงตัว)
        if (newValue % 10 != 0)
        {
            Form.ShareMonthly = 0;
            if (Msg is not null) await Msg.Error($"ค่าหุ้น({sc.value.toStringF(newValue)}) ต้องไม่มีเศษ ,กรุณาแก้ไข");
            return;
        }

        Form.ShareMonthly = newValue;
        var salaryAmount = Work.SalaryAmount ?? 0;
        var r = await Svc.UpdateShareMonthlyAsync(Form.MemType ?? "", Form.MemberGroupNo ?? "", "share_monthly", newValue, salaryAmount);
        Form.ShareMonthly = r.ShareMonthly;

        // MWA: ตรวจขั้นต่ำ/สูงสุด (service คืน Min/MaxShare เฉพาะ MWA)
        if (r.MinShare is null && r.MaxShare is null) return;

        var share            = Form.ShareMonthly ?? 0;
        var maxSharePerSalary = salaryAmount / 10;
        var maximumShare      = r.MaxShare ?? 0;

        if (r.MinShare is decimal min && share < min)
        {
            Form.ShareMonthly = min;
            if (Msg is not null) await Msg.Alert($"ไม่สามารถส่งหุ้นน้อยกว่า [ {min} ] บาท ได้");
            return;
        }
        if (share > maxSharePerSalary)
        {
            if (maxSharePerSalary > maximumShare)
            {
                Form.ShareMonthly = maximumShare;
                if (Msg is not null) await Msg.Alert($"ไม่สามารถส่งหุ้นมากกว่า [ {maximumShare} ] บาท ได้");
            }
            else
            {
                Form.ShareMonthly = maxSharePerSalary;
                if (Msg is not null) await Msg.Alert($"ไม่สามารถส่งหุ้นมากกว่า 10% ของเงินเดือนได้ [ {maxSharePerSalary} บาท ]");
            }
            return;
        }
        if (share > maximumShare)
        {
            Form.ShareMonthly = maximumShare;
            if (Msg is not null) await Msg.Alert($"ไม่สามารถส่งหุ้นมากกว่า [ {maximumShare} ] บาท ได้");
        }
    }

    // ── value-change: สมาชิกอ้างอิง เลขสมาชิก → ดึงชื่อ (legacy ofCheckMemno) ──────────
    private async Task OnReferMemnoChanged(AppMemberReferDto row, string? v)
    {
        var r = await Svc.LookupMemberAsync(v ?? "");
        if (r is null)
        {
            row.MembershipNo = "";

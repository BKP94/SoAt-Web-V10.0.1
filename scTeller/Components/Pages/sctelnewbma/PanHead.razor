    // ── value-change: เลขบัตร ผู้รับผลประโยชน์ (legacy gvGain.change_id_card) ──────────
    private readonly Dictionary<AppRecrieveGainDto, string?> _gainIdOld = new();
    private async Task OnGainIdCardChanged(AppRecrieveGainDto row, string? v)
    {
        var digits = sc.mask.ofDigits(v);
        if (!string.IsNullOrEmpty(digits) && !sc.value.isValidIdCard(digits))
        {
            row.GainIdCard = _gainIdOld.GetValueOrDefault(row);   // revert ค่าเดิม
            if (Msg is not null) await Msg.Error($"เลขบัตรประชาชน: [{v}] ,ไม่ถูกต้อง");
            return;
        }
        row.GainIdCard      = v;
        _gainIdOld[row]     = v;
    }

    private decimal GainPercentTotal => Form.RecrieveGains.Sum(g => g.GainPercent ?? 0m);

    // ── คัดลอกที่อยู่ข้ามชุด (ปัจจุบัน ↔ ทะเบียนบ้าน ↔ ที่ทำงาน) ───────────────────
    // copy ทุก field ยกเว้น AddressType (คงประเภทของช่องปลายทาง)
    private void CopyAddress(AppAddressDto from, AppAddressDto to)
    {
        to.AddressNo    = from.AddressNo;
        to.Moo          = from.Moo;
        to.Mooban       = from.Mooban;
        to.Soi          = from.Soi;
        to.Road         = from.Road;
        to.ProvinceCode = from.ProvinceCode;
        to.DistrictCode = from.DistrictCode;
        to.Tambol       = from.Tambol;
        to.Postcode     = from.Postcode;
        to.Telephone    = from.Telephone;
    }

    private void OnProvinceChanged(AppAddressDto a, string? value)
    {
        a.ProvinceCode = value;
        a.DistrictCode = null;   // reset ลูกหลานเมื่อเปลี่ยนจังหวัด
        a.Tambol       = null;
    }

    private async Task OnDistrictChanged(AppAddressDto a, string? value)
    {

@* PanOperate — แถบปุ่ม Operate (แนวตั้ง, ขวาของหน้า) — New / Open / Save / Cancel
   ปุ่ม raise EventCallback กลับให้ Page จัดการ logic (Page ถือ model) *@

<div class="op-orbit-toolbar" role="toolbar" aria-label="เครื่องมือสมัครสมาชิก">
    <span class="op-orbit-heading">เครื่องมือ</span>

    <div class="op-orbit-item op-orbit-item--primary">
        <DxButton RenderStyle="ButtonRenderStyle.Primary"
                  title="เพิ่มใหม่" aria-label="เพิ่มใหม่"
                  disabled="@Busy" @onclick="OnNew" CssClass="op-btn"
                  IconCssClass="bi bi-file-earmark-plus" />
        <span class="op-orbit-label">เพิ่มใหม่</span>
    </div>

    <div class="op-orbit-item">
        <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  title="เปิด / ค้นหา" aria-label="เปิด / ค้นหา"
                  disabled="@Busy" @onclick="OnOpen" CssClass="op-btn"
                  IconCssClass="bi bi-folder2-open" />
        <span class="op-orbit-label">เปิด</span>
    </div>

    <div class="op-orbit-item">
        <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  title="บันทึก" aria-label="บันทึก"
                  disabled="@Busy" @onclick="OnSave" CssClass="op-btn"
                  IconCssClass="bi bi-floppy" />
        <span class="op-orbit-label">บันทึก</span>
    </div>

    <div class="op-orbit-item">
        <DxButton RenderStyle="ButtonRenderStyle.Danger"
                  title="ยกเลิก" aria-label="ยกเลิก"
                  disabled="@Busy" @onclick="OnCancel" CssClass="op-btn op-btn--cancel"
                  IconCssClass="bi bi-x-lg" />
        <span class="op-orbit-label">ยกเลิก</span>
    </div>
</div>

@code {
    /// ปิดปุ่มทั้งหมดระหว่างกำลังบันทึก
    [Parameter] public bool Busy { get; set; }

    [Parameter] public EventCallback OnNew    { get; set; }
    [Parameter] public EventCallback OnOpen   { get; set; }
    [Parameter] public EventCallback OnSave   { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
}

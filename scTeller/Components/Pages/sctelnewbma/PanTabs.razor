@using SoAt.Application.ScTeller
@using scTeller.Components.Pages.sctelnewbma.tabs

@* ── PanTabs (Tabs region) ของ sctelnewbma ───────────────────────────────────────
   main ที่รวม 3 แท็บ — แต่ละแท็บแยกเป็นไฟล์ใน tabs/ (เลียนโครง legacy panTabs.ascx
   ที่โหลด user control u_tabpg_newmem_*.ascx แต่ละตัวมาประกอบ)
     • บัญชีธนาคาร          → UTabpgNewmemBankinfo
     • ข้อมูลครอบครัว        → UTabpgNewmemSpouseInfo
     • ข้อมูลการส่งหุ้น/โอน   → UTabpgNewmemShareReceive
   PanTabs เป็นแค่ตัวจัด tab — ส่ง Form/Lookups (reference ร่วม) ลงแต่ละ tab ตรง *@

<DxTabs CssClass="nb-tabs">
    <DxTabPage Text="บัญชีธนาคาร">
        <div class="nb-tabbody">
            <UTabpgNewmemBankinfo Form="Form" Lookups="Lookups" />
        </div>
    </DxTabPage>

    <DxTabPage Text="ข้อมูลครอบครัว">
        <div class="nb-tabbody">
            <UTabpgNewmemSpouseInfo Form="Form" Lookups="Lookups" />
        </div>
    </DxTabPage>

    <DxTabPage Text="ข้อมูลการส่งหุ้น/โอน">
        <div class="nb-tabbody">
            <UTabpgNewmemShareReceive Form="Form" Lookups="Lookups" />
        </div>
    </DxTabPage>
</DxTabs>

@code {
    [Parameter, EditorRequired] public ApplicationFormDto Form { get; set; } = default!;
    [Parameter, EditorRequired] public SctelnewbmaLookupsDto Lookups { get; set; } = default!;
}

@using SoAt.Application.ScTeller
@inject ISctelnewbmaService Svc

@* ── PopOpen — ค้นหา/เปิดใบสมัครที่บันทึกไว้ (เลียน legacy sctelnewbma/pops/popOpen.ascx) ──
   DxPopup: แถบ filter (เลขใบสมัคร/ชื่อ/สกุล/หน่วย/สถานะ) + ตารางผลค้นหา
   เลือกแถว → ยิง EventCallback OnSelected(application_form_no) กลับให้ Page เปิดใบสมัคร
   เป็น dumb-ish component: ถือ filter + ผลลัพธ์ของตัวเอง, ไม่ persist อะไร *@

<DxPopup @bind-Visible="Visible" HeaderText="ค้นหาใบสมัครสมาชิก"
         Width="980px" Height="640px" ShowFooter="true"
         CloseOnEscape="true" Shown="OnShownAsync">
    <BodyContentTemplate Context="popup">
        @* ── แผงค้นหา ─────────────────────────────────────────────────────── *@
        <div class="po-search">
            <div class="po-search__head">
                <span class="po-search__icon">🔍</span>
                <span class="po-search__title">เงื่อนไขการค้นหา</span>
            </div>
            @* DevExpress: อัปเดตทุกคีย์ใช้ BindValueMode.OnInput (ไม่ใช่ @bind-Text:event="oninput"
               ซึ่งเป็นของ HTML element → ส่ง ChangeEventArgs เข้า setter string แล้ว circuit crash) *@
            <div class="po-fields">
                <label class="po-field">
                    <span class="po-field__label">เลขที่ใบสมัคร</span>
                    <DxTextBox @bind-Text="_filter.ApplicationFormNo" NullText="เช่น 6900001"
                               BindValueMode="BindValueMode.OnInput" />
                </label>
                <label class="po-field">
                    <span class="po-field__label">ชื่อ</span>
                    <DxTextBox @bind-Text="_filter.MemberName" NullText="ชื่อผู้สมัคร"
                               BindValueMode="BindValueMode.OnInput" />
                </label>
                <label class="po-field">
                    <span class="po-field__label">นามสกุล</span>
                    <DxTextBox @bind-Text="_filter.MemberSurname" NullText="นามสกุล"
                               BindValueMode="BindValueMode.OnInput" />
                </label>
                <label class="po-field">
                    <span class="po-field__label">หน่วย</span>
                    <DxTextBox @bind-Text="_filter.MemberGroup" NullText="เลขหน่วย / ชื่อหน่วย"
                               BindValueMode="BindValueMode.OnInput" />
                </label>
                <label class="po-field">
                    <span class="po-field__label">สถานะใบสมัคร</span>
                    <DxComboBox Data="_statuses" TData="ComboItemDto" TValue="string"
                                ValueFieldName="@nameof(ComboItemDto.Code)" TextFieldName="@nameof(ComboItemDto.Name)"
                                @bind-Value="_filter.ApproveStatus" NullText="ทุกสถานะ"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                </label>
            </div>
            <div class="po-actions">
                <DxButton Text="ล้างเงื่อนไข" RenderStyle="ButtonRenderStyle.Secondary" Click="ClearAsync" />
                <DxButton Text="ค้นหา" RenderStyle="ButtonRenderStyle.Primary" Click="SearchAsync" />
            </div>
        </div>

        @* ── แถบสรุปผล ────────────────────────────────────────────────────── *@
        @if (_searched)
        {
            <div class="po-resultbar">
                <span class="po-resultbar__count">พบ <b>@_rows.Count</b> รายการ</span>
            </div>
        }

        @* ── ผลการค้นหา ───────────────────────────────────────────────────── *@
        @if (_rows.Count == 0 && _searched)
        {
            <div class="po-empty">
                <div class="po-empty__icon">📭</div>
                <div class="po-empty__text">ไม่พบใบสมัครที่ตรงกับเงื่อนไข</div>
                <div class="po-empty__hint">ลองปรับเงื่อนไขแล้วค้นหาอีกครั้ง</div>
            </div>
        }
        else if (_rows.Count > 0)
        {
            <DxGrid Data="_rows" CssClass="po-grid" PageSize="12"
                    ColumnResizeMode="GridColumnResizeMode.NextColumn">
                <Columns>
                    <DxGridDataColumn Caption="เลขที่ใบสมัคร" FieldName="@nameof(ApplicationSummaryDto.ApplicationFormNo)"
                                      Width="120px" TextAlignment="GridTextAlignment.Center" />
                    <DxGridDataColumn Caption="วันที่สมัคร" Width="110px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                        <CellDisplayTemplate>
                            @{ var r = (ApplicationSummaryDto)context.DataItem; }
                            @sc.value.toStringTH(r.ApplyDate)
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn Caption="ชื่อ - สกุล" FieldName="@nameof(ApplicationSummaryDto.MemberName)" />
                    <DxGridDataColumn Caption="หน่วย" FieldName="@nameof(ApplicationSummaryDto.MemberGroup)" />
                    <DxGridDataColumn Caption="สถานะ" Width="130px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                        <CellDisplayTemplate>
                            @{ var r = (ApplicationSummaryDto)context.DataItem; }
                            <span class="@StatusBadgeClass(r.ApproveStatus)">@StatusText(r.ApproveStatus)</span>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn Caption="" Width="84px" AllowSort="false">
                        <CellDisplayTemplate>
                            @{ var r = (ApplicationSummaryDto)context.DataItem; }
                            <DxButton Text="เปิด" RenderStyle="ButtonRenderStyle.Primary"
                                      CssClass="po-openbtn" Click="() => SelectAsync(r.ApplicationFormNo)" />
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                </Columns>
            </DxGrid>
        }
        else
        {
            <div class="po-empty po-empty--idle">
                <div class="po-empty__icon">🗂️</div>
                <div class="po-empty__text">ระบุเงื่อนไขแล้วกด “ค้นหา”</div>
            </div>
        }
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton Text="ปิดหน้าจอ" RenderStyle="ButtonRenderStyle.Secondary" Click="Close" />
    </FooterContentTemplate>
</DxPopup>

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }

    /// เลือกใบสมัครแล้ว — ส่ง application_form_no กลับให้ Page เปิด
    [Parameter] public EventCallback<string> OnSelected { get; set; }

    private ApplicationSearchFilter        _filter   = new();
    private List<ApplicationSummaryDto>     _rows     = [];
    private List<ComboItemDto>              _statuses = [];
    private bool                            _searched;

    protected override async Task OnInitializedAsync() =>
        _statuses = await Svc.GetApplicationStatusesAsync();

    // เปิด popup ครั้งใด → โหลดรายการล่าสุด (filter ปัจจุบัน)
    private Task OnShownAsync() => SearchAsync();

    private async Task SearchAsync()
    {
        _rows = await Svc.SearchApplicationsAsync(_filter);
        _searched = true;
    }

    // ล้างเงื่อนไข → ค้นหาใหม่ (แสดงทั้งหมด)
    private async Task ClearAsync()
    {
        _filter = new();
        await SearchAsync();
    }

    private async Task SelectAsync(string? applicationFormNo)
    {
        if (string.IsNullOrWhiteSpace(applicationFormNo)) return;
        await CloseInternal();
        await OnSelected.InvokeAsync(applicationFormNo);
    }

    private Task Close() => CloseInternal();

    private async Task CloseInternal()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
    }

    // แปลง code สถานะ → ข้อความ (จาก sc.combo.application_form_status ที่โหลดไว้)
    private string StatusText(string? code) =>
        _statuses.FirstOrDefault(s => s.Code == code)?.Name ?? code ?? "";

    // สีของ badge ตามสถานะ: 2=รออนุมัติ(amber) 1=อนุมัติ(green) 0=ไม่อนุมัติ(gray) 3=ยกเลิก(red)
    private string StatusBadgeClass(string? code) => "po-badge " + code switch
    {
        "2" => "po-badge--wait",
        "1" => "po-badge--ok",
        "0" => "po-badge--no",
        "3" => "po-badge--cancel",
        _   => "po-badge--no",
    };
}

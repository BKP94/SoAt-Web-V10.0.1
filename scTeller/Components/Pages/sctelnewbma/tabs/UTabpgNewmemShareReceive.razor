@using SoAt.Application.ScTeller

@* ── tab: ข้อมูลการส่งหุ้น/โอน (legacy u_tabpg_newmem_share_receive) ──────────────
   ข้อมูลการรับโอน (sc_mem_m_app_own_info / Form.OwnInfo):
     โอนมาจาก(ที่เดิม) / วันที่เป็นสมาชิก(ที่เดิม) / หนี้สิน(ที่เดิม) / มติที่ประชุม
   dumb component — แก้ field ลงบน Form.OwnInfo (reference ร่วม) ตรง *@

<DxFormLayout>
    <DxFormLayoutGroup Caption="ข้อมูลการรับโอน" ColSpanMd="12">
        <DxFormLayoutItem Caption="โอนมาจาก (ที่เดิม)" ColSpanMd="12">
            <ScCombo Combo="@sc.combo.sc_mem_m_ucf_othersaving" @bind-Value="Own.OtherSaving"
                     NullText="— เลือกสหกรณ์/หน่วยงานเดิม —" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="จำนวนเดือน (ย้อนหลัง)" ColSpanMd="6">
            @* legacy of_cal_first_date: กรอกจำนวนเดือน → คำนวณวันที่เป็นสมาชิก = วันนี้ − n เดือน *@
            <ScInput Col="@sc.css.col.Integer" Value="_calcMonth" TValue="int?"
                     ValueChanged="OnCalcMonthChanged" NullText="ระบุจำนวนเดือน" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="วันที่เป็นสมาชิก (ที่เดิม)" ColSpanMd="6">
            <DxDateEdit @bind-Date="Own.FirstDate" NullText="วัน/เดือน/ปี" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="หนี้สิน (ที่เดิม)" ColSpanMd="6">
            <ScInput Col="@sc.css.col.Decimal" @bind-Value="Own.OwnTotalLoan" NullText="0.00" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="มติที่ประชุม" ColSpanMd="12">
            <DxTextBox @bind-Text="Own.MatiDetail" NullText="รายละเอียดมติที่ประชุม" />
        </DxFormLayoutItem>
    </DxFormLayoutGroup>
</DxFormLayout>

@code {
    [Parameter, EditorRequired] public ApplicationFormDto Form { get; set; } = default!;

    // alias ของ Form.OwnInfo (Page รับประกันไม่ null ผ่าน EnsureSubObjects)
    private AppOwnInfoDto Own => Form.OwnInfo!;

    private int? _calcMonth;

    // legacy of_cal_first_date: วันที่เป็นสมาชิก(ที่เดิม) = วันนี้ − cal_c_month เดือน
    private void OnCalcMonthChanged(int? v)
    {
        _calcMonth = v;
        Own.FirstDate = v is int m ? DateTime.Today.AddMonths(-m) : null;
    }
}

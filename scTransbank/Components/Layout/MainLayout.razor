@inherits LayoutComponentBase
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject IConfiguration Config
@inject SoAt.Application.Sc.IScAppService ScApps
@inject AuthenticationStateProvider AuthState

<div class="app-shell">
    @* CSS-only mobile drawer: desktop แสดง sidebar ค้าง, mobile ใช้ checkbox นี้เปิด/ปิด *@
    <input type="checkbox" id="tel-nav-toggle" class="tel-nav-toggle" />

    <aside class="app-sidebar">
        <div class="sidebar-brand">
            <a class="brand-link" href="@ScCenterUrl" title="กลับ SoAt Center">
                <span class="brand-mark">SA</span>
                <span class="brand-copy">
                    <span class="brand-name">SoAt</span>
                    <span class="brand-caption">COOPERATIVE SOLUTION</span>
                </span>
            </a>
        </div>

        <div class="sidebar-context">
            <span class="sidebar-context-kicker">WORKSPACE</span>
            <strong>ระบบโอนเงินธนาคาร</strong>
            <span>ระบบงาน scTransbank</span>
        </div>

        @* เมนูหลัก (vertical) — แสดงเมื่อ login แล้ว, โหลดจาก si_security_apps *@
        <AuthorizeView>
            <Authorized>
                <nav class="sidebar-nav">
                    <TopMenu />
                </nav>
            </Authorized>
        </AuthorizeView>

        <div class="sidebar-foot">
            <span class="sidebar-foot-mark" aria-hidden="true"></span>
            <span class="sidebar-module">SoAt Solution</span>
        </div>
    </aside>

    <label for="tel-nav-toggle" class="app-sidebar-scrim" aria-label="ปิดเมนู"></label>

    <div class="app-body">
        <header class="app-topbar">
            <label for="tel-nav-toggle" class="topbar-burger" title="เปิดหรือปิดเมนู" aria-label="เปิดหรือปิดเมนู">
                <i class="bi bi-list" aria-hidden="true"></i>
            </label>
            <span class="app-module">
                <span class="app-module-kicker">ระบบงาน</span>
                <strong>scTransbank</strong>
            </span>

            <div class="app-topbar-spacer"></div>

            <AuthorizeView>
                <Authorized>
                    @* สถานะระบบ (เหมือน scCenter): วันที่การเงิน + เงินสดในมือ + ฐานข้อมูล — วางข้างชื่อผู้ใช้ *@
                    <div class="app-status">
                        <span class="app-status-item">
                            <i class="bi bi-calendar3" aria-hidden="true"></i>
                            <span class="app-status-copy">
                                <span class="app-status-k">วันที่การเงิน</span>
                                <span class="app-status-v">@(_info?.FinanceDate ?? "—")</span>
                            </span>
                        </span>
                        <span class="app-status-item">
                            <i class="bi bi-cash-coin" aria-hidden="true"></i>
                            <span class="app-status-copy">
                                <span class="app-status-k">เงินสดในมือ</span>
                                <span class="app-status-v">@(_info?.CashBalance ?? "-")</span>
                            </span>
                        </span>
                        <span class="app-status-item">
                            <i class="bi bi-database" aria-hidden="true"></i>
                            <span class="app-status-copy">
                                <span class="app-status-k">ฐานข้อมูล</span>
                                <span class="app-status-v">@(string.IsNullOrEmpty(_info?.SysName) ? "—" : _info!.SysName)</span>
                            </span>
                        </span>
                    </div>
                    <div class="app-userbox">
                        <span class="app-avatar">@Initial(context.User.Identity?.Name)</span>
                        <span class="app-userinfo">
                            <span class="app-username">@context.User.Identity?.Name</span>
                            <span class="app-userbranch">สาขา @context.User.FindFirst("branch_id")?.Value</span>
                        </span>
                    </div>
                    <form method="post" action="/logout" class="app-logout-form">
                        <AntiforgeryToken />
                        <button type="submit" class="app-logout">ออกจากระบบ</button>
                    </form>
                </Authorized>
            </AuthorizeView>
        </header>

        <main class="app-main">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string ScCenterUrl => Config["ScCenter:Url"] ?? "http://localhost:5100";

    // แถบสถานะ (วันที่การเงิน + เงินสดในมือ + ฐานข้อมูล) — ดึงจากแหล่งเดียวกับ scCenter, guard ไว้ใน service แล้ว
    private SoAt.Application.Sc.ScCenterInfoDto? _info;

    protected override async Task OnInitializedAsync()
    {
        // อ่าน user จาก cookie claims (มีตอน static SSR) แล้วส่งเข้า service ตรงๆ —
        //   getCashBalance() พึ่ง current_setting('app.login_*') ต้องมี userId/branchId ถึงจะ SET LOCAL
        //   (ambient sc.appUser ไม่ถูกโหลดใน static SSR เพราะ AppUserCircuitHandler ทำงานเฉพาะ circuit)
        string? uid = null, br = null;
        var user = (await AuthState.GetAuthenticationStateAsync()).User;
        if (user.Identity?.IsAuthenticated == true)
        {
            uid = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            br  = user.FindFirst("branch_id")?.Value;
        }

        try { _info = await ScApps.GetCenterInfoAsync(uid, br); } catch { }
    }

    // ตัวอักษรแรกของชื่อ → avatar (ไทย/อังกฤษ)
    private static string Initial(string? name) =>
        string.IsNullOrWhiteSpace(name) ? "?" : name.Trim()[..1].ToUpperInvariant();
}
